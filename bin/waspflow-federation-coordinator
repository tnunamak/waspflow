#!/usr/bin/env node
/*
 * Owner-hosted Federation v0 coordinator process. "Tim runs a coordinator
 * he hosts" is literally this: a single foreground HTTP server, started
 * with one command, kept running under systemd/tmux/whatever the operator
 * already uses for long-lived processes (this script does not daemonize
 * itself, matching waspflow-federation-injector's style).
 *
 * Raw operation is env-only to keep it trivially scriptable. The managed host
 * flow invokes `--host-config <host.json>`, which supplies those same values
 * from a private, generated state directory and may attach an ngrok tunnel:
 *   WASPFLOW_FEDERATION_COORDINATOR_PORT       default 8787
 *   WASPFLOW_FEDERATION_COORDINATOR_HOST       default 127.0.0.1
 *   WASPFLOW_FEDERATION_COORDINATOR_DATA_DIR   default ~/.waspflow/federation-coordinator/tasks
 *   WASPFLOW_FEDERATION_COLLECTIVE_TOKEN       required, shared-secret gate (see lib/federation-coordinator.mjs)
 *   WASPFLOW_FEDERATION_COORDINATOR_ROSTER_FILE
 *                                               required, JSON file mapping key_id -> public key PEM for every
 *                                               registered collective member (author AND executor keys share this
 *                                               one flat roster — see lib/federation-coordinator.mjs's roster
 *                                               comment for why). Shape:
 *                                                 { "tim-author": "-----BEGIN PUBLIC KEY-----\n...", "ocean-executor": "..." }
 *                                               HOT-RELOADED: this file is watched, and a valid edit replaces the
 *                                               live roster IN PLACE with no restart required, so onboarding a new
 *                                               member (`waspflow federation join` prints a one-line snippet to
 *                                               append here) takes effect the moment Tim saves the file. This does
 *                                               NOT add a network-reachable registration surface — the file is
 *                                               still hand-edited, local, and requires host filesystem access to
 *                                               change; only the "restart required" friction is removed. A
 *                                               malformed edit is REJECTED and logged, leaving the previous good
 *                                               roster live (never silently drops to zero members or crashes the
 *                                               server on a bad save). Removing a line + saving is still the only
 *                                               revocation mechanism v0 supports (now live, not restart-gated).
 */
'use strict';

const fs = require('node:fs');
const os = require('node:os');
const path = require('node:path');

function fail(message) {
  process.stderr.write(`waspflow-federation-coordinator: ${message}\n`);
  process.exit(1);
}

function parseRosterFile(rosterFile) {
  const rosterJson = JSON.parse(fs.readFileSync(rosterFile, 'utf8'));
  if (!rosterJson || typeof rosterJson !== 'object' || Array.isArray(rosterJson)) {
    throw new Error(`must contain a JSON object of key_id -> PEM string`);
  }
  const entries = Object.entries(rosterJson);
  if (entries.length === 0) throw new Error('has no roster entries');
  for (const [keyId, pem] of entries) {
    if (typeof pem !== 'string' || !pem) throw new Error(`roster entry "${keyId}" must map to a PEM string`);
  }
  return entries;
}

// Reloads `rosterFile` into `liveRoster` IN PLACE (same Map instance the
// coordinator's request handlers already read from), so a change takes
// effect on the very next request with no restart. A bad edit is rejected
// and logged rather than applied — the previous good roster keeps serving.
function watchRosterFile(rosterFile, liveRoster) {
  fs.watch(rosterFile, { persistent: true }, (eventType) => {
    if (eventType !== 'change' && eventType !== 'rename') return;
    let entries;
    try {
      entries = parseRosterFile(rosterFile);
    } catch (error) {
      process.stderr.write(`waspflow-federation-coordinator: roster file reload rejected (keeping previous roster): ${error.message}\n`);
      return;
    }
    liveRoster.clear();
    for (const [keyId, pem] of entries) liveRoster.set(keyId, pem);
    process.stderr.write(`waspflow-federation-coordinator: roster reloaded (${liveRoster.size} member(s))\n`);
  });
}

async function main() {
  const { startCoordinator } = await import('../lib/federation-coordinator.mjs');

  const hostConfigFlag = process.argv.slice(2);
  const hostConfigIndex = hostConfigFlag.indexOf('--host-config');
  const hostConfigFile = hostConfigIndex === -1 ? null : hostConfigFlag[hostConfigIndex + 1];
  if (hostConfigIndex !== -1 && (!hostConfigFile || hostConfigFlag.length !== 2)) {
    fail('usage: waspflow-federation-coordinator [--host-config <host.json>]');
  }
  let hostConfig = null;
  if (hostConfigFile) {
    try { hostConfig = JSON.parse(fs.readFileSync(hostConfigFile, 'utf8')); } catch (error) {
      fail(`could not read host configuration ${hostConfigFile}: ${error.message}`);
    }
  }

  const token = hostConfig
    ? fs.readFileSync(hostConfig.collective_token_path, 'utf8').trim()
    : process.env.WASPFLOW_FEDERATION_COLLECTIVE_TOKEN;
  if (!token) fail('WASPFLOW_FEDERATION_COLLECTIVE_TOKEN is required (shared-secret collective gate)');
  // The managed host flow rotates this private file atomically. Resolve it at
  // request time so a verified rotation takes effect without a coordinator
  // restart; raw env-configured coordinators retain their static token.
  const activeToken = hostConfig
    ? () => fs.readFileSync(hostConfig.collective_token_path, 'utf8').trim()
    : token;

  const rosterFile = hostConfig?.roster_path || process.env.WASPFLOW_FEDERATION_COORDINATOR_ROSTER_FILE;
  if (!rosterFile) fail('WASPFLOW_FEDERATION_COORDINATOR_ROSTER_FILE is required (JSON file mapping key_id -> public key PEM)');
  let entries;
  try {
    entries = parseRosterFile(rosterFile);
  } catch (error) {
    fail(`could not read/parse WASPFLOW_FEDERATION_COORDINATOR_ROSTER_FILE (${rosterFile}): ${error.message}`);
  }
  const roster = new Map(entries);
  watchRosterFile(rosterFile, roster);

  const port = Number(hostConfig?.port || process.env.WASPFLOW_FEDERATION_COORDINATOR_PORT || 8787);
  if (!Number.isInteger(port) || port < 0 || port > 65535) fail('WASPFLOW_FEDERATION_COORDINATOR_PORT must be a valid port number');
  const host = hostConfig?.reachability?.kind === 'lan'
    ? '0.0.0.0'
    : process.env.WASPFLOW_FEDERATION_COORDINATOR_HOST || '127.0.0.1';
  const dataDir = hostConfig?.data_dir || process.env.WASPFLOW_FEDERATION_COORDINATOR_DATA_DIR
    || path.join(os.homedir(), '.waspflow', 'federation-coordinator', 'tasks');

  const server = await startCoordinator({ dataDir, token: activeToken, roster, port, host });
  const address = server.address();
  const statusFile = hostConfig?.status_path;
  let tunnel = null;
  let status = {
    status: 'listening',
    host: address.address,
    port: address.port,
    data_dir: dataDir,
    roster_size: roster.size,
  };
  if (hostConfig?.reachability?.kind === 'url') status.public_url = hostConfig.reachability.publicUrl;
  if (hostConfig?.reachability?.kind === 'lan') status.public_url = hostConfig.reachability.publicUrl;

  if (hostConfig?.reachability?.kind === 'ngrok') {
    let authtoken;
    try { authtoken = fs.readFileSync(hostConfig.reachability.token_path, 'utf8').trim(); } catch (error) {
      status = { ...status, status: 'ngrok_token_missing', error: error.message };
      writeStatus(statusFile, status);
      fail(`could not read ngrok token: ${error.message}`);
    }
    let previousPublicUrl = hostConfig.reachability.previous_public_url || null;
    try { previousPublicUrl = previousPublicUrl || JSON.parse(fs.readFileSync(hostConfig.status_path, 'utf8')).public_url || null; } catch { /* first run */ }
    const configuredDomain = hostConfig.reachability.domain || null;
    try {
      const { startNgrokTunnel, loadNgrokSdkFromRuntime } = await import('../lib/federation-coordinator-hosting.mjs');
      tunnel = await startNgrokTunnel({
        port: address.port,
        authtoken,
        domain: configuredDomain,
        loadSdk: () => loadNgrokSdkFromRuntime(hostConfig.reachability.runtime_path),
      });
      status = { ...status, status: 'public_listening', public_url: tunnel.url };
      const assignedHost = new URL(tunnel.url).hostname;
      if ((configuredDomain && (tunnel.domainFellBack || assignedHost !== configuredDomain)) || (!configuredDomain && previousPublicUrl && previousPublicUrl !== tunnel.url)) {
        status.public_url_changed = true;
        status.previous_public_url = configuredDomain ? `https://${configuredDomain}` : previousPublicUrl;
        process.stderr.write(`warning: the collective's public address changed from ${status.previous_public_url} to ${tunnel.url}; invites sent before this restart no longer work — send fresh ones with: waspflow federation invite\n`);
      }
    } catch (error) {
      const { NgrokUnavailableError } = await import('../lib/federation-coordinator-hosting.mjs');
      status = {
        ...status,
        status: error instanceof NgrokUnavailableError ? 'ngrok_unavailable' : 'ngrok_error',
        error: error.message,
      };
      writeStatus(statusFile, status);
      fail(status.status === 'ngrok_unavailable'
        ? 'ngrok’s built-in connector is unavailable on this platform; install the ngrok agent from https://ngrok.com/download, then run it against the local coordinator port, or restart with --tunnel url:<https://your-address>.'
        : error.message);
    }
  }
  writeStatus(statusFile, status);
  process.stdout.write(JSON.stringify(status) + '\n');

  const shutdown = () => {
    // A stale "public_listening" status after exit misleads liveness readers
    // (host --rotate-token probes, future doctor checks); record the stop.
    writeStatus(statusFile, { status: 'stopped', port: address.port });
    Promise.resolve(tunnel?.close()).catch(() => {}).finally(() => server.close(() => process.exit(0)));
  };
  process.on('SIGINT', shutdown);
  process.on('SIGTERM', shutdown);
  process.on('SIGHUP', shutdown);
}

function writeStatus(file, status) {
  if (!file) return;
  const dir = path.dirname(file);
  fs.mkdirSync(dir, { recursive: true, mode: 0o700 });
  const tmp = path.join(dir, `.${path.basename(file)}.${process.pid}.tmp`);
  fs.writeFileSync(tmp, JSON.stringify(status, null, 2), { mode: 0o600 });
  fs.renameSync(tmp, file);
  fs.chmodSync(file, 0o600);
}

main().catch((error) => fail(error && error.message ? error.message : String(error)));
