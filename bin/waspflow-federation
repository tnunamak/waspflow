#!/usr/bin/env node
/*
 * Guided Federation v0 CLI: `waspflow federation {join,contribute,submit,status,daemon,ui}`.
 *
 * This is the CONSUMABLE layer the owner asked for on top of the proven,
 * already-shipped federation loop (bin/waspflow-federation-{coordinator,
 * submit,pull} + lib/federation-{coordinator,submit,pull-internals,envelope,
 * docker-backend,harness-spec,harnesses,auth-flow}.mjs). It does not
 * reimplement any of that — every verb below either calls straight into the
 * existing libs, or shells out to the existing bins with flags filled in
 * from the managed config, so this file cannot silently drift from the
 * loop those bins/tests already prove correct.
 *
 * Managed config (see lib/federation-config.mjs): ~/.waspflow/federation/
 * config.json holds coordinator_url, collective_token, key_id,
 * private_key_path, and a cached roster. `join` writes it once; every other
 * verb reads it and needs no url/token/key/roster flags at all — a
 * non-technical contributor never sees a PEM path or a task digest unless
 * they explicitly ask for the advanced --task-digest override.
 *
 * Structured output: every verb that matters to a future non-terminal UI
 * (tray/GUI) prints exactly one final JSON line to stdout when --json is
 * given, on top of human-readable progress lines on stderr — so today's
 * CLI and tomorrow's GUI can share the same event shape rather than the
 * GUI screen-scraping terminal prose. This mirrors the structured-handle
 * discipline lib/federation-auth-flow.mjs already established for auth.
 */
'use strict';

const fs = require('node:fs');
const path = require('node:path');
const os = require('node:os');
const { spawn } = require('node:child_process');
const readline = require('node:readline/promises');

function fail(message) {
  process.stderr.write(`waspflow federation: ${message}\n`);
  process.exit(1);
}

function log(message) {
  process.stderr.write(`waspflow federation: ${message}\n`);
}

const ROOT = path.join(__dirname, '..');

// Only an arg that EXACTLY matches a known `--flag-name` (or `--json`) is
// treated as a flag — never "anything starting with --". `trust`'s pubkey
// positional arg is a multi-line PEM string that itself starts with
// "-----BEGIN PUBLIC KEY-----", which begins with "--"; a naive
// starts-with('--') scan would misparse that PEM as an unknown flag.
function parseFlags(argv, known, booleanFlags = []) {
  const flags = {};
  const positional = [];
  for (let i = 0; i < argv.length; i++) {
    const arg = argv[i];
    if (arg === '--json') { flags.json = true; continue; }
    const name = arg.startsWith('--') ? arg.slice(2) : null;
    if (name !== null && booleanFlags.includes(name)) {
      flags[name] = true;
      continue;
    }
    if (name !== null && known.includes(name)) {
      const value = argv[++i];
      if (value === undefined) fail(`--${name} requires a value`);
      flags[name] = value;
      continue;
    }
    positional.push(arg);
  }
  return { flags, positional };
}

// --- sandbox install preflight ---------------------------------------------
//
// This is intentionally the same backend preflight used immediately before a
// contribution. A green `sbx version` alone is not enough: the real runtime
// also needs Docker CE/containerd v2, a healthy daemon, policy, KVM access,
// and Docker login. Keeping the probe in the backend prevents the doctor and
// contribution paths from silently disagreeing.
function preflightHumanLines(preflight) {
  const lines = ['Sandbox install preflight'];
  for (const item of preflight.checks) {
    lines.push(`${item.ok ? 'PASS' : 'FAIL'} ${item.name}: ${item.detail}`);
    if (!item.ok) lines.push(`  Fix: ${item.fix}`);
  }
  if (preflight.ok) lines.push('Your sandbox is ready for Federation contributions.');
  else lines.push('Your sandbox is not ready yet. Fix the failed checks, then re-run: waspflow federation doctor');
  return lines;
}

async function sandboxPreflight({ json, fixPolicy = false, report = true } = {}) {
  const { DockerSbxBackend, initializeDefaultSbxPolicy } = await import('../lib/federation-docker-backend.mjs');
  const backend = new DockerSbxBackend();
  let capabilities = await backend.probeCapabilities();
  let preflight = capabilities.preflight;
  const identityRepairs = capabilities.identity_repairs || [];
  let policyFix = null;

  if (fixPolicy && preflight?.checks.some((item) => item.name === 'network_policy' && !item.ok)) {
    log('initializing the global sandbox network policy with the balanced preset...');
    policyFix = await initializeDefaultSbxPolicy();
    if (policyFix.code === 0) capabilities = await backend.probeCapabilities();
    preflight = capabilities.preflight;
  }

  const result = {
    status: preflight.ok ? 'ready' : 'setup_required',
    backend_id: preflight.backend_id,
    checks: preflight.checks,
  };
  if (identityRepairs.length > 0) result.identity_repairs = identityRepairs;
  if (policyFix) result.policy_fix = { ok: policyFix.code === 0, detail: `${policyFix.stdout || ''}${policyFix.stderr || ''}`.trim() };
  if (report && json) {
    printResult(true, [], result, 'sandbox_preflight');
  } else if (report) {
    for (const line of preflightHumanLines(preflight)) process.stdout.write(`${line}\n`);
    if (policyFix && policyFix.code !== 0) process.stdout.write(`Policy initialization failed: ${result.policy_fix.detail || 'no diagnostic output'}\n`);
  }
  return { ok: preflight.ok, preflight };
}

async function cmdDoctor(argv) {
  const { flags, positional } = parseFlags(argv, [], ['fix-policy']);
  if (positional.length > 0) fail('usage: waspflow federation doctor [--fix-policy] [--json]');
  const result = await sandboxPreflight({ json: flags.json, fixPolicy: flags['fix-policy'] });
  if (!result.ok) process.exitCode = 1;
}

// Runs a child bin, streaming its stderr live (progress lines from the
// existing bins already go to stderr, so a long sandboxed run isn't silent)
// while still buffering both streams so callers can translate a known
// failure into this CLI's own vocabulary and parse the final stdout JSON.
function runChildStreaming(execPath, args, { onEvent } = {}) {
  return new Promise((resolve) => {
    const child = spawn(execPath, args, { stdio: ['inherit', 'pipe', 'pipe'] });
    let stdout = '';
    let stderr = '';
    let pendingStdout = '';
    child.stdout.on('data', (chunk) => {
      pendingStdout += chunk;
      const lines = pendingStdout.split(/\r?\n/);
      pendingStdout = lines.pop();
      for (const line of lines) {
        try {
          const event = JSON.parse(line);
          if (event.type === 'awaiting_browser' || event.type === 'auth_required_manual' || event.type === 'agent_transcript_event') {
            onEvent?.(event);
            continue;
          }
        } catch { /* final output is not necessarily JSON */ }
        stdout += `${line}\n`;
      }
    });
    child.stderr.on('data', (chunk) => { stderr += chunk; process.stderr.write(chunk); });
    child.on('exit', (code) => resolve({ status: code, stdout: `${stdout}${pendingStdout}`, stderr }));
  });
}

// Wraps `fetch` against the coordinator with a clear, actionable message on
// network-level failure (down/unreachable/wrong URL/DNS) instead of letting
// a raw `TypeError: fetch failed` stack trace reach a non-technical user —
// this is exactly the class of error a mistyped --coordinator-url or a
// coordinator that isn't running yet produces.
async function fetchCoordinator(url, opts) {
  try {
    return await fetch(url, opts);
  } catch (error) {
    fail(`could not reach the coordinator at ${url}: ${error.message}\n` +
      `Check the coordinator URL (see: waspflow federation status) and that the coordinator is running.`);
  }
}

async function verifyInviteToken(coordinatorUrl, inviteToken) {
  const probe = await fetchCoordinator(`${coordinatorUrl}/tasks/next`, {
    headers: { authorization: `Bearer ${inviteToken}` },
  });
  if (probe.status === 401) fail('the coordinator rejected the invite token — check it and try again.');
  if (!probe.ok) fail(`coordinator responded with an unexpected error (${probe.status}) — check the coordinator URL.`);
}

// `type` is merged in LAST (after any spread of upstream data in
// `structured`) so it can never be shadowed — e.g. `contributed` spreads the
// pull bin's own `{status: 'settled', ...}` response, and `task_status`
// spreads the coordinator's task record's own `status` field. Both would
// silently overwrite a `status`-based discriminator; `type` is immune by
// construction. See lib/federation-events.mjs for the full event vocabulary
// this must stay in sync with (tests/federation-events-contract.test.mjs
// enforces it).
function printResult(json, humanLines, structured, type) {
  if (json) {
    process.stdout.write(JSON.stringify({ ...structured, schema_version: 1, type }) + '\n');
  } else {
    for (const line of humanLines) process.stdout.write(line + '\n');
  }
}

// --- join -------------------------------------------------------------------
//
// Auto-generates a keypair, persists coordinator-url/collective-token/
// key-id/key-path so every later verb needs none of them again, auto-fetches
// the coordinator's public-key directory into the local roster cache
// (GET /roster — owner decision, 2026-07-21, see lib/federation-coordinator.mjs's
// top-of-file doc), and prints this member's OWN public-key snippet for the
// human to send to whoever runs the coordinator.
//
// Does NOT register the key over the network — there is deliberately no
// POST/register endpoint (see lib/federation-coordinator.mjs's doc). Adding
// one would be a real trust-model change (an unauthenticated-by-definition
// "add me to the collective" surface), which is not what GET /roster is:
// that endpoint only serves already-approved members' already-public keys,
// it does not let anyone add themselves. So MEMBERSHIP — the coordinator
// operator deciding to add a brand-new key_id to their roster file — remains
// a real, human, out-of-band decision; `join` gets the operator that one
// remaining snippet as fast as possible. Once a member is added, GET /roster
// means every OTHER already-approved member's public key auto-populates
// here and at the start of contribute/submit — no pasting required for them.
async function cmdJoin(argv) {
  const { flags, positional } = parseFlags(argv, ['key-id', 'collective-name']);
  let [coordinatorUrl, inviteToken] = positional;
  if (positional.length === 1 && /^(?:waspflow|https?):\/\//i.test(positional[0])) {
    const { parseJoinInvite } = await import('../lib/federation-daemon.mjs');
    const parsed = parseJoinInvite(positional[0]);
    coordinatorUrl = parsed.coordinatorUrl;
    inviteToken = parsed.token;
    if (!flags['collective-name'] && parsed.collectiveName) flags['collective-name'] = parsed.collectiveName;
  }
  if (!coordinatorUrl || !inviteToken) {
    fail('usage: waspflow federation join <coordinator-url> <invite-token> | <https://coordinator/join#token> | <waspflow://join?...> [--key-id <name>] [--json]');
  }

  const { loadConfig, saveConfig, generateAndStoreKeypair, configPath } = await import('../lib/federation-config.mjs');

  const existing = loadConfig();
  if (existing && existing.coordinator_url === coordinatorUrl) {
    if (existing.collective_token !== inviteToken) {
      await verifyInviteToken(coordinatorUrl, inviteToken);
      existing.collective_token = inviteToken;
      if (flags['collective-name']) existing.collective_name = flags['collective-name'];
      saveConfig(existing);
      printResult(flags.json, [
        `updated the collective token for ${coordinatorUrl}`,
        `saved configuration: ${configPath()}`,
      ], { status: 'rejoined', key_id: existing.key_id, coordinator_url: existing.coordinator_url, config_path: configPath() }, 'rejoined');
      return;
    }
    if (flags['collective-name'] && existing.collective_name !== flags['collective-name']) {
      existing.collective_name = flags['collective-name'];
      saveConfig(existing);
    }
    printResult(flags.json, [
      `already joined as ${existing.key_id}`,
      `coordinator: ${existing.coordinator_url}`,
    ], { status: 'already_joined', key_id: existing.key_id, coordinator_url: existing.coordinator_url, config_path: configPath() }, 'already_joined');
    return;
  }

  // Check the coordinator is actually reachable and the invite token is
  // accepted BEFORE generating a keypair and saving config — a mistyped URL
  // or token should surface here, not silently later the first time
  // contribute/submit tries to talk to the coordinator.
  await verifyInviteToken(coordinatorUrl, inviteToken);

  const keyId = flags['key-id'] || os.userInfo().username || 'member';
  const { privateKeyPath, publicKeyPem } = generateAndStoreKeypair(keyId);

  // The invite token IS the collective bearer token in v0 — there is no
  // separate invite-exchange step (no registration endpoint exists to
  // exchange it against; see the module doc above). Naming the CLI arg
  // "invite-token" rather than "collective-token" is deliberate UX: to the
  // non-technical user this is "the code someone sent me to join", not a
  // credential they need to understand as a bearer token.
  let config = {
    coordinator_url: coordinatorUrl,
    collective_token: inviteToken,
    key_id: keyId,
    private_key_path: privateKeyPath,
    ...(flags['collective-name'] ? { collective_name: flags['collective-name'] } : {}),
  };
  saveConfig(config);

  // Auto-fetch whoever the coordinator already has on its roster (e.g. the
  // operator themself, or any other already-approved member) — this member
  // never needs to `trust` those peers by hand. It cannot fetch THIS
  // member's own key back yet, since the operator hasn't added it to the
  // roster file at this point in the flow — that's the one snippet still
  // printed below.
  config = await refreshRosterCache(config);

  const snippet = JSON.stringify({ [keyId]: publicKeyPem });
  const peerCount = Object.keys(config.roster || {}).length;
  printResult(flags.json, [
    `joined ${coordinatorUrl} as '${keyId}'`,
    `saved configuration: ${configPath()}`,
    `existing member keys: ${peerCount}`,
    'send this public key to the coordinator operator:',
    snippet,
    'run: waspflow federation contribute',
  ], {
    status: 'joined',
    key_id: keyId,
    coordinator_url: coordinatorUrl,
    config_path: configPath(),
    peers_auto_fetched: peerCount,
    roster_snippet: { [keyId]: publicKeyPem },
    next_step: 'send roster_snippet to the coordinator operator, then run: waspflow federation contribute',
  }, 'joined');
}

// --- host / invite (operator journey) --------------------------------------
//
// The coordinator is a separate user-level service in packaged Linux builds,
// because that is the long-lived-process primitive this package already
// installs for the contributor daemon. A checkout has no installed unit, so
// it keeps a child attached to this command instead of silently daemonizing a
// process that the operator cannot inspect or stop.
function runCommand(command, args) {
  return new Promise((resolve) => {
    const child = spawn(command, args, { stdio: ['ignore', 'pipe', 'pipe'] });
    let stdout = '';
    let stderr = '';
    child.stdout.on('data', (chunk) => { stdout += chunk; });
    child.stderr.on('data', (chunk) => { stderr += chunk; });
    child.on('error', (error) => resolve({ code: 127, stderr: error.message, stdout }));
    child.on('exit', (code) => resolve({ code: code ?? 1, stdout, stderr }));
  });
}

async function ask(question) {
  if (!process.stdin.isTTY) fail(`${question}\nRun again with --tunnel ngrok, --tunnel url:<https://address>, or --tunnel lan.`);
  const prompt = readline.createInterface({ input: process.stdin, output: process.stdout });
  try { return (await prompt.question(question)).trim(); } finally { prompt.close(); }
}

async function chooseReachability() {
  process.stdout.write('Choose how remote members reach this collective:\n');
  process.stdout.write('  [1] Use ngrok\n');
  process.stdout.write('  [2] Use my HTTPS address\n');
  process.stdout.write('  [3] Use my local network\n');
  const choice = await ask('Choose 1, 2, or 3: ');
  if (choice === '1') return { kind: 'ngrok' };
  if (choice === '2') {
    const { parseTunnel } = await import('../lib/federation-host.mjs');
    return parseTunnel(`url:${await ask('Paste your HTTPS address (for example https://collective.example): ')}`);
  }
  if (choice === '3') return { kind: 'lan' };
  fail('please choose 1, 2, or 3');
}

async function storeNgrokToken(paths) {
  if (fs.existsSync(paths.ngrokToken) && fs.readFileSync(paths.ngrokToken, 'utf8').trim()) return paths.ngrokToken;
  process.stdout.write('Create a free ngrok account: https://dashboard.ngrok.com/signup\n');
  const { readSecret } = await import('../lib/federation-secret-prompt.mjs');
  const token = await readSecret({ input: process.stdin, output: process.stdout, prompt: 'Paste your authtoken (Your Authtoken page): ' });
  if (!token) fail('an ngrok authtoken is required to start the recommended tunnel');
  fs.writeFileSync(paths.ngrokToken, `${token}\n`, { mode: 0o600 });
  fs.chmodSync(paths.ngrokToken, 0o600);
  process.stdout.write('authtoken saved\n');
  return paths.ngrokToken;
}

async function prepareNgrokRuntime(paths) {
  const manifestSource = path.join(ROOT, 'coordinator');
  if (!fs.existsSync(path.join(manifestSource, 'package.json'))) {
    fail(`this installation does not include the optional ngrok connector. ${await ngrokFallbackMessage()}`);
  }
  const runtime = paths.ngrokRuntime;
  fs.mkdirSync(runtime, { recursive: true, mode: 0o700 });
  for (const name of ['package.json', 'package-lock.json']) {
    const source = path.join(manifestSource, name);
    const destination = path.join(runtime, name);
    if (!fs.existsSync(destination)) fs.copyFileSync(source, destination);
  }
  if (fs.existsSync(path.join(runtime, 'node_modules', '@ngrok', 'ngrok'))) return runtime;
  const result = await runCommand('npm', ['ci', '--omit=dev', '--prefix', runtime]);
  if (result.code !== 0) {
    fail(`could not prepare the built-in ngrok connector: ${result.stderr.trim() || result.stdout.trim()}\n${await ngrokFallbackMessage()}`);
  }
  return runtime;
}

async function ngrokFallbackMessage() {
  const { ngrokUnavailableGuidance } = await import('../lib/federation-coordinator-hosting.mjs');
  return ngrokUnavailableGuidance();
}

function coordinatorServiceInstalled() {
  return process.platform === 'linux' && fs.existsSync('/usr/lib/systemd/user/waspflow-federation-coordinator.service');
}

async function startPackagedCoordinator(config) {
  for (const args of [
    ['--user', 'daemon-reload'],
    ['--user', 'enable', '--now', 'waspflow-federation-coordinator.service'],
    ['--user', 'restart', 'waspflow-federation-coordinator.service'],
  ]) {
    const result = await runCommand('systemctl', args);
    if (result.code !== 0) return { started: false, detail: result.stderr.trim() || result.stdout.trim() };
  }
  return { started: true };
}

function startCheckoutCoordinator(config) {
  const child = spawn(process.execPath, [path.join(ROOT, 'bin', 'waspflow-federation-coordinator'), '--host-config', path.join(path.dirname(config.roster_path), 'host.json')], {
    stdio: ['ignore', 'pipe', 'pipe'],
  });
  child.stderr.on('data', (chunk) => process.stderr.write(chunk));
  child.stdout.on('data', () => {}); // status.json is the stable parent/child contract.
  return child;
}

async function waitForCoordinatorStatus(config) {
  const { readCoordinatorStatus } = await import('../lib/federation-host.mjs');
  for (let attempt = 0; attempt < 80; attempt++) {
    const status = readCoordinatorStatus(config);
    if (status && status.status !== 'listening') return status;
    if (status?.public_url) return status;
    await new Promise((resolve) => setTimeout(resolve, 100));
  }
  return readCoordinatorStatus(config);
}

async function cmdHost(argv) {
  const { flags, positional } = parseFlags(argv, ['tunnel', 'port'], ['rotate-token']);
  if (positional.length > 0 || (flags['rotate-token'] && (flags.tunnel || flags.port))) {
    fail('usage: waspflow federation host [--tunnel ngrok|url:<https://address>|lan] [--port <number>] | --rotate-token');
  }
  const { ensureHostState, parseTunnel, resolveLanUrl, saveReachability, readCollectiveToken, readCoordinatorStatus, rotateCollectiveToken, writeCollectiveToken } = await import('../lib/federation-host.mjs');
  const port = flags.port === undefined ? 8787 : Number(flags.port);
  if (!Number.isInteger(port) || port < 1 || port > 65535) fail('--port must be a number between 1 and 65535');
  let { config, paths } = ensureHostState({ port });

  if (flags['rotate-token']) {
    // A coordinator that is not running needs no live update: the token file
    // is its only token source at startup, so rotating the file alone is
    // complete. The status file can claim "listening" after a terminal-closed
    // exit, so a connection-level probe (not the file) decides liveness.
    const status = readCoordinatorStatus(config);
    const coordinatorUrl = status?.port ? `http://127.0.0.1:${status.port}` : null;
    const oldToken = readCollectiveToken(config);
    let before = null;
    if (coordinatorUrl) {
      try {
        before = await fetch(`${coordinatorUrl}/tasks/next`, { headers: { authorization: `Bearer ${oldToken}` } });
      } catch { /* not running; rotate the file directly below */ }
    }
    if (!before) {
      rotateCollectiveToken(config);
      process.stdout.write('Collective token rotated. Your coordinator is not running; the new token takes effect when you start it: waspflow federation host\nOld invites are dead. Send fresh ones with: waspflow federation invite\n');
      return;
    }
    if (!before.ok) {
      fail('cannot rotate the collective token because the managed coordinator rejected its current token; old invites remain active.');
    }

    const nextToken = rotateCollectiveToken(config);
    let updated = false;
    try {
      const [withNewToken, withOldToken] = await Promise.all([
        fetch(`${coordinatorUrl}/tasks/next`, { headers: { authorization: `Bearer ${nextToken}` } }),
        fetch(`${coordinatorUrl}/tasks/next`, { headers: { authorization: `Bearer ${oldToken}` } }),
      ]);
      updated = withNewToken.ok && withOldToken.status === 401;
    } catch { /* restore the known-good token below */ }
    if (!updated) {
      writeCollectiveToken(config, oldToken);
      fail('cannot rotate the collective token because the coordinator could not be updated; old invites remain active.');
    }
    process.stdout.write('Collective token rotated; existing members must re-join with a new invite, and old invites are dead.\n');
    return;
  }

  let reachability = flags.tunnel ? parseTunnel(flags.tunnel) : config.reachability;
  if (!reachability) reachability = await chooseReachability();
  if (reachability.kind === 'lan') reachability = { ...reachability, publicUrl: resolveLanUrl({ port: config.port }) };
  if (reachability.kind === 'ngrok') {
    reachability = {
      ...reachability,
      runtime_path: await prepareNgrokRuntime(paths),
      token_path: await storeNgrokToken(paths),
    };
  }
  config = saveReachability(config, reachability);
  try { fs.unlinkSync(config.status_path); } catch (error) { if (error.code !== 'ENOENT') throw error; }

  let checkoutChild = null;
  if (coordinatorServiceInstalled()) {
    const service = await startPackagedCoordinator(config);
    if (!service.started) fail(`could not start the coordinator service: ${service.detail}`);
  } else {
    checkoutChild = startCheckoutCoordinator(config);
  }
  const status = await waitForCoordinatorStatus(config);
  if (!status) fail('the coordinator did not report ready status; check the coordinator logs and run host again to resume.');
  if (status.status === 'ngrok_unavailable') fail(`${status.error}\nInstall the ngrok agent from https://ngrok.com/download, then run it against local port ${config.port}, or use --tunnel url:<https://your-address>.`);
  if (status.status === 'ngrok_error' || status.status === 'ngrok_token_missing') fail(status.error || 'the ngrok tunnel could not start');
  const publicUrl = status.public_url || reachability.publicUrl;
  if (!publicUrl) fail('the coordinator started but did not provide a reachable address');
  const invite = (await import('../lib/federation-host.mjs')).createJoinInvite({ coordinatorUrl: publicUrl, collectiveToken: readCollectiveToken(config) });
  process.stdout.write(`\nYOUR COLLECTIVE IS READY\n${publicUrl}\n\nSend this invite to each member:\n${invite}\n\n`);
  if (checkoutChild) {
    process.stdout.write('This source-checkout coordinator stops when this terminal closes.\n');
    await new Promise((resolve) => checkoutChild.on('exit', resolve));
  }
}

async function cmdInvite(argv) {
  const { flags, positional } = parseFlags(argv, ['url']);
  if (positional.length > 0) fail('usage: waspflow federation invite [--url <http(s)://address>]');
  const { coordinatorHome, hostPaths, createJoinInvite, readCollectiveToken, readCoordinatorStatus } = await import('../lib/federation-host.mjs');
  const paths = hostPaths(coordinatorHome());
  if (!fs.existsSync(paths.config)) fail(`no hosted collective found at ${paths.config}. Run: waspflow federation host`);
  const config = JSON.parse(fs.readFileSync(paths.config, 'utf8'));
  const status = readCoordinatorStatus(config);
  const coordinatorUrl = flags.url || status?.public_url || config.reachability?.publicUrl;
  if (!coordinatorUrl) fail('the public coordinator URL is not known yet; run: waspflow federation host');
  // A down coordinator can come back on a different public address (a tunnel
  // pin that fails to re-bind), so an invite minted now could go stale.
  if (!flags.url) {
    let live = false;
    if (status?.port) {
      try { live = (await fetch(`http://127.0.0.1:${status.port}/tasks/next`, { headers: { authorization: `Bearer ${readCollectiveToken(config)}` } })).ok; } catch { /* not running */ }
    }
    if (!live) log('your coordinator is not running — start it first (waspflow federation host), then mint invites, so the address in them is the live one.');
  }
  const invite = createJoinInvite({ coordinatorUrl, collectiveToken: readCollectiveToken(config) });
  process.stdout.write(`${invite}\n`);
}

// --- contribute --------------------------------------------------------------
//
// The two-command contributor journey's second half. No flags required:
// reads config for coordinator/token/identity, refreshes the local roster
// cache from the coordinator's GET /roster (so a first-time contributor
// never has to run `trust` on the default path — see refreshRosterCache),
// discovers the next claimable task via GET /tasks/next (so nobody has to
// paste a task_digest), drives the auth pre-flight above, then shells out to
// the EXACT proven bin/waspflow-federation-pull with every flag filled in —
// so the real claim/verify/fetch/run/submit sequence that bin already
// implements and tests is what actually executes, unmodified.
async function cmdContribute(argv) {
  const { flags } = parseFlags(argv, ['task-digest', 'harness', 'lease-seconds']);
  const { requireConfig } = await import('../lib/federation-config.mjs');
  let config = requireConfig();
  // The sandbox preflight is deliberately before roster refresh, task claim,
  // or harness login. A new machine therefore receives actionable setup
  // state instead of an opaque backend 500 after it has claimed work.
  const sandbox = await sandboxPreflight({ json: flags.json, report: false });
  if (!sandbox.ok) {
    // Contribution owns the machine-readable failure event. Successful
    // preflights stay silent so every existing successful contribute path
    // still emits exactly one final JSON event.
    const preflight = sandbox.preflight;
    printResult(flags.json, preflightHumanLines(preflight), {
      status: 'setup_required', backend_id: preflight.backend_id, checks: preflight.checks,
    }, 'sandbox_preflight');
    process.exitCode = 1;
    return;
  }
  config = await refreshRosterCache(config);

  const harness = flags.harness || 'claude-code-subscription';
  let taskDigest = flags['task-digest'];
  if (!taskDigest) {
    log('no --task-digest given — asking the coordinator for the next claimable task...');
    const res = await fetchCoordinator(`${config.coordinator_url}/tasks/next`, {
      headers: { authorization: `Bearer ${config.collective_token}` },
    });
    if (!res.ok) {
      const body = await res.json().catch(() => ({}));
      fail(`could not reach coordinator for a task: ${res.status} ${body.error || ''}`);
    }
    const body = await res.json();
    if (!body.task_digest) {
      printResult(flags.json, ['no task is currently available — nothing to contribute right now.'],
        { status: 'no_task_available' }, 'no_task_available');
      return;
    }
    taskDigest = body.task_digest;
    log(`claimable task found: ${taskDigest}`);
  }
  const displayId = await displayIdForTask(config, taskDigest);

  const pullArgs = [
    '--coordinator-url', config.coordinator_url,
    '--collective-token', config.collective_token,
    '--task-digest', taskDigest,
    '--executor-key', config.key_id,
    '--private-key-file', config.private_key_path,
    '--roster-file', rosterFileFor(config),
    '--harness', harness,
  ];
  if (flags['lease-seconds']) pullArgs.push('--lease-seconds', flags['lease-seconds']);
  if (flags.json) pullArgs.push('--auth-events', 'json');

  log(`running task ${taskDigest} sandboxed (harness: ${harness})...`);
  // stderr streams live (a sandboxed run can take a while) AND is buffered so
  // a "not in --roster-file" failure can be translated into this CLI's own
  // `trust` vocabulary below.
  const result = await runChildStreaming(process.execPath, [path.join(ROOT, 'bin', 'waspflow-federation-pull'), ...pullArgs], {
    onEvent: (event) => printResult(true, [], { ...event, task_digest: taskDigest }, event.type),
  });
  if (result.status !== 0) {
    // The author's key_id is only known once the underlying pull bin claims
    // the task (it comes back inside the task envelope's own signature), so
    // this cannot be pre-checked before spawning — but the pull bin's own
    // "not in --roster-file" failure is common enough for a first-time
    // contributor that it's worth translating into the guided verb's own
    // vocabulary (trust) rather than leaving its raw wording as the only clue.
    const match = /signer key_id "([^"]+)"/.exec(result.stderr || '');
    if (/is not in --roster-file/.test(result.stderr) && match) {
      fail(
        `you haven't trusted '${match[1]}' yet, so this task's authenticity can't be verified.\n` +
        `Ask them for their public key, then run: waspflow federation trust ${match[1]} <their-pubkey-file-or-string>`
      );
    }
    fail(`contribute failed (task ${taskDigest}) — see output above`);
  }
  if (flags.json) {
    const submitResponse = JSON.parse(result.stdout);
    printResult(true, [], {
      status: 'contributed', task_digest: taskDigest, ...submitResponse,
      ...(displayId ? { display_id: displayId } : {}),
    }, 'contributed');
  } else {
    log(`done — task ${taskDigest} submitted.`);
  }
}

// Fetches the coordinator's public-key directory (GET /roster — owner
// decision, 2026-07-21) and merges it into the local roster cache, then
// persists it to config.json. This is what makes `trust` unnecessary on the
// DEFAULT path: every already-approved member's public key is available
// automatically, rather than requiring each peer to be pasted in by hand.
// Called at the start of contribute/submit (and after a successful join) so
// the cache is always fresh against the coordinator's current roster file
// (which the operator may still be editing — hot-reloaded, no restart).
// Best-effort: a coordinator that's briefly unreachable here should not hard
// -fail contribute/submit outright — the existing local cache (from a prior
// fetch, or from manual `trust`) may still be sufficient, and the actual
// claim/submit step will fail on its own with a clear error if it isn't.
async function refreshRosterCache(config) {
  const { saveConfig } = await import('../lib/federation-config.mjs');
  let res;
  try {
    res = await fetch(`${config.coordinator_url}/roster`, {
      headers: { authorization: `Bearer ${config.collective_token}` },
    });
  } catch {
    return config; // coordinator unreachable — proceed with whatever cache already exists
  }
  if (!res.ok) return config; // e.g. an older coordinator without GET /roster yet — degrade silently to the existing cache
  const body = await res.json().catch(() => null);
  if (!body || !Array.isArray(body.roster)) return config;

  config.roster = config.roster || {};
  for (const entry of body.roster) {
    if (entry && typeof entry.key_id === 'string' && typeof entry.public_key_pem === 'string') {
      config.roster[entry.key_id] = entry.public_key_pem;
    }
  }
  saveConfig(config);
  return config;
}

// The pull protocol deals in a digest, while the contributor-facing ledger
// needs the signed task's human display id. Discovery is best-effort here:
// the task can still run if a concurrent claim makes it disappear from the
// list, but normal completion emits the display id for the daemon ledger.
async function displayIdForTask(config, taskDigest) {
  try {
    const res = await fetch(`${config.coordinator_url}/tasks`, {
      headers: { authorization: `Bearer ${config.collective_token}` },
    });
    const tasks = await res.json();
    const task = Array.isArray(tasks) && tasks.find((item) => item?.task_digest === taskDigest);
    return typeof task?.display_id === 'string' ? task.display_id : null;
  } catch {
    return null;
  }
}

// Materializes the local roster cache into a temp file for --roster-file.
// On the DEFAULT path this cache is auto-populated from the coordinator's
// GET /roster (see refreshRosterCache above); `waspflow federation trust` is
// the advanced/offline fallback for when the coordinator can't be reached
// to auto-fetch it (air-gapped, coordinator down) — see the UX report.
function rosterFileFor(config) {
  const roster = config.roster || {};
  const file = path.join(os.tmpdir(), `wf-federation-roster-${process.pid}.json`);
  fs.writeFileSync(file, JSON.stringify(roster));
  // Public keys only (never private material), but still disposable —
  // clean it up on any exit path (success, fail()'s process.exit, or an
  // uncaught error) rather than leaving it in tmpdir indefinitely.
  process.on('exit', () => { try { fs.unlinkSync(file); } catch { /* already gone */ } });
  return file;
}

// --- trust (advanced fallback, not the default path) -------------------------
//
// contribute/submit now auto-fetch every peer's public key from the
// coordinator's GET /roster (refreshRosterCache above), so this verb is no
// longer required on the normal path. It remains as the offline/air-gapped/
// coordinator-unreachable fallback: adds a peer's public key to this
// member's LOCAL roster cache in config.json by hand, entirely without
// talking to the coordinator, so contribute/submit can still independently
// re-verify a peer's signature even when GET /roster can't be reached (or
// against an older coordinator that predates it). Never talks to the
// coordinator or any network endpoint — the coordinator's own roster is a
// separate, hand-edited file the OPERATOR maintains
// (lib/federation-coordinator.mjs) — this is this MEMBER's local cache,
// which may legitimately be a subset or superset of it.
async function cmdTrust(argv) {
  const { flags, positional } = parseFlags(argv, ['pubkey-file']);
  const [keyId, pubkeyArg] = positional;
  if (!keyId) fail('usage: waspflow federation trust <key-id> <pubkey-pem-string-or-@file> [--json]');

  const { requireConfig, saveConfig } = await import('../lib/federation-config.mjs');
  const config = requireConfig();

  let pubkeyPem;
  if (pubkeyArg && pubkeyArg.startsWith('@')) {
    pubkeyPem = fs.readFileSync(pubkeyArg.slice(1), 'utf8');
  } else if (flags['pubkey-file']) {
    pubkeyPem = fs.readFileSync(flags['pubkey-file'], 'utf8');
  } else if (pubkeyArg) {
    pubkeyPem = pubkeyArg;
  } else {
    fail('usage: waspflow federation trust <key-id> <pubkey-pem-string-or-@file> [--json]');
  }
  if (!pubkeyPem.includes('BEGIN PUBLIC KEY')) fail('that does not look like a PEM public key (expected "-----BEGIN PUBLIC KEY-----")');

  config.roster = config.roster || {};
  config.roster[keyId] = pubkeyPem;
  saveConfig(config);

  log(`trusted '${keyId}' — saved to your local roster cache.`);
  printResult(flags.json, [`trusted '${keyId}'`], { status: 'trusted', key_id: keyId }, 'trusted');
}

// --- approve (owner-only local roster edit) ---------------------------------
//
// Membership remains a local filesystem decision. This is deliberately a
// convenience for the coordinator owner, not a coordinator API: writing the
// roster file lets the existing watcher hot-reload the approval without
// adding a network-reachable registration surface.
async function cmdApprove(argv) {
  const { flags, positional } = parseFlags(argv, ['roster-file']);
  const [keyId, publicKeyFile] = positional;
  if (!keyId || !publicKeyFile) {
    fail('usage: waspflow federation approve <key_id> <public_key_pem_file|-> [--roster-file <path>] [--json]');
  }
  const rosterFile = flags['roster-file'] || process.env.WASPFLOW_FEDERATION_COORDINATOR_ROSTER_FILE;
  if (!rosterFile) fail('approve requires --roster-file or WASPFLOW_FEDERATION_COORDINATOR_ROSTER_FILE');
  const publicKeyPem = publicKeyFile === '-' ? fs.readFileSync(0, 'utf8') : fs.readFileSync(publicKeyFile, 'utf8');
  if (!publicKeyPem.includes('BEGIN PUBLIC KEY')) fail('that does not look like a PEM public key (expected "-----BEGIN PUBLIC KEY-----")');
  let roster;
  try {
    roster = JSON.parse(fs.readFileSync(rosterFile, 'utf8'));
  } catch (error) {
    fail(`could not read/parse roster file ${rosterFile}: ${error.message}`);
  }
  if (!roster || typeof roster !== 'object' || Array.isArray(roster)) fail(`roster file ${rosterFile} must contain a JSON object`);
  roster[keyId] = publicKeyPem;
  // Keep the roster path's inode stable. The coordinator watches this exact
  // local file; replacing it by rename can detach an fs.watch watcher on
  // Linux after the first approval. A short malformed intermediate state is
  // safe because its watcher deliberately keeps the previous valid roster.
  fs.writeFileSync(rosterFile, JSON.stringify(roster, null, 2));
  log(`approved '${keyId}' in ${rosterFile}; the coordinator will hot-reload it.`);
  printResult(flags.json, [`approved '${keyId}'`], { status: 'approved', key_id: keyId, roster_file: rosterFile }, 'approved');
}

// --- submit ------------------------------------------------------------------
//
// The requester-side guided verb. No coordinator/token/key flags — those
// come from config (join must have been run once by the requester too, same
// as any collective member). Refreshes the roster cache the same way
// contribute does, so `--output-dir`'s independent result-signature
// re-verification also works without a manual `trust` on the default path.
// Shells out to the proven bin/waspflow-federation-submit with everything
// filled in.
async function cmdSubmit(argv) {
  const { flags } = parseFlags(argv, [
    'display-id', 'source', 'git-url', 'git-ref', 'git-private', 'github-access', 'prompt', 'prompt-file', 'network', 'expires-in',
    'poll-interval', 'timeout', 'output-dir',
  ]);
  const { requireConfig } = await import('../lib/federation-config.mjs');
  let config = requireConfig();
  config = await refreshRosterCache(config);

  if (!flags['display-id']) fail('submit: --display-id is required');
  if (flags.source && flags['git-url']) fail('submit: --source and --git-url cannot be used together');
  if (!flags.prompt && !flags['prompt-file']) fail('submit: --prompt or --prompt-file is required');

  const submitArgs = [
    '--coordinator-url', config.coordinator_url,
    '--collective-token', config.collective_token,
    '--collective', config.coordinator_url,
    '--author-key-id', config.key_id,
    '--private-key-file', config.private_key_path,
    '--display-id', flags['display-id'],
  ];
  if (flags.source) submitArgs.push('--source', flags.source);
  if (flags['git-url']) submitArgs.push('--git-url', flags['git-url']);
  if (flags['git-ref']) submitArgs.push('--git-ref', flags['git-ref']);
  if (flags['git-private']) submitArgs.push('--git-private', flags['git-private']);
  if (flags['github-access']) submitArgs.push('--github-access', flags['github-access']);
  if (flags.prompt) submitArgs.push('--prompt', flags.prompt);
  if (flags['prompt-file']) submitArgs.push('--prompt-file', flags['prompt-file']);
  if (flags.network) submitArgs.push('--network', flags.network);
  if (flags['expires-in']) submitArgs.push('--expires-in', flags['expires-in']);
  if (flags['poll-interval']) submitArgs.push('--poll-interval', flags['poll-interval']);
  if (flags.timeout) submitArgs.push('--timeout', flags.timeout);
  if (flags['output-dir']) {
    submitArgs.push('--output-dir', flags['output-dir']);
    submitArgs.push('--roster-file', rosterFileFor(config));
  }

  const result = await runChildStreaming(process.execPath, [path.join(ROOT, 'bin', 'waspflow-federation-submit'), ...submitArgs]);
  if (result.stdout) process.stdout.write(result.stdout);
  if (result.status !== 0) {
    // Same translation as cmdContribute's — the executor's key_id is only
    // known once the task settles, so this can't be pre-checked either.
    const match = /signer key_id "([^"]+)"/.exec(result.stderr || '');
    if (/is not in the roster/.test(result.stderr) && match) {
      fail(
        `you haven't trusted '${match[1]}' yet, so this task's result can't be verified as theirs.\n` +
        `Ask them for their public key, then run: waspflow federation trust ${match[1]} <their-pubkey-file-or-string>`
      );
    }
    process.exit(result.status || 1);
  }
}

// --- status ------------------------------------------------------------------
//
// With no args: local config health (joined? as who? which coordinator?).
// With --task-digest: proxies GET /tasks/:digest (unauthenticated on the
// coordinator by design — the digest itself is the access token, see
// lib/federation-coordinator.mjs's handleGet comment).
async function cmdStatus(argv) {
  const { flags } = parseFlags(argv, ['task-digest']);
  const { loadConfig, configPath } = await import('../lib/federation-config.mjs');
  const config = loadConfig();

  if (!config) {
    printResult(flags.json, [
      'not joined yet.',
      "run: waspflow federation join <coordinator-url> <invite-token>",
    ], { status: 'not_joined' }, 'not_joined');
    return;
  }

  if (flags['task-digest']) {
    const res = await fetchCoordinator(`${config.coordinator_url}/tasks/${flags['task-digest']}`);
    const body = await res.json().catch(() => ({}));
    if (!res.ok) fail(`task lookup failed: ${res.status} ${body.error || ''}`);
    printResult(flags.json, [
      `task ${flags['task-digest']}: ${body.status}`,
    ], { status: 'task_status', ...body }, 'task_status');
    return;
  }

  printResult(flags.json, [
    `joined as '${config.key_id}'`,
    `coordinator: ${config.coordinator_url}`,
    `config: ${configPath()}`,
  ], { status: 'joined', key_id: config.key_id, coordinator_url: config.coordinator_url, config_path: configPath() }, 'member_status');
}

// `waspflow federation` is deliberately an entry point, not a second help
// screen. The local daemon is safe to start before joining: its UI is the
// onboarding surface and it binds only to loopback with a random session
// token. Doctor remains detect-and-guide, so a missing sandbox explains the
// next machine setup without preventing someone from pasting their invite.
async function cmdFirstRun() {
  const { loadConfig } = await import('../lib/federation-config.mjs');
  const configured = loadConfig();

  if (!configured) {
    process.stdout.write('Welcome to Waspflow Federation. Checking this machine first...\n\n');
    await sandboxPreflight({ report: true });
    process.stdout.write('\nStarting the local Federation onboarding UI...\n');
  } else {
    process.stdout.write(`Federation is configured for ${configured.coordinator_url}. Opening the local UI...\n`);
  }

  const { openFederationUi } = await import('../lib/federation-daemon.mjs');
  const url = await openFederationUi();
  process.stdout.write(`Open: ${url}\n`);
  if (!configured) {
    process.stdout.write('Paste the invite from your collective operator into the Join screen, then click Contribute.\n');
  }
}

async function main() {
  const [verb, ...rest] = process.argv.slice(2);
  if (!verb) return cmdFirstRun();
  switch (verb) {
    case 'doctor': return cmdDoctor(rest);
    case 'join': return cmdJoin(rest);
    case 'contribute': return cmdContribute(rest);
    case 'submit': return cmdSubmit(rest);
    case 'status': return cmdStatus(rest);
    case 'trust': return cmdTrust(rest);
    case 'approve': return cmdApprove(rest);
    case 'host': return cmdHost(rest);
    case 'invite': return cmdInvite(rest);
    case 'daemon': {
      const { runDaemon } = await import('../lib/federation-daemon.mjs');
      return runDaemon(rest);
    }
    case 'ui': {
      const { openFederationUi } = await import('../lib/federation-daemon.mjs');
      const url = await openFederationUi();
      process.stdout.write(`${url}\n`);
      return;
    }
    default:
      process.stderr.write(`usage: waspflow federation <host|invite|doctor|join|contribute|submit|status|trust|approve|daemon|ui> ...\n`);
      process.exit(1);
  }
}

// Expected, user-actionable errors (e.g. FederationConfigError already carries
// a "Run 'waspflow federation join ...' first" message) render as a clean
// guided line — a non-technical contributor who runs `contribute` before `join`
// gets guidance, not a stack trace. Only genuinely unexpected errors show the
// stack for debugging.
function isExpectedError(error) {
  return !!error && typeof error.name === 'string' && /^Federation\w*Error$/.test(error.name);
}

main().catch((error) => {
  if (isExpectedError(error)) fail(error.message);
  else fail(error && error.stack ? error.stack : String(error));
});
