#!/usr/bin/env bash
#
# waspflow — turnkey live orchestration of Claude/Codex/Grok agents in tmux.
#
# An orchestrating session (itself Claude, Codex, or Grok, in ANY project dir)
# uses this to spawn an agent of any supported provider into a tmux window,
# watch it stream, steer/revise it live or after teardown, wait for it to go
# idle, and reap it — all surviving the orchestrator's own compaction (the
# windows + lane state persist on disk).
#
# Verbs:
#   spawn   --provider <claude|codex|grok> | --op <id> --lane <name> [opts] -- <task>
#   exec    --provider <claude|codex|grok> [opts] [-o FILE] -- <task prompt>
#   ops     list|explain|resolve|path     operating-point resolver (not a picker)
#   init    [--profile NAME] [--cwd DIR] [--force] [--print]  write project config
#   demo    --provider <claude|codex|grok> [--run]            guided first lane
#   list    [--status S,...] [--lifecycle-state S,...] [--project DIR] [--limit N] [--json]
#   status  <lane>                        one lane's state (json)
#   peek    <lane> [--lines N]            de-escaped tail of the live pane
#   wait    <lane> [--timeout S] [--interval S] [--reap]   block until idle, optionally reap
#   park    <lane> [--reason TEXT] [--adopt-legacy]  stop a verified-idle owned window
#   gc      [--lane-age S] [--project DIR] [--adopt-legacy] [--apply]  dry-run park candidates
#   revise  <lane> [--out FILE] -- <message>      steer live, or resume if exited
#   accept-runtime <lane> --reason TEXT            accept this exact observed Codex drift
#   attach  <lane>                        attach your terminal to the pane
#   close   <lane> --status <...> [--into|--by|--reason ...]  set fan-in outcome
#   captured <lane> --in <ref>            is lane's work in <ref>? (by content)
#   verify  <lane>                         non-destructive verification checkpoint
#   reap    <lane|--status S,...> [--force] [--keep-worktree] [--no-archive]
#   check   [--cwd DIR] [--config FILE] [--no-fail] project integrity gate
#   doctor                                check deps + backends
#
# State:    $WASPFLOW_HOME (default ~/.local/state/waspflow)
# tmux:     all windows live in session "$WASPFLOW_TMUX_SESSION" (default waspflow)

set -euo pipefail

# ---- locate the engine ------------------------------------------------------
# Resolve symlinks so `waspflow` works when symlinked onto PATH.
_self="${BASH_SOURCE[0]}"
while [[ -h "$_self" ]]; do
  _dir="$(cd "$(dirname "$_self")" && pwd)"
  _self="$(readlink "$_self")"
  [[ "$_self" != /* ]] && _self="$_dir/$_self"
done
WASPFLOW_BIN_DIR="$(cd "$(dirname "$_self")" && pwd)"
WASPFLOW_ROOT="$(cd "$WASPFLOW_BIN_DIR/.." && pwd)"
# Honor a pre-set WASPFLOW_LIB (defaults to the repo lib) so tests can inject a
# lib dir with a fake provider adapter and drive the real command paths.
WASPFLOW_LIB="${WASPFLOW_LIB:-$WASPFLOW_ROOT/lib}"
export WASPFLOW_ROOT WASPFLOW_LIB

# shellcheck disable=SC1090
source "$WASPFLOW_LIB/core.sh"
# shellcheck disable=SC1090
source "$WASPFLOW_LIB/ops.sh"
# shellcheck disable=SC1090
source "$WASPFLOW_LIB/selection.sh"
# shellcheck disable=SC1090
source "$WASPFLOW_LIB/exec.sh"
# shellcheck disable=SC1090
source "$WASPFLOW_LIB/worktree.sh"
# shellcheck disable=SC1090
source "$WASPFLOW_LIB/artifacts.sh"
# shellcheck source=/dev/null
source "$WASPFLOW_LIB/escalation.sh"
# shellcheck disable=SC1090
source "$WASPFLOW_LIB/fanin.sh"
# shellcheck disable=SC1090
source "$WASPFLOW_LIB/project.sh"

# Keep ordinary control-plane verbs independent of event-reader setup. This is
# both compatibility isolation and the performance boundary: ordinary list
# never loads provider logs. Ordinary Codex status intentionally refreshes its
# single-lane runtime receipt; event and inspection options load the reader.
load_event_reader() {
  # shellcheck disable=SC1090
  source "$WASPFLOW_LIB/events.sh"
}

usage() {
  cat <<EOF
waspflow — turnkey live orchestration of Claude/Codex/Grok agents in tmux.

First successful run:
  waspflow doctor
  waspflow demo --provider codex
  waspflow demo --provider codex --run

Verbs:
  spawn   --provider <claude|codex|grok> | --op <id> --lane <name> [opts] -- <task>
  exec    --provider <claude|codex|grok> | --op <id> [--model M] [--auto] [--accept-provider-default] [--effort L] [--mcp P] [--cwd DIR] [-o FILE] -- <task prompt>
  ops     list|explain|resolve|path     operating-point resolver (decision cards)
  init    [--profile NAME] [--cwd DIR] [--force] [--print]  write project config
  demo    --provider <claude|codex|grok> [--run]            guided first lane
  list    [--status S,...] [--lifecycle-state S,...] [--project DIR] [--limit N] [--json]
                                          show the durable global lane index
  receipts summary [--json]               outcome ledger: arms, verify results, stats-eligible fraction
  status  <lane> [--tail-events N --json] one lane's state or safe provider-event tail
  events  <lane> [--lines N] [--json]   normalized provider event tail (automation default)
  inspect [<lane>] [--json]              read-only lane reconciliation/classification
  peek    <lane> [--lines N] [--events]  pane diagnosis (or normalized event tail)
  wait    <lane> [--timeout S] [--interval S] [--reap]   block until idle; --reap cleans up only after idle
  park    <lane> [--reason TEXT] [--adopt-legacy]  park an owned, terminal-idle resumable lane
  gc      [--lane-age S] [--project DIR] [--adopt-legacy] [--apply]
                                      dry-run eligible terminal-idle lanes; --apply parks, never reaps
  revise  <lane> [--out FILE] -- <message>      steer live, or resume if exited
  accept-runtime <lane> --reason TEXT            accept the current observed Codex runtime mismatch
  attach  <lane>                        attach your terminal to the pane
  close   <lane> --status <harvested|superseded|abandoned|open> [prov]  fan-in outcome
  captured <lane> --in <ref>            is lane's work already in <ref>? (by content)
  verify  <lane> [--json]               run prepare/verify without reaping (0 pass, 2 fail)
  escalate <lane> [--to OP|PROVIDER/MODEL[/EFFORT]] [--handoff] [--reset-tree]
           [--force] [--ack-deprecated] [--note TEXT] [--json]
           [--resume-transition|--abort-transition]
           revise steers the SAME arm in-session; escalate switches arms after a failed verify
  reap    <lane|--status S,...> [--force] [--keep-worktree] [--no-archive]  clean up
  check   [--cwd DIR] [--config FILE] [--no-fail] [--explain] project integrity gate
  doctor                                check deps + backends
  federation <join|contribute|submit|status|trust|daemon|ui> ...   guided Federation Preview CLI (see below)

Federation Preview (pool spare subscription capacity across a trusted collective):
  federation join <coordinator-url> <invite-token>   one-time: auto keypair + save config
  federation contribute [--task-digest D] [--harness H]   pull + run a task sandboxed (default flow)
  federation submit --display-id ID --source DIR (--prompt TEXT|--prompt-file F) [--output-dir DIR]
  federation status [--task-digest D]                local config / task status
  federation trust <key-id> <pubkey-pem-or-@file>    trust a peer's public key for signature re-verification
  federation daemon [--port N]                       run the local Federation web-UI daemon
  federation ui                                      open the local Federation web UI (starts daemon if needed)
  # Advanced/flagged power-user CLIs (unchanged): bin/waspflow-federation-{coordinator,submit,pull}

Operating points (not cheap/default/max profiles):
  waspflow ops list --task implementation
  waspflow ops explain implement.standard
  waspflow ops resolve review.audit --json
  waspflow spawn --op implement.standard --lane fix -- "…"
  # explicit flags always win over --op expansion

Fan-in (docs/lane-closeout-and-fan-in.md):
  close   <lane> --status harvested  --into <pr#|ref>   # work landed here
  close   <lane> --status superseded --by   <lane|ref>  # a better version won
  close   <lane> --status abandoned  --reason "..."     # dead end, dropped
  list    --status harvested,superseded,abandoned        # the reap-safe set
  reap    --status harvested,superseded,abandoned        # fan-in cleanup, one command

Spawn opts:
  --op <id>          expand a task-shaped operating point (see ops list)
  --model <id>       provider model override
  --auto              select the op fallback (requires --op)
  --ack-deprecated    permit --auto to use an edge-deprecated fallback
  --accept-provider-default
                    intentionally use the provider default model
  --effort <level>   none|minimal|low|medium|high|xhigh|max (pass-through; never silent demote)
  --mcp <policy>     auto|none|inherit (default: auto; MCP-minimal where supported)
  --cwd <dir>        worker cwd (default: current dir)
  --isolate          create an isolated git worktree
  --report <path>    require a deliverable report at reap
  --verify <cmd>     configure a project verification command (run via verify or reap)
  --verify-name <s>  label for verification receipts (default: verify)
  --verify-timeout <seconds>
                    verification timeout in seconds (default: 1800)
  --verify-strength <suite|smoke>
                    declare oracle strength for the receipt (never inferred)
  --prepare <cmd>    run setup command before --verify
  --arg <flag>       pass an extra arg to the provider CLI

Exec opts:
  --op <id>          expand a task-shaped operating point
  --model <id>       provider model override
  --auto              select the op fallback (requires --op)
  --ack-deprecated    permit --auto to use an edge-deprecated fallback
  --accept-provider-default
                    intentionally use the provider default model
  --effort <level>   none|minimal|low|medium|high|xhigh|max
  --mcp <policy>     auto|none|inherit (default: auto; MCP-minimal where supported)
  --cwd <dir>        worker cwd (default: current dir)
  -o <file>          write final message to file (default: stdout)

Billing safety:
  Claude workers refuse to launch when ANTHROPIC_API_KEY is set because that
  bills pay-as-you-go API rates instead of subscription/Agent-SDK credit.
  Unset ANTHROPIC_API_KEY, or intentionally override with:
    WASPFLOW_ALLOW_API_BILLING=1 waspflow spawn --provider claude ...

State: $WASPFLOW_HOME (default ~/.local/state/waspflow)
tmux:  $WASPFLOW_TMUX_SESSION (default waspflow)

Exit codes: 1 usage/error; 2 failed contract; 3 launch unconfirmed; 4 stalled;
            5 selection_required (nothing launched; choose an arm and retry)
EOF
}

# ---- arg splitting ----------------------------------------------------------
# Split argv at the first literal `--` into FLAGS (before) and REST (after).
# REST is the free-text prompt/message so it never needs quoting gymnastics.
split_after_ddash() {
  FLAGS=(); REST=()
  local seen=0
  for a in "$@"; do
    if [[ $seen -eq 0 && "$a" == "--" ]]; then seen=1; continue; fi
    if [[ $seen -eq 0 ]]; then FLAGS+=("$a"); else REST+=("$a"); fi
  done
}

# ============================================================================
# verbs
# ============================================================================

cmd_spawn() {
  local provider="" lane="" model="" cwd="$PWD" isolate=0 effort="" mcp="auto" report="" no_recovery=0
  local verify_command="" verify_name="verify" verify_timeout=1800 prepare_command="" verify_strength=""
  local op_id="" OP_ID="" OP_MODE="" provider_explicit=false model_explicit=false auto=false ack_deprecated=false accept_provider_default=false
  local -a extra=()
  split_after_ddash "$@"
  set -- "${FLAGS[@]:-}"
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --provider) provider="${2:-}"; provider_explicit=true; shift 2 ;;
      --op)       op_id="${2:-}"; shift 2 ;;
      --lane)     lane="${2:-}"; shift 2 ;;
      --model)    model="${2:-}"; model_explicit=true; shift 2 ;;
      --auto) auto=true; shift ;;
      --ack-deprecated) ack_deprecated=true; shift ;;
      --accept-provider-default) accept_provider_default=true; shift ;;
      --effort)   effort="${2:-}"; shift 2 ;;
      --mcp)
        [[ $# -ge 2 && -n "${2:-}" ]] || die "spawn: --mcp requires auto, none, or inherit"
        mcp="$2"; shift 2
        ;;
      --cwd)      cwd="${2:-}"; shift 2 ;;
      --isolate|--worktree) isolate=1; shift ;;
      --report)   report="${2:-}"; shift 2 ;;     # opt-in deliverable contract
      --no-recovery) no_recovery=1; shift ;;
      --verify) verify_command="${2:-}"; shift 2 ;;
      --verify-name) verify_name="${2:-}"; shift 2 ;;
      --verify-timeout) verify_timeout="${2:-}"; shift 2 ;;
      --verify-strength) verify_strength="${2:-}"; shift 2 ;;
      --prepare) prepare_command="${2:-}"; shift 2 ;;
      --arg)      extra+=("${2:-}"); shift 2 ;;   # repeatable pass-through to the agent CLI
      "")         shift ;;
      *) die "spawn: unknown option '$1'" ;;
    esac
  done
  local prompt="${REST[*]:-}"

  [[ "$auto" == false || -n "$op_id" ]] || die "spawn: --auto requires --op"
  [[ "$auto" == false || "$model_explicit" == false ]] || die "spawn: --auto conflicts with --model"
  [[ "$auto" == false || "$accept_provider_default" == false ]] || die "spawn: --auto conflicts with --accept-provider-default"
  [[ "$model_explicit" == false || "$accept_provider_default" == false ]] || die "spawn: --model conflicts with --accept-provider-default"
  [[ "$ack_deprecated" == false || "$auto" == true ]] || die "spawn: --ack-deprecated applies only to --auto"
  local selection_mode
  selection_mode="$(selection_gate_mode)"
  if [[ "$selection_mode" == enforce && -z "$op_id" && "$model_explicit" == false && "$accept_provider_default" == false ]]; then
    selection_menu
    return 5
  fi
  if [[ "$selection_mode" == warn && -z "$op_id" && "$model_explicit" == false && "$accept_provider_default" == false ]]; then
    warn "selection: bare provider default; add --accept-provider-default to make this intentional"
  fi

  # Expand --op first (explicit --provider/--model/--effort win over expansion).
  if [[ -n "$op_id" ]]; then
    local op_fallback_provider op_fallback_model
    op_fallback_provider="$(jq -r '.expands_to.provider // empty' <<<"$(ops_get_point "$op_id")")"
    op_fallback_model="$(jq -r '.expands_to.model // empty' <<<"$(ops_get_point "$op_id")")"
    if [[ "$provider_explicit" == true && "$model_explicit" == false && "$provider" != "$op_fallback_provider" ]]; then
      die "op $op_id resolves $op_fallback_provider/$op_fallback_model; --provider $provider contradicts it — give --model too, or drop one"
    fi
    ops_apply_to_spawn "$op_id"
    [[ "$accept_provider_default" == true ]] && model=""
  fi

  [[ -n "$provider" ]] || die "spawn: --provider or --op is required (claude|codex|grok)"
  is_known_provider "$provider" || die "spawn: unknown provider '$provider'"
  [[ -n "$lane" ]] || die "spawn: --lane is required"
  validate_lane_name "$lane"
  [[ -n "$prompt" ]] || die "spawn: a task prompt is required after '--'"
  cwd="$(cd "$cwd" && pwd)" || die "spawn: --cwd does not exist"
  guard_cwd "$cwd"   # never hand a worker '/' silently (known grok --cwd / crash)
  if [[ -n "$effort" && ! "$effort" =~ ^(none|minimal|low|medium|high|xhigh|max)$ ]]; then
    die "spawn: --effort must be one of none|minimal|low|medium|high|xhigh|max (got: $effort)"
  fi

  # Enforced selection runs before tmux/lane creation. The selected fallback is
  # still checked by Phase 1 below; explicit --model callers deliberately skip
  # this selector gate (the doctrine is explicit choice proceeds).
  local gate_endpoint="default" gate_raw=false gate_scope gate_billing
  [[ ${#extra[@]} -gt 0 ]] && gate_raw=true
  if [[ "$provider" == codex ]]; then
    local gate_arg
    for gate_arg in "${extra[@]}"; do
      [[ "$gate_arg" == --oss ]] && gate_endpoint=oss
      [[ "$gate_arg" == --profile=* ]] && gate_endpoint="${gate_arg#--profile=}"
    done
  fi
  if [[ "$selection_mode" == enforce && -n "$op_id" && "$model_explicit" == false && "$accept_provider_default" == false ]]; then
    load_provider "$provider"
    gate_scope="$(model_validation_scope "$provider" "${extra[@]}")"
    gate_billing="$(billing_path_v1 "$provider" "$gate_endpoint" "$gate_raw")"
    local selection_rc=0
    selection_gate_op "$op_id" "$provider" "$model" "$gate_scope" "$gate_billing" "$ack_deprecated" "$auto" || selection_rc=$?
    [[ "$selection_rc" -eq 0 ]] || return "$selection_rc"
  fi

  # If capabilities-derived whitelist is loaded, enforce per provider (after op expansion).
  if [[ -n "$effort" && -n "${provider:-}" ]]; then
    local _wl_var="WASPFLOW_EFFORTS_${provider^^}"
    local _wl="${!_wl_var:-}"
    if [[ -n "$_wl" && ! "$effort" =~ ^($_wl)$ ]]; then
      die "spawn: effort '$effort' not in capabilities whitelist for $provider (valid: ${_wl//|/, })"
    fi
  fi
  if [[ -n "$verify_command" ]]; then
    [[ -n "$verify_name" ]] || die "spawn: --verify-name cannot be empty"
    [[ "$verify_timeout" =~ ^[0-9]+$ && "$verify_timeout" -gt 0 ]] \
      || die "spawn: --verify-timeout must be a positive integer (got: $verify_timeout)"
  elif [[ -n "$prepare_command" ]]; then
    die "spawn: --prepare requires --verify"
  fi
  [[ -z "$verify_strength" || "$verify_strength" == suite || "$verify_strength" == smoke ]] \
    || die "spawn: --verify-strength must be suite or smoke (got: $verify_strength)"
  [[ -z "$verify_strength" || -n "$verify_command" ]] \
    || die "spawn: --verify-strength requires --verify"

  require_cmd tmux jq
  # Start the dedicated server before opening the lane-operation lock. A tmux
  # server launched while that fd is open would inherit it and hold the flock
  # for the lifetime of the server, deadlocking every later command for the lane.
  tmux_ensure_session
  # Serialize claim/check/create/capture for this lane name. Without this, two
  # concurrent spawns can both pass the existence check and create duplicates.
  command -v flock >/dev/null 2>&1 || die "spawn: flock is required for an atomic lane claim"
  mkdir -p "$WASPFLOW_LOCKS_DIR"
  local spawn_lock_fd
  exec {spawn_lock_fd}>"$WASPFLOW_LOCKS_DIR/$lane.lock"
  flock -x "$spawn_lock_fd"
  # A lane record is durable evidence. Reusing a name is allowed only after the
  # old record was explicitly reaped; parked, exited, malformed, and otherwise
  # unreaped records must never be silently overwritten by a new spawn.
  if lane_exists "$lane"; then
    jq empty "$(lane_state_file "$lane")" 2>/dev/null \
      || die "spawn: lane '$lane' has corrupted state.json; refusing to overwrite it"
    [[ "$(lane_get "$lane" status)" == "reaped" ]] \
      || die "spawn: lane '$lane' already exists and is unreaped (reap it first or pick another name)"
  fi
  # Avoid creating an indistinguishable second tmux window when a record was
  # deleted manually but its old window remains.
  tmux_named_lane_window_exists "$lane" \
    && die "spawn: tmux window '$WASPFLOW_TMUX_SESSION:$lane' already exists; inspect or remove it first"

  load_provider "$provider"

  local model_validation_scope
  model_validation_scope="$(model_validation_scope "$provider" "${extra[@]}")"
  validate_model "$provider" "$model" spawn "$model_validation_scope"
  validate_mcp_extra "$provider" "$mcp" "${extra[@]}"
  "${provider}_preflight" || die "spawn aborted: $provider preflight failed"

  # Worktree isolation (opt-in, only inside a git repo).
  local work_cwd="$cwd" wt_path="" repo_root=""
  if [[ "$isolate" -eq 1 ]]; then
    repo_root="$(worktree_repo_root "$cwd")"
    wt_path="$(worktree_create "$lane" "$cwd")" || die "spawn: worktree isolation failed"
    work_cwd="$wt_path"
    log "isolated worktree: $wt_path"
  fi

  # Discover from the worker's effective cwd. Provider MCP configuration can be
  # project-scoped, and the isolated worktree is the process boundary that must
  # be measured. If discovery fails after worktree creation, remove that empty
  # worktree instead of leaking setup debris.
  if ! resolve_mcp_policy "$provider" "$mcp" "$work_cwd"; then
    [[ -n "$wt_path" ]] && worktree_remove "$lane" "$wt_path" "$repo_root" 1 >/dev/null 2>&1 || true
    die "$provider: cannot resolve MCP policy '$mcp'"
  fi
  [[ -n "$MCP_WARNING" ]] && warn "$MCP_WARNING"

  local session_id transcript
  session_id="$(new_uuid)"           # claude/grok use this; codex mints its own
  mkdir -p "$(lane_dir "$lane")"
  transcript="$(lane_transcript "$lane")"
  : >"$transcript"

  # Resolve a --report path to absolute against the worker's working dir so the
  # agent writes it where we'll look for it.
  local report_abs=""
  if [[ -n "$report" ]]; then
    [[ "$report" != *$'\n'* && "$report" != *$'\r'* ]] \
      || die "spawn: --report cannot contain newlines"
    report_abs="$(artifacts_normalize_report_path "$work_cwd" "$report")" \
      || die "spawn: cannot normalize --report path '$report'"
    prompt="$(artifacts_report_prompt "$prompt" "$report_abs")"
  fi

  # Record state BEFORE spawn so a crash mid-spawn is still recoverable.
  # Claude and Grok accept a client-minted --session-id; Codex discovers its own.
  local recorded_sid=""
  case "$provider" in claude|grok) recorded_sid="$session_id" ;; esac
  # When --op was used, record policy/catalog pins for lane→evidence traceability.
  local policy_version="" catalog_ref="" policy_file=""
  local task_family="" constraint_family=""
  if [[ -n "${OP_ID:-}" ]]; then
    ops_load 2>/dev/null || true
    if [[ -n "${OPS_POLICY_JSON:-}" ]]; then
      policy_version="$(jq -r '.policy_version // empty' <<<"$OPS_POLICY_JSON")"
      catalog_ref="$(jq -r '.catalog_ref // empty' <<<"$OPS_POLICY_JSON")"
    fi
    policy_file="${OPS_POLICY_FILE:-}"
    local op_row
    op_row="$(ops_get_point "$OP_ID" 2>/dev/null || true)"
    task_family="$(jq -r '.task_family // empty' <<<"$op_row" 2>/dev/null || true)"
    constraint_family="$(jq -r '.constraint_family // empty' <<<"$op_row" 2>/dev/null || true)"
  fi

  local endpoint_profile="default" raw_provider_args="false" codex_profile="" codex_oss=0 arg
  [[ ${#extra[@]} -gt 0 ]] && raw_provider_args="true"
  if [[ "$provider" == codex ]]; then
    local i
    for ((i=0; i<${#extra[@]}; i++)); do
      arg="${extra[$i]}"
      case "$arg" in
        --oss) codex_oss=1 ;;
        --profile=*) codex_profile="${arg#--profile=}" ;;
        --profile|-p) codex_profile="${extra[$((i + 1))]:-default}" ;;
      esac
    done
    [[ "$codex_oss" -eq 1 ]] && endpoint_profile="oss" || endpoint_profile="${codex_profile:-default}"
  fi
  local billing_path auth_principal lane_uuid
  billing_path="$(billing_path_v1 "$provider" "$endpoint_profile" "$raw_provider_args")"
  auth_principal="$(billing_auth_principal "$provider")"
  lane_uuid="$(new_uuid)"
  # Compute dispositions on every selected/explicit arm. Enforcement decides
  # whether to stop; explicit choice always continues after its warnings.
  if [[ -n "$op_id" ]]; then
    selection_prepare_op "$op_id" "$provider" "$model" "$MODEL_VALIDATION_SCOPE" "$billing_path" "$ack_deprecated"
    if [[ "$selection_mode" == warn || "$model_explicit" == true ]]; then selection_emit_warnings "$SELECTION_DISPOSITION"; fi
  elif [[ "$model_explicit" == true ]]; then
    local explicit_edge explicit_disposition
    explicit_edge="$(selection_edge_label "$provider" "$model")"
    explicit_disposition="$(selection_disposition "$MODEL_VALIDATION_STATE" unratified "$explicit_edge" none false false false explicit)"
    selection_emit_warnings "$explicit_disposition"
  fi
  local selection_quota_observation selection_quota_filtered
  selection_quota_observation="${SELECTION_QUOTA_OBSERVATION:-$(quota_observation_v1 "$provider")}"
  selection_quota_filtered="${SELECTION_QUOTA_FILTERED:-$(selection_quota_filtered "$billing_path" "$selection_quota_observation" "$MODEL_VALIDATION_SCOPE")}"

  # Runtime receipt enforcement is versioned at launch. Existing lanes with no
  # marker retain their historical lifecycle semantics; new Codex lanes must
  # prove a healthy current observation before reap can claim success.
  local runtime_receipt_version="" runtime_receipt_enforced="false"
  if [[ "$provider" == codex ]]; then
    runtime_receipt_version="2"
    runtime_receipt_enforced="true"
  fi
  # The isolated worktree starts at this exact commit. It is the only sound
  # baseline for the v1 test-integrity heuristic; normal/legacy lanes report
  # that signal as unknown instead of inventing a fork point.
  local verify_fork_point=""
  [[ -n "$wt_path" ]] && verify_fork_point="$(git -C "$work_cwd" rev-parse HEAD 2>/dev/null || true)"
  local spawned_epoch
  spawned_epoch="$(date +%s)"
  lane_set "$lane" \
    provider "$provider" \
    lane_uuid "$lane_uuid" \
    surface "tui" \
    status "live" \
    result "" \
    outcome "" \
    outcome_into "" \
    outcome_by "" \
    outcome_reason "" \
    outcome_epoch "" \
    receipt_emitted "false" \
    receipt_emitted_segment "-1" \
    receipt_id "" \
    cwd "$work_cwd" \
    origin_cwd "$cwd" \
    model "$model" \
    model_requested "$model" \
    model_passed "$model" \
    effort "$effort" \
    endpoint_profile "$endpoint_profile" \
    raw_provider_args "$raw_provider_args" \
    auth_principal "$auth_principal" \
    billing_path "$billing_path" \
    selection_quota_observation "$selection_quota_observation" \
    selection_quota_filtered "$selection_quota_filtered" \
    model_validation_state "$MODEL_VALIDATION_STATE" \
    model_validation_source "$MODEL_VALIDATION_SOURCE" \
    model_validation_scope "$MODEL_VALIDATION_SCOPE" \
    model_validation_at "$MODEL_VALIDATION_AT" \
    surface_changed "false" \
    mcp_requested "$mcp" \
    mcp_resolved "$MCP_RESOLVED" \
    mcp_warning "$MCP_WARNING" \
    mcp_argv "$MCP_ARGV_JSON" \
    mcp_env "$MCP_ENV_JSON" \
    effort_requested "$effort" \
    runtime_receipt_version "$runtime_receipt_version" \
    runtime_receipt_enforced "$runtime_receipt_enforced" \
    runtime_settings_state "unknown" \
    runtime_refresh_state "pending" \
    runtime_refresh_error "" \
    runtime_model "" \
    runtime_effort "" \
    runtime_settings_source "" \
    runtime_settings_observed_at "" \
    runtime_settings_match_requested "" \
    runtime_settings_accepted_at "" \
    runtime_settings_accepted_reason "" \
    runtime_settings_accepted_observed_at "" \
    op "${OP_ID:-}" \
    op_mode "${OP_MODE:-}" \
    task_family "$task_family" \
    constraint_family "$constraint_family" \
    policy_version "$policy_version" \
    catalog_ref "$catalog_ref" \
    policy_file "$policy_file" \
    op_expands_to "${OP_EXPANDS_TO:-}" \
    explicit_overrides "${EXPLICIT_OVERRIDES:-[]}" \
    session_id "$recorded_sid" \
    arm_generation "0" \
    arm_history "[]" \
    escalation_path "[]" \
    escalations_total "0" \
    consecutive_failed_segments "0" \
    segment_index "0" \
    segment_started_epoch "$spawned_epoch" \
    segment_entered_via_escalation "false" \
    ladder_cursor "${OP_ID:-}" \
    pending_transition "" \
    escalation_error "" \
    rollout "" \
    worktree "$wt_path" \
    repo_root "$repo_root" \
    verify_fork_point "$verify_fork_point" \
    transcript "$transcript" \
    report "$report_abs" \
    no_recovery "$([[ "$no_recovery" -eq 1 ]] && echo true || echo false)" \
    verify_command "$verify_command" \
    verify_name "$verify_name" \
    verify_timeout "$verify_timeout" \
    verify_strength "$verify_strength" \
    prepare_command "$prepare_command" \
    verify_runs "[]" \
    verify_state "" \
    verify_failure_class "" \
    verify_test_files_changed "" \
    verify_checkpoint_epoch "" \
    verify_checkpoint_fingerprint "" \
    verify_epoch "" \
    verify_exit_code "" \
    prepare_state "" \
    prepare_exit_code "" \
    prepare_epoch "" \
    baseline_oracle_ran "" \
    baseline_oracle_state "" \
    baseline_oracle_reason "" \
    spawn_epoch "$spawned_epoch" \
    prompt "$prompt"

  # Durable artifacts: prompt + git-status-before, automatically (no flag).
  artifacts_capture_before "$lane" "$work_cwd" "$prompt"

  # Spawn + confirm the task actually submitted. A provider adapter returns nonzero
  # when it could not confirm submission (dead-on-arrival: window up, task never
  # injected — e.g. a modal stole focus). Record the lane either way so it stays
  # inspectable, but tell the caller LOUDLY and exit nonzero: a silent "spawned"
  # on a lane that never ran is the failure that makes an orchestrator report
  # phantom work in flight.
  local spawn_rc=0
  "${provider}_spawn" "$lane" "$work_cwd" "$model" "$session_id" "$transcript" "$prompt" "${extra[@]}" || spawn_rc=$?

  # Adapters create the window before they confirm prompt submission. Capture
  # ownership whenever that window exists—even on rc=3—so a failed startup and
  # its MCP children remain auditable/cleanable rather than becoming an unowned
  # leak. If the just-created window cannot be identified, stop it by name now.
  local window_owned=0
  tmux_owned_lane_window_exists "$lane" && window_owned=1
  if tmux_named_lane_window_exists "$lane" && [[ "$window_owned" -ne 1 ]]; then
    tmux kill-window -t "$WASPFLOW_TMUX_SESSION:$lane" 2>/dev/null || true
    lane_set "$lane" status "spawn_failed" spawn_submitted "false"
    die "spawn: provider created a window without an ownership receipt; stopped the unowned window"
  fi

  if [[ "$spawn_rc" -ne 0 ]]; then
    lane_set "$lane" spawn_submitted "false"
    err "spawn: lane '$lane' launched but the task was NOT confirmed submitted"
    err "  the worker may be stuck at a startup prompt (trust gate / MCP auth / other modal)."
    err "  inspect:  waspflow peek $lane        (see what is blocking)"
    err "  recover:  waspflow revise $lane -- \"<the task>\"   (re-inject once unblocked)"
    err "  the lane is recorded, so nothing is lost — but do NOT assume it is working."
    return 3
  fi
  lane_set "$lane" spawn_submitted "true"
  if [[ "$window_owned" -ne 1 ]]; then
    lane_set "$lane" status "spawn_failed" spawn_submitted "false"
    die "spawn: provider reported success but created no owned tmux window"
  fi

  log "spawned $provider lane '$lane' (tmux: $WASPFLOW_TMUX_SESSION:$lane) — next: wait/peek/revise/reap $lane"
  [[ -n "$report_abs" ]] && log "  deliverable contract: $report_abs (verified on idle; one recovery pass if missing)"
  [[ -n "$verify_command" ]] && log "  verify contract: $verify_name -> $verify_command"
  return 0
}

cmd_exec() {
  exec_run "$@"
}

cmd_demo() {
  local provider="" lane="" run=0 cwd="$PWD"
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --provider) provider="${2:-}"; shift 2 ;;
      --lane) lane="${2:-}"; shift 2 ;;
      --cwd) cwd="${2:-}"; shift 2 ;;
      --run) run=1; shift ;;
      -h|--help)
        cat <<'EOF'
waspflow demo --provider <claude|codex|grok> [--run] [--lane NAME] [--cwd DIR]

Without --run, prints a safe first-run walkthrough.
With --run, performs spawn -> wait -> peek -> reap using a tiny no-edit task.
EOF
        return 0
        ;;
      *) die "demo: unknown option '$1'" ;;
    esac
  done

  if [[ -z "$provider" ]]; then
    if command -v codex >/dev/null 2>&1; then provider="codex"
    elif command -v claude >/dev/null 2>&1; then provider="claude"
    elif command -v grok >/dev/null 2>&1; then provider="grok"
    else die "demo: no provider found on PATH (install codex, claude, or grok, or pass --provider)"
    fi
  fi
  is_known_provider "$provider" || die "demo: unknown provider '$provider'"
  cwd="$(cd "$cwd" && pwd)" || die "demo: --cwd does not exist"
  lane="${lane:-demo-$(date +%s)}"
  validate_lane_name "$lane"

  local prompt="This is a waspflow first-run demo. Do not edit files. Reply with exactly one sentence that starts with 'waspflow demo ready'."
  if [[ "$run" -ne 1 ]]; then
    cat <<EOF
waspflow demo

This will prove the core loop with a no-edit task:

  waspflow spawn --provider $provider --accept-provider-default --lane $lane --cwd "$cwd" -- "$prompt"
  waspflow wait $lane --timeout 300
  waspflow peek $lane --lines 8
  waspflow reap $lane

Run it now:

  waspflow demo --provider $provider --lane $lane --cwd "$cwd" --run
EOF
    return 0
  fi

  cmd_spawn --provider "$provider" --accept-provider-default --lane "$lane" --cwd "$cwd" -- "$prompt"
  cmd_wait "$lane" --timeout 300
  cmd_peek "$lane" --lines 8
  cmd_reap "$lane"
}

# Healthy fleet JSON is the high-volume machine surface. Parse bounded chunks of
# selected state files in one jq process rather than reopening each record for
# every field. A malformed file makes its chunk fail and deliberately falls
# back to the conservative per-file path below, which surfaces corruption.
cmd_list_json_batch() {
  local lanes="$1" snapshot="$2" lane start=0 chunk_size=128 output
  local -a names=() files=() rows=()
  mapfile -t names <<<"$lanes"
  while [[ "$start" -lt "${#names[@]}" ]]; do
    files=()
    for ((i=start; i<start+chunk_size && i<${#names[@]}; i++)); do files+=("$(lane_state_file "${names[$i]}")"); done
    output="$(jq -c --arg snapshot "$snapshot" '
      input_filename as $file |
      ($file | split("/") | .[-2]) as $lane |
      (.tmux_window // "") as $window |
      ((.tmux_pane_pid // "") | tostring) as $pid |
      (if $window != "" and ($pid|test("^[0-9]+$"))
       then ($snapshot | split("\n") | any((split("|")[0] // "") == $window and (split("|")[2] // "") == $pid))
       else ($snapshot | split("\n") | any((split("|")[1] // "") == $lane)) end) as $live_window |
      (if .status == "reaped" then "reaped" elif .status == "parked" then "parked" elif $live_window then "live" else "exited" end) as $lifecycle |
      {lane:$lane,provider:(.provider // ""),lifecycle_state:$lifecycle,
       record_status:(.status // ""),outcome:(if (.outcome // "") == "" then "open" else .outcome end),result:(.result // ""),
       cwd:(.cwd // ""),origin_cwd:(.origin_cwd // ""),repo_root:(.repo_root // ""),
       requested_model:(.model_requested // .model // ""),requested_effort:(.effort_requested // .effort // ""),
       runtime_model:(.runtime_model // ""),runtime_effort:(.runtime_effort // ""),
       runtime_settings_source:(.runtime_settings_source // ""),runtime_settings_observed_at:(.runtime_settings_observed_at // ""),
       runtime_settings_state:(.runtime_settings_state // "unknown"),runtime_settings_match_requested:(.runtime_settings_match_requested // "unknown"),
       runtime_settings_error:(.runtime_settings_error // ""),runtime_refresh_state:(.runtime_refresh_state // "unknown"),
       runtime_refresh_error:(.runtime_refresh_error // ""),runtime_receipt_enforced:(.runtime_receipt_enforced // "false"),spawn_epoch:(.spawn_epoch // ""),
       updated_at:(.updated_at // ""),parked_at:(.parked_at // ""),spawn_submitted:(.spawn_submitted // ""),
       mcp_requested:(.mcp_requested // ""),mcp_resolved:(.mcp_resolved // ""),mcp_warning:(.mcp_warning // ""),
       tmux_session:(.tmux_session // ""),tmux_window:(.tmux_window // ""),tmux_pane_pid:(.tmux_pane_pid // "")}
    ' "${files[@]}" 2>/dev/null)" || return 1
    while IFS= read -r lane; do [[ -n "$lane" ]] && rows+=("$lane"); done <<<"$output"
    start=$((start + chunk_size))
  done
  [[ ${#rows[@]} -eq 0 ]] && echo '[]' || printf '%s\n' "${rows[@]}" | jq -cs .
}

# The flywheel made visible: what the outcome ledger holds, and how much of it
# is stats-eligible calibration data. Read-only over receipts.jsonl.
cmd_receipts() {
  local sub="${1:-summary}" json=0
  shift || true
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json=1; shift ;;
      *) die "receipts: unknown option '$1' (usage: receipts summary [--json])" ;;
    esac
  done
  [[ "$sub" == summary ]] || die "receipts: unknown subcommand '$sub' (only: summary [--json])"
  local ledger="$WASPFLOW_HOME/receipts.jsonl"
  [[ -r "$ledger" ]] || { log "receipts: no ledger yet ($ledger)"; return 0; }
  local report
  report="$(jq -cR 'fromjson? // empty' "$ledger" | jq -cs '
    map(select(type == "object")) as $all |
    ($all | map(select(.receipt_kind == "lane" or (.receipt_kind // "lane") == "lane"))) as $lanes |
    {
      total_rows: ($all | length),
      lanes: ($lanes | length),
      execs: ($all | map(select(.receipt_kind == "exec")) | length),
      segments: ($all | map(select(.receipt_kind == "lane_segment")) | length),
      eligible: ($lanes | map(select(.stats_eligible == true)) | length),
      escalations: ($all | map(.escalation_path // [] | length) | add // 0),
      by_arm: ($lanes | group_by((.arm_requested.provider // "?") + "/" + (if (.arm_requested.model // "") == "" then "(default)" else .arm_requested.model end)) |
        map({arm: ((.[0].arm_requested.provider // "?") + "/" + (if (.[0].arm_requested.model // "") == "" then "(default)" else .[0].arm_requested.model end)),
             n: length,
             verified: (map(select(.result == "verified")) | length),
             verify_failed: (map(select(.result == "verify_failed")) | length),
             eligible: (map(select(.stats_eligible == true)) | length)}) | sort_by(-.n)),
      top_ineligibility: ($lanes | map((.ineligibility_reasons? // []) | if type == "array" then .[] else empty end) | group_by(.) |
        map({reason: .[0], n: length}) | sort_by(-.n) | .[0:5])
    }')"
  if [[ "$json" -eq 1 ]]; then printf '%s\n' "$report"; return 0; fi
  jq -r '
    "receipts: \(.lanes) lanes, \(.segments) segments, \(.execs) execs (\(.total_rows) rows)",
    "eligible calibration data: \(.eligible)/\(.lanes) lane receipts",
    "escalations recorded: \(.escalations)",
    "per arm (n verified/failed eligible):",
    (.by_arm[] | "  \(.arm)  \(.n)  \(.verified)/\(.verify_failed)  \(.eligible)"),
    "top ineligibility reasons:",
    (if (.top_ineligibility | length) == 0 then "  (none)" else (.top_ineligibility[] | "  \(.reason)  \(.n)") end)
  ' <<<"$report"
}

cmd_list() {
  local status_filter="" lifecycle_filter="" project="" limit="" json=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --status) [[ $# -ge 2 ]] || die "list: --status requires a value"; status_filter="$2"; shift 2 ;;
      --lifecycle-state) [[ $# -ge 2 ]] || die "list: --lifecycle-state requires a value"; lifecycle_filter="$2"; shift 2 ;;
      --project) [[ $# -ge 2 ]] || die "list: --project requires a directory"; project="$2"; shift 2 ;;
      --limit) [[ $# -ge 2 ]] || die "list: --limit requires a value"; limit="$2"; shift 2 ;;
      --json) json=1; shift ;;
      -*) die "list: unknown option '$1'" ;;
      *) shift ;;
    esac
  done
  [[ -z "$limit" || "$limit" =~ ^[0-9]+$ && "$limit" -gt 0 ]] \
    || die "list: --limit must be a positive integer (got: $limit)"
  if [[ -n "$lifecycle_filter" ]]; then
    local requested_state
    local -a requested_states=()
    IFS=',' read -r -a requested_states <<<"$lifecycle_filter"
    for requested_state in "${requested_states[@]}"; do
      case "$requested_state" in live|exited|parked|reaped) ;; *) die "list: --lifecycle-state must contain only live, exited, parked, or reaped" ;; esac
    done
  fi
  if [[ -n "$project" ]]; then
    project="$(cd "$project" && pwd)" || die "list: --project does not exist: $project"
  fi
  local lanes; lanes="$(list_lanes)"
  if [[ -z "$lanes" ]]; then
    [[ "$json" -eq 1 ]] && echo '[]' || echo "(no lanes)"
    return 0
  fi
  [[ "$json" -eq 1 ]] || printf '%-20s %-8s %-8s %-11s %-48s %s\n' LANE PROVIDER STATE OUTCOME INTENT/RUNTIME CWD
  local tmux_snapshot; tmux_snapshot="$(tmux_fleet_snapshot)"
  # Fast path: the common machine fleet inventory. Filters and prefix limits
  # intentionally use the exact conservative path below; this path handles the
  # healthy, unfiltered index without changing those semantics.
  if [[ "$json" -eq 1 && -z "$status_filter" && -z "$lifecycle_filter" && -z "$project" && -z "$limit" ]]; then
    if cmd_list_json_batch "$lanes" "$tmux_snapshot"; then return 0; fi
  fi
  local lane matched=0 any_corrupt=0 emitted=0
  local -a json_rows=()
  while IFS= read -r lane; do
    [[ -n "$lane" ]] || continue
    # `--limit` is intentionally a prefix of the sorted durable index. Once it
    # is filled, later corrupt records are outside that requested prefix; an
    # unbounded list still surfaces every corrupt record.
    [[ -z "$limit" || "$emitted" -lt "$limit" ]] || break
    # A corrupt state.json must be SURFACED, not laundered into a blank/exited lane
    # (that would misreport the fleet). A corrupt record has unknown scope, so
    # it remains visible even under project/state filters rather than disappearing.
    local record
    if ! record="$(jq -c . "$(lane_state_file "$lane")" 2>/dev/null)"; then
      matched=1; any_corrupt=1
      if [[ "$json" -eq 1 ]]; then
        json_rows+=("$(jq -cn --arg lane "$lane" '{lane:$lane,lifecycle_state:"corrupt",corrupt:true,error:"unparseable state.json",scope:"unknown"}')")
      else
      printf '%-20s %-8s %-8s %-11s %-48s %s\n' "$lane" "?" "CORRUPT" "?" "unknown" "(unparseable state.json)"
      fi
      continue
    fi
    # Read each durable record once. All filtering and rendering below operates
    # on that value, never by re-opening state.json or provider session logs.
    local provider status cwd outcome origin_cwd repo_root window pane_pid live lifecycle
    # Delimit with US (\x1f), NOT tab: tab is IFS-whitespace, so `read` collapses
    # consecutive tabs and an empty middle field (e.g. repo_root="" on a
    # non-isolated lane) shifts every later field left — window/pane_pid empty,
    # so a dead lane matches on name and prints live, disagreeing with --json
    # (excellence audit Ranks 1 & 11). US never appears in these values.
    IFS=$'\x1f' read -r provider status cwd outcome origin_cwd repo_root window pane_pid < <(
      jq -j '[(.provider // ""),(.status // ""),(.cwd // ""),(if (.outcome // "") == "" then "open" else .outcome end),(.origin_cwd // ""),(.repo_root // ""),(.tmux_window // ""),(.tmux_pane_pid // "")] | join("\u001f")' <<<"$record"
    ) || true
    # --status filters on the fan-in OUTCOME (the reap-safe question).
    if [[ -n "$status_filter" ]]; then
      [[ ",$status_filter," == *",$outcome,"* ]] || continue
    fi
    if [[ -n "$window" && "$pane_pid" =~ ^[0-9]+$ ]]; then
      if awk -F '|' -v w="$window" -v p="$pane_pid" '$1 == w && $3 == p { found=1 } END { exit !found }' <<<"$tmux_snapshot"; then live="live"; else live="exited"; fi
    elif awk -F '|' -v n="$lane" '$2 == n { found=1 } END { exit !found }' <<<"$tmux_snapshot"; then live="live"; else live="exited"; fi
    [[ "$status" == "reaped" ]] && live="reaped"
    [[ "$status" == "parked" ]] && live="parked"
    lifecycle="$live"
    [[ -z "$lifecycle_filter" || ",$lifecycle_filter," == *",$lifecycle,"* ]] || continue
    [[ -z "$project" ]] || lane_matches_project "$lane" "$project" || continue
    matched=1
    if [[ "$json" -eq 1 ]]; then
      # Fleet JSON is an index, not `status`: expose operational metadata only.
      # In particular, do not copy prompts, commands, or provider argv/env from
      # the full lane record into bulk audit output.
      json_rows+=("$(jq -c --arg lane "$lane" --arg lifecycle "$lifecycle" --arg outcome "$outcome" '
        {lane:$lane,provider:(.provider // ""),lifecycle_state:$lifecycle,
         record_status:(.status // ""),outcome:$outcome,result:(.result // ""),
         cwd:(.cwd // ""),origin_cwd:(.origin_cwd // ""),repo_root:(.repo_root // ""),
         requested_model:(.model_requested // .model // ""),requested_effort:(.effort_requested // .effort // ""),
         runtime_model:(.runtime_model // ""),runtime_effort:(.runtime_effort // ""),
         runtime_settings_source:(.runtime_settings_source // ""),runtime_settings_observed_at:(.runtime_settings_observed_at // ""),
         runtime_settings_state:(.runtime_settings_state // "unknown"),runtime_settings_match_requested:(.runtime_settings_match_requested // "unknown"),
         runtime_settings_error:(.runtime_settings_error // ""),runtime_refresh_state:(.runtime_refresh_state // "unknown"),
         runtime_refresh_error:(.runtime_refresh_error // ""),runtime_receipt_enforced:(.runtime_receipt_enforced // "false"),spawn_epoch:(.spawn_epoch // ""),
         updated_at:(.updated_at // ""),parked_at:(.parked_at // ""),
         spawn_submitted:(.spawn_submitted // ""),mcp_requested:(.mcp_requested // ""),
         mcp_resolved:(.mcp_resolved // ""),mcp_warning:(.mcp_warning // ""),
         tmux_session:(.tmux_session // ""),tmux_window:(.tmux_window // ""),
         tmux_pane_pid:(.tmux_pane_pid // "")}' <<<"$record")")
    else
      local runtime_label
      runtime_label="$(jq -r '((.model_requested // .model // "default") + "/" + (.effort_requested // .effort // "default") + " -> ") + (if (.runtime_settings_state // "unknown") == "observed" then ((.runtime_model // "?") + "/" + (.runtime_effort // "?") + " " + (if .runtime_settings_match_requested == "false" then "DRIFT" elif .runtime_settings_match_requested == "true" then "match" else "observed" end)) else (.runtime_settings_state // "unknown") end) + " [refresh=" + (.runtime_refresh_state // "unknown") + if (.runtime_refresh_error // "") != "" then ":" + .runtime_refresh_error else "" end + "]"' <<<"$record")"
      printf '%-20s %-8s %-8s %-11s %-48s %s\n' "$lane" "$provider" "$live" "$outcome" "$runtime_label" "$cwd"
    fi
    emitted=$((emitted + 1))
  done <<<"$lanes"
  if [[ "$json" -eq 1 ]]; then
    if [[ "${#json_rows[@]}" -eq 0 ]]; then echo '[]'; else printf '%s\n' "${json_rows[@]}" | jq -cs .; fi
  elif [[ -n "$status_filter" && "$matched" -eq 0 ]]; then
    echo "(no lanes with outcome in: $status_filter)"
  fi
  [[ "$any_corrupt" -eq 1 ]] && { warn "list: one or more lanes have corrupt state.json (shown as CORRUPT)"; return 2; }
  return 0
}

cmd_close() {
  local lane="" outcome="" pkey="" pval=""
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --status)  outcome="${2:-}"; shift 2 ;;
      --into)    pkey="into";   pval="${2:-}"; shift 2 ;;
      --by)      pkey="by";     pval="${2:-}"; shift 2 ;;
      --reason)  pkey="reason"; pval="${2:-}"; shift 2 ;;
      "")        shift ;;
      -*)        die "close: unknown option '$1'" ;;
      *)         [[ -z "$lane" ]] && { lane="$1"; shift; } || die "close: unexpected arg '$1'" ;;
    esac
  done
  [[ -n "$lane" ]]    || die "close: <lane> required"
  [[ -n "$outcome" ]] || die "close: --status <harvested|superseded|abandoned|open> required"
  fanin_close "$lane" "$outcome" "$pkey" "$pval"
}

cmd_captured() {
  local lane="" ref=""
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --in) ref="${2:-}"; shift 2 ;;
      "")   shift ;;
      -*)   die "captured: unknown option '$1'" ;;
      *)    [[ -z "$lane" ]] && { lane="$1"; shift; } || die "captured: unexpected arg '$1'" ;;
    esac
  done
  [[ -n "$lane" ]] || die "captured: <lane> required"
  [[ -n "$ref" ]]  || die "captured: --in <ref> required"
  fanin_captured "$lane" "$ref"   # prints verdict to stdout, summary to stderr
}

cmd_status() {
  local lane="${1:-}"; shift || true
  local tail_events="" json=0
  while [[ $# -gt 0 ]]; do
    case "$1" in --tail-events) tail_events="${2:-}"; shift 2 ;; --json) json=1; shift ;; *) die "status: unknown option '$1'" ;; esac
  done
  [[ -n "$lane" ]] || die "status: <lane> required"
  lane_exists "$lane" || die "no such lane '$lane'"
  if [[ -n "$tail_events" ]]; then
    [[ "$tail_events" =~ ^[0-9]+$ && "$tail_events" -gt 0 ]] || die "status: --tail-events must be a positive integer"
    [[ "$json" -eq 1 ]] || die "status: --tail-events requires --json (safe machine schema)"
    load_event_reader
    local provider; provider="$(lane_get "$lane" provider)"; load_provider "$provider"
    jq -cn --arg lane "$lane" --arg provider "$provider" --argjson event_tail "$(provider_event_tail "$lane" "$tail_events")" '{lane:$lane,provider:$provider,event_tail:$event_tail}'
    return 0
  fi
  [[ "$json" -eq 0 ]] || die "status: --json is only needed with --tail-events (status is already JSON)"
  # Pretty-print the state, but on malformed JSON emit a clear waspflow error
  # instead of leaking a raw `jq: parse error` to the operator (red-team finding).
  local sf; sf="$(lane_state_file "$lane")"
  # Hot path: codex refresh tails a bounded rollout snapshot; claude/grok
  # refreshers scan whole session logs (hundreds of MB) and belong at reap
  # time only. status shows their attestation once a reap/receipt computed it.
  if [[ "$(lane_get "$lane" provider)" == codex ]]; then
    provider_refresh_runtime_settings "$lane"
  fi
  jq . "$sf" 2>/dev/null || die "lane '$lane' has corrupted state.json ($sf) — cannot parse"
}

cmd_events() {
  local lane="${1:-}"; shift || true
  local lines=40 json=0
  while [[ $# -gt 0 ]]; do
    case "$1" in --lines) lines="${2:-}"; shift 2 ;; --json) json=1; shift ;; *) die "events: unknown option '$1'" ;; esac
  done
  [[ -n "$lane" ]] || die "events: <lane> required"
  [[ "$lines" =~ ^[0-9]+$ && "$lines" -gt 0 ]] || die "events: --lines must be a positive integer"
  lane_exists "$lane" || die "events: no such lane '$lane'"
  load_event_reader
  local provider; provider="$(lane_get "$lane" provider)"; load_provider "$provider"
  local tail; tail="$(provider_event_tail "$lane" "$lines")"
  if [[ "$json" -eq 1 ]]; then printf '%s\n' "$tail"; else jq -r '.events[] | [(.event_time // ""), .event_type, (if .turn_completed_mark then "turn-complete" elif .turn_started_mark then "turn-started" else "" end)] | @tsv' <<<"$tail"; fi
}

cmd_inspect() {
  local lane="" json=0
  while [[ $# -gt 0 ]]; do case "$1" in --json) json=1; shift ;; -*) die "inspect: unknown option '$1'" ;; *) [[ -z "$lane" ]] && { lane="$1"; shift; } || die "inspect: one lane at a time; use inspect --json for fleet output" ;; esac; done
  if [[ -n "$lane" ]]; then lane_exists "$lane" || die "inspect: no such lane '$lane'"; load_event_reader; lane_inspection_json "$lane"; return 0; fi
  [[ "$json" -eq 1 ]] || die "inspect: fleet inspection requires --json"
  load_event_reader
  local rows=() l
  while IFS= read -r l; do [[ -n "$l" ]] && rows+=("$(lane_inspection_json "$l")"); done < <(list_lanes)
  [[ ${#rows[@]} -eq 0 ]] && echo '[]' || printf '%s\n' "${rows[@]}" | jq -cs .
}

cmd_accept_runtime() {
  local lane="${1:-}"; shift || true
  local reason=""
  while [[ $# -gt 0 ]]; do
    case "$1" in --reason) reason="${2:-}"; shift 2 ;; *) die "accept-runtime: expected --reason TEXT" ;; esac
  done
  [[ -n "$lane" && -n "$reason" ]] || die "accept-runtime: <lane> and --reason TEXT are required"
  lane_exists "$lane" || die "no such lane '$lane'"
  [[ "$(lane_get "$lane" provider)" == codex ]] || die "accept-runtime: runtime receipts currently exist only for Codex"
  load_provider codex
  codex_refresh_runtime_settings "$lane"
  [[ "$(lane_get "$lane" runtime_settings_match_requested)" == false ]] || die "accept-runtime: lane '$lane' has no observed runtime mismatch to accept"
  lane_set "$lane" runtime_settings_accepted_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    runtime_settings_accepted_reason "$reason" \
    runtime_settings_accepted_observed_at "$(lane_get "$lane" runtime_settings_observed_at)"
  log "accept-runtime: accepted observed Codex runtime drift for lane '$lane' at $(lane_get "$lane" runtime_settings_observed_at)"
}

cmd_peek() {
  local lane="${1:-}" lines=40 events=0; shift || true
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --lines) lines="${2:-}"; shift 2 ;;
      --events) events=1; shift ;;
      -*) die "peek: unknown option '$1'" ;;
      *) shift ;;
    esac
  done
  [[ -n "$lane" ]] || die "peek: <lane> required"
  [[ "$lines" =~ ^[0-9]+$ ]] || die "peek: --lines must be a positive integer (got: $lines)"
  lane_exists "$lane" || die "peek: no such lane '$lane'"
  if [[ "$events" -eq 1 ]]; then cmd_events "$lane" --lines "$lines"; return 0; fi
  if tmux_window_exists "$lane"; then
    tmux capture-pane -p -t "$(tmux_window_target "$lane")" -S -"$lines" 2>/dev/null \
      | strip_ansi | grep -v '^$' | tail -"$lines"
  else
    local t; t="$(lane_get "$lane" transcript)"
    [[ -f "$t" ]] || die "peek: lane '$lane' has no live window and no transcript yet"
    strip_ansi <"$t" | grep -v '^$' | tail -"$lines"
  fi
}

cmd_wait() {
  local lane="${1:-}" timeout=600 interval=2 reap_after_idle=0; shift || true
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --timeout) timeout="${2:-}"; shift 2 ;;
      --interval) interval="${2:-}"; shift 2 ;;
      --reap) reap_after_idle=1; shift ;;
      -*) die "wait: unknown option '$1'" ;;
      *) shift ;;
    esac
  done
  [[ -n "$lane" ]] || die "wait: <lane> required"
  [[ "$timeout" =~ ^[0-9]+$ && "$timeout" -gt 0 ]] || die "wait: --timeout must be a positive integer (got: $timeout)"
  [[ "$interval" =~ ^[0-9]+$ && "$interval" -gt 0 ]] || die "wait: --interval must be a positive integer (got: $interval)"
  lane_exists "$lane" || die "no such lane '$lane'"
  [[ "$(lane_get "$lane" status)" != escalating ]] || die "wait: escalation in progress for lane '$lane'"
  local provider; provider="$(lane_get "$lane" provider)"
  load_provider "$provider"
  require_cmd jq

  # Stale-idle barrier. A live `revise` starts a new turn asynchronously; the
  # provider's idle predicate reads the LAST terminal event, which — in the window
  # right after revise — is still the PRIOR turn's end_turn/task_complete. So a
  # bare `revise x; wait` would return instantly on the previous turn's idle and
  # silently drop the steering instruction.
  #
  # Barrier signal: revise records revise_barrier_mark = the provider's completed-
  # turn mark at revise time. wait honors idle only once that mark advances, so a
  # prior terminal event cannot satisfy a new live revise. This keys on the
  # provider session log, not the pane transcript. If the revised turn completes
  # before wait is called, the mark is already past the barrier and it clears on
  # the first poll. A queued user message alone must not clear this barrier.
  local barrier_mark
  barrier_mark="$(lane_get "$lane" revise_barrier_mark)"
  local barrier_cleared=0
  [[ -n "$barrier_mark" ]] || barrier_cleared=1

  # Mid-run interactive-prompt (stall) detection. A worker can BLOCK mid-turn on a
  # prompt that expects a human keystroke (quota/model-downgrade offer, security
  # wait, y/n). It never reaches idle, so plain `wait` would stall blind until
  # timeout. We watch the lane transcript for activity: if it stops growing for
  # WASPFLOW_STALL_SECONDS *and* the pane looks blocked, return a distinct
  # 'blocked' state (rc 4) with the pane text — so the orchestrator answers via
  # `revise` in seconds instead of losing the whole timeout. We never auto-answer.
  local stall_secs; stall_secs="$(numeric_knob WASPFLOW_STALL_SECONDS 45)"
  local transcript; transcript="$(lane_transcript "$lane")"
  local last_size; last_size="$(wc -c <"$transcript" 2>/dev/null || echo 0)"
  local last_change; last_change="$(date +%s)"

  local deadline=$(( $(date +%s) + timeout ))
  while :; do
    # A successful handoff can replace provider/session while wait is polling.
    # Never keep a stale adapter or session snapshot across iterations.
    [[ "$(lane_get "$lane" status)" != escalating ]] \
      || die "wait: escalation in progress for lane '$lane'"
    provider="$(lane_get "$lane" provider)"
    load_provider "$provider"
    if [[ "$barrier_cleared" -eq 0 ]]; then
      local cur_mark; cur_mark="$("${provider}_turn_mark" "$lane" 2>/dev/null || echo 0)"
      if [[ "${cur_mark:-0}" -gt "$barrier_mark" ]]; then
        # New turn appended a session event past the revise mark — barrier satisfied.
        barrier_cleared=1
        lane_set "$lane" revise_barrier_mark ""
      fi
    fi
    if [[ "$barrier_cleared" -eq 1 ]] && "${provider}_is_idle" "$lane"; then
      # Capture the change so far (cheap, idempotent). Deliverable enforcement +
      # the honest result happen at reap (the explicit end-of-run), so an
      # intermediate idle between revise turns doesn't trigger premature recovery.
      artifacts_capture_after "$lane"
      log "wait: lane '$lane' is IDLE"
      # Preserve wait's timeout/stall semantics: cleanup is reached only through
      # the verified-idle path above. Its final result/rc belongs to reap, so a
      # blocking harness receives the same result it would get from a separate
      # `wait && reap` sequence.
      if [[ "$reap_after_idle" -eq 1 ]]; then
        local reap_rc=0
        _wait_reap_after_idle "$lane" || reap_rc=$?
        # A revise may have won the operation lock after the outer idle read.
        # Re-enter the wait loop until the new turn reaches a fresh terminal
        # event; never convert stale idle into destructive cleanup.
        [[ "$reap_rc" -eq 5 ]] && continue
        return "$reap_rc"
      fi
      return 0
    fi
    # --- stall check ---
    # The ROBUST signal is STALL itself, not prompt wording: the worker produced no
    # output for stall_secs while its turn hasn't ended. Whatever the cause — an
    # interactive prompt awaiting input, a hung backend, a network wait — the right
    # action is the SAME: stop waiting blind, surface it, let the orchestrator peek
    # and decide. We do NOT gate on matching the prompt text (that's brittle: it
    # breaks the moment a provider rephrases or a new prompt type appears). Prompt
    # matching is only an optional HINT in the message, never the trigger.
    local now cur_size; now="$(date +%s)"
    cur_size="$(wc -c <"$transcript" 2>/dev/null || echo 0)"
    if [[ "$cur_size" != "$last_size" ]]; then
      last_size="$cur_size"; last_change="$now"      # activity → reset the stall clock
    elif [[ $(( now - last_change )) -ge "$stall_secs" ]]; then
      local pane hint=""
      pane="$(tmux capture-pane -p -t "$(tmux_window_target "$lane")" -S -40 2>/dev/null | strip_ansi)"
      hint="$(wf_pane_looks_blocked "$pane" || true)"   # optional: names a likely prompt shape
      lane_set "$lane" wait_state "stalled" stalled_after "$stall_secs" \
        blocked_hint "${hint:-unknown (no output; could be a prompt, a hang, or a slow tool)}"
      warn "wait: lane '$lane' STALLED — no output for ${stall_secs}s and turn not ended${hint:+ (looks like: $hint)}"
      warn "  the worker may be waiting on an interactive prompt (e.g. a quota/model-downgrade"
      warn "  offer or a security check) or genuinely hung. waspflow never auto-answers. Inspect:"
      warn "    waspflow peek $lane            # see exactly what it's waiting on"
      warn "    waspflow revise $lane -- \"<answer>\"   # answer a prompt (e.g. 1 / yes / no) — YOUR call"
      warn "  or raise --interval/WASPFLOW_STALL_SECONDS if this turn is just slow."
      return 4
    fi
    if [[ "$now" -ge "$deadline" ]]; then
      warn "wait: TIMEOUT after ${timeout}s (lane '$lane' never went idle)"
      return 1
    fi
    sleep "$interval"
  done
}

# Set PARK_REFUSAL and return nonzero unless a lane can be parked without
# guessing about terminal state or tmux ownership. This is deliberately shared
# by `park` and fleet `gc`, so their safety predicate cannot drift.
lane_is_parkable() {
  local lane="$1" adopt_legacy="${2:-0}" provider barrier mark need_adopt=0
  PARK_REFUSAL=""
  PARK_NEEDS_ADOPT=0
  if ! jq empty "$(lane_state_file "$lane")" 2>/dev/null; then
    PARK_REFUSAL="corrupt state.json"; return 1
  fi
  if [[ "$(lane_get "$lane" status)" != "live" ]]; then
    PARK_REFUSAL="lifecycle state is '$(lane_get "$lane" status)' (need live)"; return 1
  fi
  if ! tmux_owned_lane_window_exists "$lane"; then
    if [[ "$adopt_legacy" -eq 1 ]] && tmux_named_lane_window_exists "$lane"; then
      need_adopt=1
    else
      PARK_REFUSAL="no verified owned tmux window (legacy lanes require explicit --adopt-legacy)"; return 1
    fi
  fi
  provider="$(lane_get "$lane" provider)"
  if [[ -z "$provider" || ! -f "$WASPFLOW_LIB/providers/$provider.sh" ]]; then
    PARK_REFUSAL="missing provider adapter"; return 1
  fi
  load_provider "$provider"
  if ! "${provider}_session_resumable" "$lane"; then
    PARK_REFUSAL="provider session is not resumable"; return 1
  fi
  # A live revise records this barrier while the provider log still ends with
  # the prior turn. Treat it as active until the terminal mark advances.
  barrier="$(lane_get "$lane" revise_barrier_mark)"
  if [[ -n "$barrier" ]]; then
    mark="$("${provider}_turn_mark" "$lane" 2>/dev/null || echo '')"
    if [[ ! "$barrier" =~ ^[0-9]+$ || ! "$mark" =~ ^[0-9]+$ || "$mark" -le "$barrier" ]]; then
      PARK_REFUSAL="a revise turn is still pending"; return 1
    fi
  fi
  if ! "${provider}_is_idle" "$lane"; then
    PARK_REFUSAL="provider terminal oracle is not idle"; return 1
  fi
  PARK_NEEDS_ADOPT="$need_adopt"
  return 0
}

_park_one() {
  local lane="$1"
  lane_operation_run "$lane" _park_one_locked "$@"
}

_park_one_locked() {
  local lane="$1" reason="$2" adopt_legacy="${3:-0}"
  lane_is_parkable "$lane" "$adopt_legacy" || { err "park: lane '$lane' refused: $PARK_REFUSAL"; return 1; }
  if [[ "$PARK_NEEDS_ADOPT" -eq 1 ]]; then
    tmux_capture_lane_ownership "$lane" \
      || { err "park: lane '$lane' legacy ownership could not be adopted"; return 1; }
    tmux_owned_lane_window_exists "$lane" \
      || { err "park: lane '$lane' adopted ownership did not verify"; return 1; }
  fi
  tmux_kill_owned_lane_window "$lane" \
    || { err "park: lane '$lane' ownership changed before its window could be stopped"; return 1; }
  lane_set "$lane" status "parked" parked_at "$(date +%s)" park_reason "$reason"
  log "park: lane '$lane' parked — transcript, state, session, worktree, and artifacts preserved"
}

cmd_park() {
  local lane="" reason="operator requested" adopt_legacy=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --reason) [[ $# -ge 2 ]] || die "park: --reason requires text"; reason="$2"; shift 2 ;;
      --adopt-legacy) adopt_legacy=1; shift ;;
      -*) die "park: unknown option '$1'" ;;
      *) [[ -z "$lane" ]] && { lane="$1"; shift; } || die "park: unexpected arg '$1'" ;;
    esac
  done
  [[ -n "$lane" ]] || die "park: <lane> required"
  [[ -n "$reason" ]] || die "park: --reason cannot be empty"
  lane_exists "$lane" || die "park: no such lane '$lane'"
  [[ "$(lane_get "$lane" status)" != escalating ]] || die "park: escalation in progress for lane '$lane'"
  _park_one "$lane" "$reason" "$adopt_legacy"
}

cmd_gc() {
  local lane_age project="" apply=0 adopt_legacy=0; lane_age="$(numeric_knob WASPFLOW_GC_LANE_AGE_SECONDS 86400)"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --lane-age) [[ $# -ge 2 ]] || die "gc: --lane-age requires seconds"; lane_age="$2"; shift 2 ;;
      --project) [[ $# -ge 2 ]] || die "gc: --project requires a directory"; project="$2"; shift 2 ;;
      --apply) apply=1; shift ;;
      --adopt-legacy) adopt_legacy=1; shift ;;
      -*) die "gc: unknown option '$1'" ;;
      *) die "gc: unexpected arg '$1'" ;;
    esac
  done
  [[ "$lane_age" =~ ^[0-9]+$ && "$lane_age" -gt 0 ]] \
    || die "gc: --lane-age must be a positive integer seconds value (got: $lane_age)"
  if [[ -n "$project" ]]; then
    project="$(cd "$project" && pwd)" || die "gc: --project does not exist: $project"
  fi

  local mode="dry-run"; [[ "$apply" -eq 1 ]] && mode="apply"
  printf 'gc: mode=%s lane_age_seconds=%s%s\n' "$mode" "$lane_age" "${project:+ project=$project}"
  [[ "$apply" -eq 1 ]] || echo "gc: dry run only; pass --apply to park selected lanes (gc never reaps or touches worktrees/artifacts)"
  printf '%-20s %s\n' LANE LANE_AGE_SECONDS

  local now lane spawned age selected=0 parked=0 failed=0
  now="$(date +%s)"
  while IFS= read -r lane; do
    [[ -n "$lane" ]] || continue
    if ! jq empty "$(lane_state_file "$lane")" 2>/dev/null; then
      warn "gc: skipping corrupt lane '$lane'"; continue
    fi
    [[ -z "$project" ]] || lane_matches_project "$lane" "$project" || continue
    spawned="$(lane_get "$lane" spawn_epoch)"
    [[ "$spawned" =~ ^[0-9]+$ && "$spawned" -le "$now" ]] || continue
    age=$((now - spawned))
    [[ "$age" -ge "$lane_age" ]] || continue
    lane_is_parkable "$lane" "$adopt_legacy" || continue
    printf '%-20s %s\n' "$lane" "$age"
    selected=$((selected + 1))
    if [[ "$apply" -eq 1 ]]; then
      if _park_one "$lane" "gc: lane age ${age}s reached threshold ${lane_age}s" "$adopt_legacy"; then
        parked=$((parked + 1))
      else
        failed=$((failed + 1))
      fi
    fi
  done < <(list_lanes)
  [[ "$selected" -gt 0 ]] || echo "(no safely parkable terminal-idle lanes older than the lane age threshold)"
  if [[ "$apply" -eq 1 ]]; then
    log "gc: parked $parked of $selected selected lanes"
    [[ "$failed" -eq 0 ]] || { err "gc: $failed selected lane(s) could not be parked"; return 2; }
  fi
  return 0
}

_wait_reap_after_idle() {
  local lane="$1"
  lane_operation_run "$lane" _wait_reap_after_idle_locked "$lane"
}

_wait_reap_after_idle_locked() {
  local lane="$1" provider barrier mark
  provider="$(lane_get "$lane" provider)"
  load_provider "$provider"
  barrier="$(lane_get "$lane" revise_barrier_mark)"
  if [[ -n "$barrier" ]]; then
    mark="$("${provider}_turn_mark" "$lane" 2>/dev/null || echo '')"
    [[ "$barrier" =~ ^[0-9]+$ && "$mark" =~ ^[0-9]+$ && "$mark" -gt "$barrier" ]] \
      || return 5
    lane_set "$lane" revise_barrier_mark ""
  fi
  "${provider}_is_idle" "$lane" || return 5
  _reap_one_locked "$lane" 0 0 0
}

cmd_revise() {
  split_after_ddash "$@"
  local lane="" out=""
  set -- "${FLAGS[@]:-}"
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --out) out="${2:-}"; shift 2 ;;
      "") shift ;;
      *) [[ -z "$lane" ]] && { lane="$1"; shift; } || die "revise: unexpected arg '$1'" ;;
    esac
  done
  local message="${REST[*]:-}"
  [[ -n "$lane" ]] || die "revise: <lane> required"
  [[ -n "$message" ]] || die "revise: a message is required after '--'"
  lane_exists "$lane" || die "no such lane '$lane'"
  lane_operation_run "$lane" _revise_one "$lane" "$message" "$out"
}

_revise_one() {
  local lane="$1" message="$2" out="$3" report
  local transition phase
  transition="$(lane_get "$lane" pending_transition)"
  phase="$(jq -r '.phase // ""' <<<"$transition" 2>/dev/null || true)"
  if ! [[ "$(lane_get "$lane" status)" != escalating && "$phase" != receipt_committed && "$phase" != launch_provisioned && "$phase" != confirmed ]]; then
    err "revise: escalation in progress for lane '$lane' (use escalate --resume-transition or --abort-transition)"
    return 1
  fi
  local provider; provider="$(lane_get "$lane" provider)"
  report="$(lane_get "$lane" report)"
  message="$(artifacts_report_prompt "$message" "$report")"
  load_provider "$provider"
  if tmux_window_exists "$lane"; then
    log "revise: steering live pane for lane '$lane'"
    # Live steer starts a NEW turn asynchronously; record the provider completed-
    # turn mark now so a following `wait` will not honor the PRIOR turn's stale
    # idle until the new turn completes (see cmd_wait barrier).
    # Headless resume (else branch) blocks until the reply, so it needs no barrier.
    local mark
    mark="$("${provider}_turn_mark" "$lane" 2>/dev/null || echo 0)"
    lane_set "$lane" revise_barrier_mark "$mark"
  else
    log "revise: lane '$lane' window exited; resuming session headlessly"
    lane_set "$lane" surface_changed "true"
  fi
  "${provider}_revise" "$lane" "$message" "$out"
}

cmd_attach() {
  local lane="${1:-}"; [[ -n "$lane" ]] || die "attach: <lane> required"
  tmux_window_exists "$lane" || die "attach: lane '$lane' has no live window"
  log "attaching to $WASPFLOW_TMUX_SESSION:$lane (detach with Ctrl-b d)"
  tmux select-window -t "$(tmux_window_target "$lane")"
  tmux attach-session -t "$WASPFLOW_TMUX_SESSION"
}

cmd_reap() {
  local lane="" force=0 keep_wt=0 no_archive=0 status_filter=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force=1; shift ;;
      --keep-worktree) keep_wt=1; shift ;;
      --no-archive) no_archive=1; shift ;;
      --status) status_filter="${2:-}"; shift 2 ;;   # batch: reap the reap-safe set
      -*) die "reap: unknown option '$1'" ;;
      "") shift ;;
      *) [[ -z "$lane" ]] && { lane="$1"; shift; } || die "reap: unexpected arg '$1'" ;;
    esac
  done

  # Batch mode: reap every lane whose fan-in outcome matches the filter. This is
  # the one-command fan-in cleanup — `reap --status harvested,superseded,abandoned`.
  if [[ -n "$status_filter" ]]; then
    [[ -z "$lane" ]] || die "reap: give a <lane> OR --status, not both"
    local rc=0 any=0 l
    while IFS= read -r l; do
      [[ -n "$l" ]] || continue
      [[ "$(lane_get "$l" status)" == "reaped" ]] && continue   # already reaped
      fanin_outcome_matches "$l" "$status_filter" || continue
      any=1
      _reap_one "$l" "$force" "$keep_wt" "$no_archive" || rc=$?
    done < <(list_lanes)
    [[ "$any" -eq 1 ]] || log "reap: no lanes with outcome in: $status_filter"
    return "$rc"
  fi

  [[ -n "$lane" ]] || die "reap: <lane> required (or --status S,... for batch)"
  lane_exists "$lane" || die "no such lane '$lane'"
  _reap_one "$lane" "$force" "$keep_wt" "$no_archive"
}

# Run a configured verification contract while preserving the lane's lifecycle:
# no provider/tmux interaction, no result promotion, no worktree cleanup. The
# operation lock only prevents a concurrent reap from deleting the cwd while the
# command runs; it does not imply that the lane itself is stopped.
cmd_verify() {
  local lane="" json=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json=true; shift ;;
      -*) die "verify: unknown option '$1'" ;;
      *)
        [[ -z "$lane" ]] || die "verify: unexpected argument '$1'"
        lane="$1"; shift
        ;;
    esac
  done
  [[ -n "$lane" ]] || die "verify: <lane> required"
  lane_exists "$lane" || die "verify: no such lane '$lane'"
  [[ -n "$(lane_get "$lane" verify_command)" ]] \
    || die "verify: lane '$lane' has no --verify contract"
  lane_operation_run "$lane" _verify_one "$lane" "$json"
}

_verify_one() {
  local lane="$1" json="${2:-false}" verify_state failure baseline
  verify_state="$(artifacts_run_verify_checkpoint "$lane" checkpoint)"
  [[ "$verify_state" == passed ]] || artifacts_classify_pre_existing "$lane"
  failure="$(lane_get "$lane" verify_failure_class)"
  baseline="$(lane_get "$lane" baseline_oracle_state)"
  case "$verify_state" in
    passed)
      if [[ "$json" == true ]]; then
        jq -cn --arg lane "$lane" '{ok:true,state:"passed",failure_class:"none",suggested_argv:[]}'
      else
        log "verify: lane '$lane' checkpoint passed"
      fi
      return 0
      ;;
    *)
      if [[ "$failure" == task ]]; then escalate_proposal_for_lane "$lane"; fi
      if [[ "$json" == true ]]; then
        jq -cn --arg state "$verify_state" --arg failure "$failure" --arg baseline "$baseline" --arg lane "$lane" --argjson suggested "$(printf '%s\n' "${ESCALATE_PROPOSAL_COMMANDS[@]:-}" | jq -Rsc 'split("\n") | map(select(length > 0))')" '
          {ok:false,state:$state,failure_class:$failure,
           attribution_warning:(if $failure == "task" and ($baseline == "skipped" or $baseline == "inconclusive") then "baseline unverified — failure may predate the worker" else "" end),
           suggested_argv:(if $failure == "task" then $suggested else [] end)}'
      else
        err "verify: lane '$lane' checkpoint failed (${verify_state}; class=$failure)"
        if [[ "$failure" == task && "$baseline" != skipped && "$baseline" != inconclusive ]]; then
          err "  ${ESCALATE_PROPOSAL_LINE:-next: waspflow escalate $lane}"
        elif [[ "$failure" == task ]]; then
          warn "verify: baseline unverified — failure may predate the worker"
          err "  ${ESCALATE_PROPOSAL_LINE:-next: waspflow escalate $lane}"
        fi
      fi
      return 2
      ;;
  esac
}

# Reap a single lane. Args: lane force keep_wt no_archive. Returns 2 on an unmet
# deliverable/verification contract so callers/CI can key on it.
_reap_one() {
  local lane="$1"
  lane_operation_run "$lane" _reap_one_locked "$@"
}

_reap_one_locked() {
  local lane="$1" force="$2" keep_wt="$3" no_archive="$4"
  if [[ "$(lane_get "$lane" status)" == escalating ]] || escalate_transition_requires_resolution "$lane"; then
    err "reap: escalation transition must be resumed or aborted for lane '$lane'"
    err "  next: waspflow escalate $lane --resume-transition"
    err "  next: waspflow escalate $lane --abort-transition"
    return 1
  fi
  local provider; provider="$(lane_get "$lane" provider)"
  load_provider "$provider"

  provider_refresh_runtime_settings "$lane"
  if [[ "$provider" == codex && "$(lane_get "$lane" runtime_receipt_enforced)" == true ]]; then
    local runtime_health runtime_match runtime_at accepted_at
    runtime_health="$(lane_get "$lane" runtime_refresh_state)"
    runtime_match="$(lane_get "$lane" runtime_settings_match_requested)"
    runtime_at="$(lane_get "$lane" runtime_settings_observed_at)"
    accepted_at="$(lane_get "$lane" runtime_settings_accepted_observed_at)"
    if [[ "$runtime_health" != observed ]] || \
       { [[ "$runtime_match" != true ]] && [[ "$runtime_match" != false || "$accepted_at" != "$runtime_at" ]]; }; then
      artifacts_capture_after "$lane"
      lane_set "$lane" result "runtime_unverified" runtime_verification_state "${runtime_health:-unknown}:${runtime_match:-unknown}"
      err "reap: lane '$lane' has no current verified Codex runtime receipt (refresh=${runtime_health:-unknown}, match=${runtime_match:-unknown}); inspect status or accept-runtime after reviewing an observed drift"
      return 2
    fi
  fi
  if [[ "$(lane_get "$lane" runtime_settings_match_requested)" == false ]] && \
     [[ "$(lane_get "$lane" runtime_settings_accepted_observed_at)" != "$(lane_get "$lane" runtime_settings_observed_at)" ]]; then
    artifacts_capture_after "$lane"
    lane_set "$lane" result "runtime_drift" runtime_verification_state mismatch
    err "reap: lane '$lane' has explicit requested/runtime model or effort drift; inspect status or run accept-runtime $lane --reason TEXT"
    return 2
  fi

  # Finalize FIRST (before killing the window or removing the worktree): capture
  # the diff, enforce any --report contract, and — if the report is missing —
  # run one recovery pass. Recovery may resume the live pane OR the exited
  # session, and needs the worktree intact to read the diff + write the report.
  local result; result="$(artifacts_finalize "$lane" "$provider")"
  result="$(artifacts_verify "$lane" "$result")"
  artifacts_emit_receipt_v1 "$lane" "$result" || warn "reap: could not emit receipt for lane '$lane'"

  if tmux_window_exists "$lane"; then
    tmux kill-window -t "$(tmux_window_target "$lane")" 2>/dev/null || true
  fi
  # Scope receipts are intentionally reaped only after finalization: report
  # recovery may have started a new headless scope after the pane exited.
  tmux_kill_owned_lane_scopes "$lane"

  # Bundle-before-reap: archive the branch tip to a verified git bundle BEFORE
  # removing the worktree/branch, so "reaping is cleanup, not data loss" holds
  # even for unpushed branches. --no-archive opts out for the truly disposable.
  [[ "$no_archive" -eq 1 ]] || fanin_bundle_lane "$lane" || true

  local wt; wt="$(lane_get "$lane" worktree)"
  if [[ -n "$wt" && "$keep_wt" -ne 1 ]]; then
    local repo_root; repo_root="$(lane_get "$lane" repo_root)"
    if worktree_remove "$lane" "$wt" "$repo_root" "$force"; then
      log "reap: removed worktree $wt"
    fi
  fi

  lane_set "$lane" status "reaped"
  case "$result" in
    succeeded)       log "reap: lane '$lane' reaped — result=succeeded" ;;
    verified)        log "reap: lane '$lane' reaped — result=verified" ;;
    recovered)       warn "reap: lane '$lane' reaped — result=recovered (report rebuilt by recovery pass)" ;;
    verify_failed)   err  "reap: lane '$lane' reaped — result=verify_failed" ;;
    report_missing)  err  "reap: lane '$lane' reaped — result=report_missing (recovery disabled)" ;;
    failed)          err  "reap: lane '$lane' reaped — result=failed (required report never produced)" ;;
    abandoned)       warn "reap: lane '$lane' reaped — result=abandoned (closed out via 'close --status $(lane_outcome "$lane")'; deliverable not judged, no recovery run)" ;;
    runtime_drift)   err  "reap: lane '$lane' reaped — result=runtime_drift" ;;
    runtime_unverified) err "reap: lane '$lane' reaped — result=runtime_unverified" ;;
    corrupt_result)  err  "reap: lane '$lane' — state has an unrecognized result value (not laundered to success); inspect state.json" ;;
    *)               log "reap: lane '$lane' reaped" ;;
  esac
  case "$result" in failed|report_missing|verify_failed|runtime_drift|runtime_unverified|corrupt_result) return 2 ;; esac
  return 0
}

# Guided Federation v0 CLI: `waspflow federation {join,contribute,submit,status,trust}`.
# A thin passthrough to bin/waspflow-federation (Node) — see that file's own
# module doc for why: every verb there either calls straight into the
# existing federation libs or shells out to the existing, already-tested
# bin/waspflow-federation-{submit,pull} bins, so this dispatcher deliberately
# adds no logic of its own beyond finding node and the sibling script.
cmd_federation() {
  require_cmd node
  node "$WASPFLOW_BIN_DIR/waspflow-federation" "$@"
}

cmd_doctor() {
  echo "waspflow doctor"
  echo "  WASPFLOW_HOME = $WASPFLOW_HOME"
  echo "  tmux session  = $WASPFLOW_TMUX_SESSION"
  local ok=1
  local agent_ok=0
  for c in tmux jq git flock; do
    if command -v "$c" >/dev/null 2>&1; then echo "  [ok]   $c"; else echo "  [MISS] $c (required)"; ok=0; fi
  done
  command -v curl >/dev/null 2>&1 || ok=0
  command -v uuidgen >/dev/null 2>&1 || [[ -r /proc/sys/kernel/random/uuid ]] || ok=0
  for c in claude codex grok curl uuidgen; do
    if command -v "$c" >/dev/null 2>&1; then
      echo "  [ok]   $c"
      [[ "$c" == "claude" || "$c" == "codex" || "$c" == "grok" ]] && agent_ok=1
    elif [[ "$c" == "curl" || "$c" == "uuidgen" ]]; then
      echo "  [MISS] $c (required on systems without an equivalent)"
    else
      echo "  [warn] $c (install at least one agent CLI)"
    fi
  done
  if ! command -v uuidgen >/dev/null 2>&1 && [[ -r /proc/sys/kernel/random/uuid ]]; then
    echo "  [ok]   /proc/sys/kernel/random/uuid"
  fi
  # Codex backend
  local url="$WASPFLOW_CODEX_BACKEND_HEALTH_URL"
  if [[ -n "$url" ]] && command -v curl >/dev/null 2>&1; then
    local code; code="$(curl -s -o /dev/null -w '%{http_code}' --max-time 4 "$url" 2>/dev/null || echo 000)"
    if [[ "$code" == "200" ]]; then echo "  [ok]   codex model proxy $url"; else
      echo "  [warn] codex model proxy $url -> $code (start your Codex proxy, or unset WASPFLOW_CODEX_BACKEND_HEALTH_URL)"; fi
  fi
  billing_report_auth
  # Federation Preview (Docker Sandboxes backend) is optional: sbx absence
  # never counts against `ok` or the "missing prerequisites" verdict below.
  if [[ -x "$WASPFLOW_ROOT/bin/federation-detect-sbx" ]]; then
    if command -v sbx >/dev/null 2>&1; then
      local sbx_line sbx_extra
      sbx_line="$("$WASPFLOW_ROOT/bin/federation-detect-sbx" 2>/dev/null | sed 's/^federation-detect-sbx: //')"
      sbx_extra="$("$WASPFLOW_ROOT/bin/federation-detect-sbx" 2>&1 >/dev/null | sed 's/^federation-detect-sbx: /  [warn] sbx: /')"
      echo "  [ok]   $sbx_line"
      [[ -n "$sbx_extra" ]] && echo "$sbx_extra"
    else
      echo "  [warn] sbx not found — Federation Preview unavailable; see README.md \"Install sbx (Docker Sandboxes)\" or run bin/federation-install-sbx"
    fi
  fi
  if command -v clawmeter >/dev/null 2>&1; then
    local quota_check
    quota_check="$(quota_observation_v1 codex)"
    if [[ "$(jq -r '.state' <<<"$quota_check")" == absent ]]; then
      echo "  [warn] clawmeter codex envelope: $(jq -r '.reason' <<<"$quota_check")"
    else
      echo "  [ok]   clawmeter codex envelope shape"
    fi
  fi
  # Policy edges rot by design (they are dated judgments); surface staleness
  # here rather than letting an old edge decay into a silent deny-list entry.
  if ops_load 2>/dev/null; then
    local edge_warnings
    edge_warnings="$(selection_edge_staleness_report "$OPS_POLICY_JSON" \
      "${MINNOWS_DATA_HOME:-${XDG_DATA_HOME:-$HOME/.local/share}/minnows-data}/model-catalog/models.json")"
    if [[ -n "$edge_warnings" ]]; then printf '%s\n' "$edge_warnings"
    elif jq -e '(.preferred_over // []) | length > 0' <<<"$OPS_POLICY_JSON" >/dev/null 2>&1; then
      echo "  [ok]   policy preferred_over edges current vs catalog"
    fi
  fi
  [[ "$agent_ok" -eq 1 ]] || ok=0
  [[ "$ok" -eq 1 ]] || {
    echo "  -> missing prerequisites"
    echo "     see: $WASPFLOW_ROOT/docs/prerequisites.md"
    return 1
  }
  echo "  -> ready"
}

# ============================================================================
main() {
  local verb="${1:-}"; shift || true
  case "$verb" in
    spawn)  cmd_spawn "$@" ;;
    exec)   cmd_exec "$@" ;;
    ops)    cmd_ops "$@" ;;
    init)   cmd_init "$@" ;;
    demo)   cmd_demo "$@" ;;
    list|ls) cmd_list "$@" ;;
    receipts) cmd_receipts "$@" ;;
    status) cmd_status "$@" ;;
    events) cmd_events "$@" ;;
    inspect) cmd_inspect "$@" ;;
    peek)   cmd_peek "$@" ;;
    wait)   cmd_wait "$@" ;;
    park)   cmd_park "$@" ;;
    gc)     cmd_gc "$@" ;;
    revise) cmd_revise "$@" ;;
    accept-runtime) cmd_accept_runtime "$@" ;;
    attach) cmd_attach "$@" ;;
    close)  cmd_close "$@" ;;
    captured) cmd_captured "$@" ;;
    verify) cmd_verify "$@" ;;
    escalate) cmd_escalate "$@" ;;
    reap)   cmd_reap "$@" ;;
    check)  cmd_check "$@" ;;
    doctor) cmd_doctor "$@" ;;
    federation) cmd_federation "$@" ;;
    -h|--help|help|"") usage ;;
    *) die "unknown command '$verb' (try: waspflow help)" ;;
  esac
}
main "$@"
