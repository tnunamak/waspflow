#!/usr/bin/env bash
#
# waspflow — turnkey live orchestration of Claude/Codex agents in tmux.
#
# An orchestrating session (itself Claude or Codex, in ANY project dir) uses
# this to spawn an agent of either provider into a tmux window, watch it stream,
# steer/revise it live or after teardown, wait for it to go idle, and reap it —
# all surviving the orchestrator's own compaction (the windows + lane state
# persist on disk).
#
# Verbs:
#   spawn   --provider <claude|codex> --lane <name> [opts] -- <task prompt>
#   exec    --provider <claude|codex> [opts] [-o FILE] -- <task prompt>
#   init    [--profile NAME] [--cwd DIR] [--force] [--print]  write project config
#   demo    --provider <claude|codex> [--run]                 guided first lane
#   list    [--status S,...]              show all lanes + status/outcome
#   status  <lane>                        one lane's state (json)
#   peek    <lane> [--lines N]            de-escaped tail of the live pane
#   wait    <lane> [--timeout S] [--interval S]   block until idle
#   revise  <lane> [--out FILE] -- <message>      steer live, or resume if exited
#   attach  <lane>                        attach your terminal to the pane
#   close   <lane> --status <...> [--into|--by|--reason ...]  set fan-in outcome
#   captured <lane> --in <ref>            is lane's work in <ref>? (by content)
#   reap    <lane|--status S,...> [--force] [--keep-worktree] [--no-archive]
#   check   [--cwd DIR] [--config FILE] [--no-fail] project integrity gate
#   doctor                                check deps + backends
#
# State:    $WASPFLOW_HOME (default ~/.local/state/waspflow)
# tmux:     all windows live in session "$WASPFLOW_TMUX_SESSION" (default waspflow)

set -euo pipefail

# ---- locate the engine ------------------------------------------------------
# Resolve symlinks so `waspflow` works when symlinked onto PATH.
_self="${BASH_SOURCE[0]}"
while [[ -h "$_self" ]]; do
  _dir="$(cd "$(dirname "$_self")" && pwd)"
  _self="$(readlink "$_self")"
  [[ "$_self" != /* ]] && _self="$_dir/$_self"
done
WASPFLOW_BIN_DIR="$(cd "$(dirname "$_self")" && pwd)"
WASPFLOW_ROOT="$(cd "$WASPFLOW_BIN_DIR/.." && pwd)"
WASPFLOW_LIB="$WASPFLOW_ROOT/lib"
export WASPFLOW_ROOT WASPFLOW_LIB

# shellcheck disable=SC1090
source "$WASPFLOW_LIB/core.sh"
# shellcheck disable=SC1090
source "$WASPFLOW_LIB/exec.sh"
# shellcheck disable=SC1090
source "$WASPFLOW_LIB/worktree.sh"
# shellcheck disable=SC1090
source "$WASPFLOW_LIB/artifacts.sh"
# shellcheck disable=SC1090
source "$WASPFLOW_LIB/fanin.sh"
# shellcheck disable=SC1090
source "$WASPFLOW_LIB/project.sh"

usage() {
  cat <<EOF
waspflow — turnkey live orchestration of Claude/Codex agents in tmux.

First successful run:
  waspflow doctor
  waspflow demo --provider codex
  waspflow demo --provider codex --run

Verbs:
  spawn   --provider <claude|codex> --lane <name> [opts] -- <task prompt>
  exec    --provider <claude|codex> [--model M] [--effort L] [--cwd DIR] [-o FILE] -- <task prompt>
  init    [--profile NAME] [--cwd DIR] [--force] [--print]  write project config
  demo    --provider <claude|codex> [--run]                 guided first lane
  list    [--status S,...]              show all lanes (filter by fan-in outcome)
  status  <lane>                        one lane's state (json)
  peek    <lane> [--lines N]            de-escaped tail of the live pane
  wait    <lane> [--timeout S] [--interval S]   block until idle
  revise  <lane> [--out FILE] -- <message>      steer live, or resume if exited
  attach  <lane>                        attach your terminal to the pane
  close   <lane> --status <harvested|superseded|abandoned|open> [prov]  fan-in outcome
  captured <lane> --in <ref>            is lane's work already in <ref>? (by content)
  reap    <lane|--status S,...> [--force] [--keep-worktree] [--no-archive]  clean up
  check   [--cwd DIR] [--config FILE] [--no-fail] [--explain] project integrity gate
  doctor                                check deps + backends

Fan-in (docs/lane-closeout-and-fan-in.md):
  close   <lane> --status harvested  --into <pr#|ref>   # work landed here
  close   <lane> --status superseded --by   <lane|ref>  # a better version won
  close   <lane> --status abandoned  --reason "..."     # dead end, dropped
  list    --status harvested,superseded,abandoned        # the reap-safe set
  reap    --status harvested,superseded,abandoned        # fan-in cleanup, one command

Spawn opts:
  --model <id>       provider model override
  --effort <level>   low|medium|high|xhigh|max
  --cwd <dir>        worker cwd (default: current dir)
  --isolate          create an isolated git worktree
  --report <path>    require a deliverable report at reap
  --arg <flag>       pass an extra arg to the provider CLI

Exec opts:
  --model <id>       provider model override
  --effort <level>   low|medium|high|xhigh|max
  --cwd <dir>        worker cwd (default: current dir)
  -o <file>          write final message to file (default: stdout)

State: $WASPFLOW_HOME (default ~/.local/state/waspflow)
tmux:  $WASPFLOW_TMUX_SESSION (default waspflow)
EOF
}

# ---- arg splitting ----------------------------------------------------------
# Split argv at the first literal `--` into FLAGS (before) and REST (after).
# REST is the free-text prompt/message so it never needs quoting gymnastics.
split_after_ddash() {
  FLAGS=(); REST=()
  local seen=0
  for a in "$@"; do
    if [[ $seen -eq 0 && "$a" == "--" ]]; then seen=1; continue; fi
    if [[ $seen -eq 0 ]]; then FLAGS+=("$a"); else REST+=("$a"); fi
  done
}

# ============================================================================
# verbs
# ============================================================================

cmd_spawn() {
  local provider="" lane="" model="" cwd="$PWD" isolate=0 effort="" report="" no_recovery=0
  local -a extra=()
  split_after_ddash "$@"
  set -- "${FLAGS[@]:-}"
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --provider) provider="${2:-}"; shift 2 ;;
      --lane)     lane="${2:-}"; shift 2 ;;
      --model)    model="${2:-}"; shift 2 ;;
      --effort)   effort="${2:-}"; shift 2 ;;
      --cwd)      cwd="${2:-}"; shift 2 ;;
      --isolate|--worktree) isolate=1; shift ;;
      --report)   report="${2:-}"; shift 2 ;;     # opt-in deliverable contract
      --no-recovery) no_recovery=1; shift ;;
      --arg)      extra+=("${2:-}"); shift 2 ;;   # repeatable pass-through to the agent CLI
      "")         shift ;;
      *) die "spawn: unknown option '$1'" ;;
    esac
  done
  local prompt="${REST[*]:-}"

  [[ -n "$provider" ]] || die "spawn: --provider is required (claude|codex)"
  is_known_provider "$provider" || die "spawn: unknown provider '$provider'"
  [[ -n "$lane" ]] || die "spawn: --lane is required"
  validate_lane_name "$lane"
  [[ -n "$prompt" ]] || die "spawn: a task prompt is required after '--'"
  cwd="$(cd "$cwd" && pwd)" || die "spawn: --cwd does not exist"
  if [[ -n "$effort" && ! "$effort" =~ ^(low|medium|high|xhigh|max)$ ]]; then
    die "spawn: --effort must be one of low|medium|high|xhigh|max (got: $effort)"
  fi

  if lane_exists "$lane" && [[ "$(lane_get "$lane" status)" == "live" ]]; then
    die "lane '$lane' is already live (reap it first or pick another name)"
  fi

  require_cmd tmux jq
  load_provider "$provider"
  "${provider}_preflight" || die "spawn aborted: $provider preflight failed"

  # Worktree isolation (opt-in, only inside a git repo).
  local work_cwd="$cwd" wt_path="" repo_root=""
  if [[ "$isolate" -eq 1 ]]; then
    repo_root="$(worktree_repo_root "$cwd")"
    wt_path="$(worktree_create "$lane" "$cwd")" || die "spawn: worktree isolation failed"
    work_cwd="$wt_path"
    log "isolated worktree: $wt_path"
  fi

  local session_id transcript
  session_id="$(new_uuid)"           # claude uses this; codex mints its own
  mkdir -p "$(lane_dir "$lane")"
  transcript="$(lane_transcript "$lane")"
  : >"$transcript"

  # Resolve a --report path to absolute against the worker's working dir so the
  # agent writes it where we'll look for it.
  local report_abs=""
  if [[ -n "$report" ]]; then
    case "$report" in
      /*) report_abs="$report" ;;
      *)  report_abs="$work_cwd/$report" ;;
    esac
  fi

  # Record state BEFORE spawn so a crash mid-spawn is still recoverable.
  lane_set "$lane" \
    provider "$provider" \
    status "live" \
    result "" \
    cwd "$work_cwd" \
    origin_cwd "$cwd" \
    model "$model" \
    effort "$effort" \
    session_id "$([[ "$provider" == claude ]] && echo "$session_id" || echo "")" \
    rollout "" \
    worktree "$wt_path" \
    repo_root "$repo_root" \
    transcript "$transcript" \
    report "$report_abs" \
    no_recovery "$([[ "$no_recovery" -eq 1 ]] && echo true || echo false)" \
    spawn_epoch "$(date +%s)" \
    prompt "$prompt"

  # Durable artifacts: prompt + git-status-before, automatically (no flag).
  artifacts_capture_before "$lane" "$work_cwd" "$prompt"

  "${provider}_spawn" "$lane" "$work_cwd" "$model" "$session_id" "$transcript" "$prompt" "${extra[@]}"

  log "spawned $provider lane '$lane' (tmux: $WASPFLOW_TMUX_SESSION:$lane)"
  [[ -n "$report_abs" ]] && log "  deliverable contract: $report_abs (verified on idle; one recovery pass if missing)"
  log "  peek:   waspflow peek $lane"
  log "  wait:   waspflow wait $lane"
  log "  revise: waspflow revise $lane -- \"<message>\""
  log "  reap:   waspflow reap $lane"
}

cmd_exec() {
  exec_run "$@"
}

cmd_demo() {
  local provider="" lane="" run=0 cwd="$PWD"
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --provider) provider="${2:-}"; shift 2 ;;
      --lane) lane="${2:-}"; shift 2 ;;
      --cwd) cwd="${2:-}"; shift 2 ;;
      --run) run=1; shift ;;
      -h|--help)
        cat <<'EOF'
waspflow demo --provider <claude|codex> [--run] [--lane NAME] [--cwd DIR]

Without --run, prints a safe first-run walkthrough.
With --run, performs spawn -> wait -> peek -> reap using a tiny no-edit task.
EOF
        return 0
        ;;
      *) die "demo: unknown option '$1'" ;;
    esac
  done

  if [[ -z "$provider" ]]; then
    if command -v codex >/dev/null 2>&1; then provider="codex"
    elif command -v claude >/dev/null 2>&1; then provider="claude"
    else die "demo: no provider found on PATH (install codex or claude, or pass --provider)"
    fi
  fi
  is_known_provider "$provider" || die "demo: unknown provider '$provider'"
  cwd="$(cd "$cwd" && pwd)" || die "demo: --cwd does not exist"
  lane="${lane:-demo-$(date +%s)}"
  validate_lane_name "$lane"

  local prompt="This is a waspflow first-run demo. Do not edit files. Reply with exactly one sentence that starts with 'waspflow demo ready'."
  if [[ "$run" -ne 1 ]]; then
    cat <<EOF
waspflow demo

This will prove the core loop with a no-edit task:

  waspflow spawn --provider $provider --lane $lane --cwd "$cwd" -- "$prompt"
  waspflow wait $lane --timeout 300
  waspflow peek $lane --lines 8
  waspflow reap $lane

Run it now:

  waspflow demo --provider $provider --lane $lane --cwd "$cwd" --run
EOF
    return 0
  fi

  cmd_spawn --provider "$provider" --lane "$lane" --cwd "$cwd" -- "$prompt"
  cmd_wait "$lane" --timeout 300
  cmd_peek "$lane" --lines 8
  cmd_reap "$lane"
}

cmd_list() {
  local status_filter=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --status) status_filter="${2:-}"; shift 2 ;;
      *) shift ;;
    esac
  done
  local lanes; lanes="$(list_lanes)"
  if [[ -z "$lanes" ]]; then echo "(no lanes)"; return 0; fi
  printf '%-20s %-8s %-8s %-11s %s\n' LANE PROVIDER STATE OUTCOME CWD
  local lane matched=0
  while IFS= read -r lane; do
    [[ -n "$lane" ]] || continue
    local provider status cwd live outcome
    provider="$(lane_get "$lane" provider)"
    status="$(lane_get "$lane" status)"
    cwd="$(lane_get "$lane" cwd)"
    outcome="$(lane_outcome "$lane")"
    # --status filters on the fan-in OUTCOME (the reap-safe question).
    if [[ -n "$status_filter" ]]; then
      fanin_outcome_matches "$lane" "$status_filter" || continue
    fi
    matched=1
    if tmux_window_exists "$lane"; then live="live"; else live="exited"; fi
    [[ "$status" == "reaped" ]] && live="reaped"
    printf '%-20s %-8s %-8s %-11s %s\n' "$lane" "$provider" "$live" "$outcome" "$cwd"
  done <<<"$lanes"
  [[ -n "$status_filter" && "$matched" -eq 0 ]] && echo "(no lanes with outcome in: $status_filter)"
  return 0
}

cmd_close() {
  local lane="" outcome="" pkey="" pval=""
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --status)  outcome="${2:-}"; shift 2 ;;
      --into)    pkey="into";   pval="${2:-}"; shift 2 ;;
      --by)      pkey="by";     pval="${2:-}"; shift 2 ;;
      --reason)  pkey="reason"; pval="${2:-}"; shift 2 ;;
      "")        shift ;;
      -*)        die "close: unknown option '$1'" ;;
      *)         [[ -z "$lane" ]] && { lane="$1"; shift; } || die "close: unexpected arg '$1'" ;;
    esac
  done
  [[ -n "$lane" ]]    || die "close: <lane> required"
  [[ -n "$outcome" ]] || die "close: --status <harvested|superseded|abandoned|open> required"
  fanin_close "$lane" "$outcome" "$pkey" "$pval"
}

cmd_captured() {
  local lane="" ref=""
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --in) ref="${2:-}"; shift 2 ;;
      "")   shift ;;
      -*)   die "captured: unknown option '$1'" ;;
      *)    [[ -z "$lane" ]] && { lane="$1"; shift; } || die "captured: unexpected arg '$1'" ;;
    esac
  done
  [[ -n "$lane" ]] || die "captured: <lane> required"
  [[ -n "$ref" ]]  || die "captured: --in <ref> required"
  fanin_captured "$lane" "$ref"   # prints verdict to stdout, summary to stderr
}

cmd_status() {
  local lane="${1:-}"; [[ -n "$lane" ]] || die "status: <lane> required"
  lane_exists "$lane" || die "no such lane '$lane'"
  jq . "$(lane_state_file "$lane")"
}

cmd_peek() {
  local lane="${1:-}" lines=40; shift || true
  while [[ $# -gt 0 ]]; do case "$1" in --lines) lines="${2:-40}"; shift 2 ;; *) shift ;; esac; done
  [[ -n "$lane" ]] || die "peek: <lane> required"
  if tmux_window_exists "$lane"; then
    tmux capture-pane -p -t "$(tmux_window_target "$lane")" -S -"$lines" 2>/dev/null \
      | strip_ansi | grep -v '^$' | tail -"$lines"
  else
    local t; t="$(lane_get "$lane" transcript)"
    [[ -f "$t" ]] || die "peek: lane '$lane' has no live window and no transcript"
    strip_ansi <"$t" | grep -v '^$' | tail -"$lines"
  fi
}

cmd_wait() {
  local lane="${1:-}" timeout=600 interval=2; shift || true
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --timeout) timeout="${2:-600}"; shift 2 ;;
      --interval) interval="${2:-2}"; shift 2 ;;
      *) shift ;;
    esac
  done
  [[ -n "$lane" ]] || die "wait: <lane> required"
  lane_exists "$lane" || die "no such lane '$lane'"
  local provider; provider="$(lane_get "$lane" provider)"
  load_provider "$provider"
  require_cmd jq

  local deadline=$(( $(date +%s) + timeout ))
  log "wait: lane '$lane' ($provider) timeout=${timeout}s"
  while :; do
    if "${provider}_is_idle" "$lane"; then
      # Capture the change so far (cheap, idempotent). Deliverable enforcement +
      # the honest result happen at reap (the explicit end-of-run), so an
      # intermediate idle between revise turns doesn't trigger premature recovery.
      artifacts_capture_after "$lane"
      log "wait: lane '$lane' is IDLE"
      return 0
    fi
    if [[ "$(date +%s)" -ge "$deadline" ]]; then
      warn "wait: TIMEOUT after ${timeout}s (lane '$lane' never went idle)"
      return 1
    fi
    sleep "$interval"
  done
}

cmd_revise() {
  split_after_ddash "$@"
  local lane="" out=""
  set -- "${FLAGS[@]:-}"
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --out) out="${2:-}"; shift 2 ;;
      "") shift ;;
      *) [[ -z "$lane" ]] && { lane="$1"; shift; } || die "revise: unexpected arg '$1'" ;;
    esac
  done
  local message="${REST[*]:-}"
  [[ -n "$lane" ]] || die "revise: <lane> required"
  [[ -n "$message" ]] || die "revise: a message is required after '--'"
  lane_exists "$lane" || die "no such lane '$lane'"
  local provider; provider="$(lane_get "$lane" provider)"
  load_provider "$provider"
  if tmux_window_exists "$lane"; then
    log "revise: steering live pane for lane '$lane'"
  else
    log "revise: lane '$lane' window exited; resuming session headlessly"
  fi
  "${provider}_revise" "$lane" "$message" "$out"
}

cmd_attach() {
  local lane="${1:-}"; [[ -n "$lane" ]] || die "attach: <lane> required"
  tmux_window_exists "$lane" || die "attach: lane '$lane' has no live window"
  log "attaching to $WASPFLOW_TMUX_SESSION:$lane (detach with Ctrl-b d)"
  tmux select-window -t "$(tmux_window_target "$lane")"
  tmux attach-session -t "$WASPFLOW_TMUX_SESSION"
}

cmd_reap() {
  local lane="" force=0 keep_wt=0 no_archive=0 status_filter=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force=1; shift ;;
      --keep-worktree) keep_wt=1; shift ;;
      --no-archive) no_archive=1; shift ;;
      --status) status_filter="${2:-}"; shift 2 ;;   # batch: reap the reap-safe set
      -*) die "reap: unknown option '$1'" ;;
      "") shift ;;
      *) [[ -z "$lane" ]] && { lane="$1"; shift; } || die "reap: unexpected arg '$1'" ;;
    esac
  done

  # Batch mode: reap every lane whose fan-in outcome matches the filter. This is
  # the one-command fan-in cleanup — `reap --status harvested,superseded,abandoned`.
  if [[ -n "$status_filter" ]]; then
    [[ -z "$lane" ]] || die "reap: give a <lane> OR --status, not both"
    local rc=0 any=0 l
    while IFS= read -r l; do
      [[ -n "$l" ]] || continue
      [[ "$(lane_get "$l" status)" == "reaped" ]] && continue   # already reaped
      fanin_outcome_matches "$l" "$status_filter" || continue
      any=1
      _reap_one "$l" "$force" "$keep_wt" "$no_archive" || rc=$?
    done < <(list_lanes)
    [[ "$any" -eq 1 ]] || log "reap: no lanes with outcome in: $status_filter"
    return "$rc"
  fi

  [[ -n "$lane" ]] || die "reap: <lane> required (or --status S,... for batch)"
  lane_exists "$lane" || die "no such lane '$lane'"
  _reap_one "$lane" "$force" "$keep_wt" "$no_archive"
}

# Reap a single lane. Args: lane force keep_wt no_archive. Returns 2 on an unmet
# deliverable contract (failed|report_missing) so callers/CI can key on it.
_reap_one() {
  local lane="$1" force="$2" keep_wt="$3" no_archive="$4"
  local provider; provider="$(lane_get "$lane" provider)"
  load_provider "$provider"

  # Finalize FIRST (before killing the window or removing the worktree): capture
  # the diff, enforce any --report contract, and — if the report is missing —
  # run one recovery pass. Recovery may resume the live pane OR the exited
  # session, and needs the worktree intact to read the diff + write the report.
  local result; result="$(artifacts_finalize "$lane" "$provider")"

  if tmux_window_exists "$lane"; then
    tmux kill-window -t "$(tmux_window_target "$lane")" 2>/dev/null || true
    log "reap: killed window for lane '$lane'"
  fi

  # Bundle-before-reap: archive the branch tip to a verified git bundle BEFORE
  # removing the worktree/branch, so "reaping is cleanup, not data loss" holds
  # even for unpushed branches. --no-archive opts out for the truly disposable.
  [[ "$no_archive" -eq 1 ]] || fanin_bundle_lane "$lane" || true

  local wt; wt="$(lane_get "$lane" worktree)"
  if [[ -n "$wt" && "$keep_wt" -ne 1 ]]; then
    local repo_root; repo_root="$(lane_get "$lane" repo_root)"
    if worktree_remove "$lane" "$wt" "$repo_root" "$force"; then
      log "reap: removed worktree $wt"
    fi
  fi

  lane_set "$lane" status "reaped"
  case "$result" in
    succeeded)       log "reap: lane '$lane' reaped — result=succeeded" ;;
    recovered)       warn "reap: lane '$lane' reaped — result=recovered (report rebuilt by recovery pass)" ;;
    report_missing)  err  "reap: lane '$lane' reaped — result=report_missing (recovery disabled)" ;;
    failed)          err  "reap: lane '$lane' reaped — result=failed (required report never produced)" ;;
    *)               log "reap: lane '$lane' reaped" ;;
  esac
  log "reap: state retained ($(lane_dir "$lane")); rm it to purge"
  case "$result" in failed|report_missing) return 2 ;; esac
  return 0
}

cmd_doctor() {
  echo "waspflow doctor"
  echo "  WASPFLOW_HOME = $WASPFLOW_HOME"
  echo "  tmux session  = $WASPFLOW_TMUX_SESSION"
  local ok=1
  local agent_ok=0
  for c in tmux jq git; do
    if command -v "$c" >/dev/null 2>&1; then echo "  [ok]   $c"; else echo "  [MISS] $c (required)"; ok=0; fi
  done
  command -v curl >/dev/null 2>&1 || ok=0
  command -v uuidgen >/dev/null 2>&1 || [[ -r /proc/sys/kernel/random/uuid ]] || ok=0
  for c in claude codex curl uuidgen; do
    if command -v "$c" >/dev/null 2>&1; then
      echo "  [ok]   $c"
      [[ "$c" == "claude" || "$c" == "codex" ]] && agent_ok=1
    elif [[ "$c" == "curl" || "$c" == "uuidgen" ]]; then
      echo "  [MISS] $c (required on systems without an equivalent)"
    else
      echo "  [warn] $c (install at least one agent CLI)"
    fi
  done
  if ! command -v uuidgen >/dev/null 2>&1 && [[ -r /proc/sys/kernel/random/uuid ]]; then
    echo "  [ok]   /proc/sys/kernel/random/uuid"
  fi
  # Codex backend
  local url="$WASPFLOW_CODEX_BACKEND_HEALTH_URL"
  if [[ -n "$url" ]] && command -v curl >/dev/null 2>&1; then
    local code; code="$(curl -s -o /dev/null -w '%{http_code}' --max-time 4 "$url" 2>/dev/null || echo 000)"
    if [[ "$code" == "200" ]]; then echo "  [ok]   codex model proxy $url"; else
      echo "  [warn] codex model proxy $url -> $code (start your Codex proxy, or unset WASPFLOW_CODEX_BACKEND_HEALTH_URL)"; fi
  fi
  [[ "$agent_ok" -eq 1 ]] || ok=0
  [[ "$ok" -eq 1 ]] || {
    echo "  -> missing prerequisites"
    echo "     see: $WASPFLOW_ROOT/docs/prerequisites.md"
    return 1
  }
  echo "  -> ready"
}

# ============================================================================
main() {
  local verb="${1:-}"; shift || true
  case "$verb" in
    spawn)  cmd_spawn "$@" ;;
    exec)   cmd_exec "$@" ;;
    init)   cmd_init "$@" ;;
    demo)   cmd_demo "$@" ;;
    list|ls) cmd_list "$@" ;;
    status) cmd_status "$@" ;;
    peek)   cmd_peek "$@" ;;
    wait)   cmd_wait "$@" ;;
    revise) cmd_revise "$@" ;;
    attach) cmd_attach "$@" ;;
    close)  cmd_close "$@" ;;
    captured) cmd_captured "$@" ;;
    reap)   cmd_reap "$@" ;;
    check)  cmd_check "$@" ;;
    doctor) cmd_doctor "$@" ;;
    -h|--help|help|"") usage ;;
    *) die "unknown command '$verb' (try: waspflow help)" ;;
  esac
}
main "$@"
