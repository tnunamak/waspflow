#!/usr/bin/env bash
#
# waspflow — turnkey live orchestration of Claude/Codex/Grok agents in tmux.
#
# An orchestrating session (itself Claude, Codex, or Grok, in ANY project dir)
# uses this to spawn an agent of any supported provider into a tmux window,
# watch it stream, steer/revise it live or after teardown, wait for it to go
# idle, and reap it — all surviving the orchestrator's own compaction (the
# windows + lane state persist on disk).
#
# Verbs:
#   spawn   --provider <claude|codex|grok> | --op <id> --lane <name> [opts] -- <task>
#   exec    --provider <claude|codex|grok> [opts] [-o FILE] -- <task prompt>
#   ops     list|explain|resolve|path     operating-point resolver (not a picker)
#   init    [--profile NAME] [--cwd DIR] [--force] [--print]  write project config
#   demo    --provider <claude|codex|grok> [--run]            guided first lane
#   list    [--status S,...]              show all lanes + status/outcome
#   status  <lane>                        one lane's state (json)
#   peek    <lane> [--lines N]            de-escaped tail of the live pane
#   wait    <lane> [--timeout S] [--interval S]   block until idle
#   revise  <lane> [--out FILE] -- <message>      steer live, or resume if exited
#   attach  <lane>                        attach your terminal to the pane
#   close   <lane> --status <...> [--into|--by|--reason ...]  set fan-in outcome
#   captured <lane> --in <ref>            is lane's work in <ref>? (by content)
#   reap    <lane|--status S,...> [--force] [--keep-worktree] [--no-archive]
#   check   [--cwd DIR] [--config FILE] [--no-fail] project integrity gate
#   doctor                                check deps + backends
#
# State:    $WASPFLOW_HOME (default ~/.local/state/waspflow)
# tmux:     all windows live in session "$WASPFLOW_TMUX_SESSION" (default waspflow)

set -euo pipefail

# ---- locate the engine ------------------------------------------------------
# Resolve symlinks so `waspflow` works when symlinked onto PATH.
_self="${BASH_SOURCE[0]}"
while [[ -h "$_self" ]]; do
  _dir="$(cd "$(dirname "$_self")" && pwd)"
  _self="$(readlink "$_self")"
  [[ "$_self" != /* ]] && _self="$_dir/$_self"
done
WASPFLOW_BIN_DIR="$(cd "$(dirname "$_self")" && pwd)"
WASPFLOW_ROOT="$(cd "$WASPFLOW_BIN_DIR/.." && pwd)"
# Honor a pre-set WASPFLOW_LIB (defaults to the repo lib) so tests can inject a
# lib dir with a fake provider adapter and drive the real command paths.
WASPFLOW_LIB="${WASPFLOW_LIB:-$WASPFLOW_ROOT/lib}"
export WASPFLOW_ROOT WASPFLOW_LIB

# shellcheck disable=SC1090
source "$WASPFLOW_LIB/core.sh"
# shellcheck disable=SC1090
source "$WASPFLOW_LIB/exec.sh"
# shellcheck disable=SC1090
source "$WASPFLOW_LIB/ops.sh"
# shellcheck disable=SC1090
source "$WASPFLOW_LIB/worktree.sh"
# shellcheck disable=SC1090
source "$WASPFLOW_LIB/artifacts.sh"
# shellcheck disable=SC1090
source "$WASPFLOW_LIB/fanin.sh"
# shellcheck disable=SC1090
source "$WASPFLOW_LIB/project.sh"

usage() {
  cat <<EOF
waspflow — turnkey live orchestration of Claude/Codex/Grok agents in tmux.

First successful run:
  waspflow doctor
  waspflow demo --provider codex
  waspflow demo --provider codex --run

Verbs:
  spawn   --provider <claude|codex|grok> | --op <id> --lane <name> [opts] -- <task>
  exec    --provider <claude|codex|grok> [--model M] [--effort L] [--cwd DIR] [-o FILE] -- <task prompt>
  ops     list|explain|resolve|path     operating-point resolver (decision cards)
  init    [--profile NAME] [--cwd DIR] [--force] [--print]  write project config
  demo    --provider <claude|codex|grok> [--run]            guided first lane
  list    [--status S,...]              show all lanes (filter by fan-in outcome)
  status  <lane>                        one lane's state (json)
  peek    <lane> [--lines N]            de-escaped tail of the live pane
  wait    <lane> [--timeout S] [--interval S]   block until idle
  revise  <lane> [--out FILE] -- <message>      steer live, or resume if exited
  attach  <lane>                        attach your terminal to the pane
  close   <lane> --status <harvested|superseded|abandoned|open> [prov]  fan-in outcome
  captured <lane> --in <ref>            is lane's work already in <ref>? (by content)
  reap    <lane|--status S,...> [--force] [--keep-worktree] [--no-archive]  clean up
  check   [--cwd DIR] [--config FILE] [--no-fail] [--explain] project integrity gate
  doctor                                check deps + backends

Operating points (not cheap/default/max profiles):
  waspflow ops list --task implementation
  waspflow ops explain implement.standard
  waspflow ops resolve review.audit --json
  waspflow spawn --op implement.standard --lane fix -- "…"
  # explicit flags always win over --op expansion

Fan-in (docs/lane-closeout-and-fan-in.md):
  close   <lane> --status harvested  --into <pr#|ref>   # work landed here
  close   <lane> --status superseded --by   <lane|ref>  # a better version won
  close   <lane> --status abandoned  --reason "..."     # dead end, dropped
  list    --status harvested,superseded,abandoned        # the reap-safe set
  reap    --status harvested,superseded,abandoned        # fan-in cleanup, one command

Spawn opts:
  --op <id>          expand a task-shaped operating point (see ops list)
  --model <id>       provider model override
  --effort <level>   none|minimal|low|medium|high|xhigh|max (pass-through; never silent demote)
  --cwd <dir>        worker cwd (default: current dir)
  --isolate          create an isolated git worktree
  --report <path>    require a deliverable report at reap
  --verify <cmd>     run a project verification command at reap
  --verify-name <s>  label for verification receipts (default: verify)
  --verify-timeout <seconds>
                    verification timeout in seconds (default: 1800)
  --prepare <cmd>    run setup command before --verify at reap
  --arg <flag>       pass an extra arg to the provider CLI

Exec opts:
  --model <id>       provider model override
  --effort <level>   none|minimal|low|medium|high|xhigh|max
  --cwd <dir>        worker cwd (default: current dir)
  -o <file>          write final message to file (default: stdout)

Billing safety:
  Claude workers refuse to launch when ANTHROPIC_API_KEY is set because that
  bills pay-as-you-go API rates instead of subscription/Agent-SDK credit.
  Unset ANTHROPIC_API_KEY, or intentionally override with:
    WASPFLOW_ALLOW_API_BILLING=1 waspflow spawn --provider claude ...

State: $WASPFLOW_HOME (default ~/.local/state/waspflow)
tmux:  $WASPFLOW_TMUX_SESSION (default waspflow)
EOF
}

# ---- arg splitting ----------------------------------------------------------
# Split argv at the first literal `--` into FLAGS (before) and REST (after).
# REST is the free-text prompt/message so it never needs quoting gymnastics.
split_after_ddash() {
  FLAGS=(); REST=()
  local seen=0
  for a in "$@"; do
    if [[ $seen -eq 0 && "$a" == "--" ]]; then seen=1; continue; fi
    if [[ $seen -eq 0 ]]; then FLAGS+=("$a"); else REST+=("$a"); fi
  done
}

# ============================================================================
# verbs
# ============================================================================

cmd_spawn() {
  local provider="" lane="" model="" cwd="$PWD" isolate=0 effort="" report="" no_recovery=0
  local verify_command="" verify_name="verify" verify_timeout=1800 prepare_command=""
  local op_id="" OP_ID="" OP_MODE=""
  local -a extra=()
  split_after_ddash "$@"
  set -- "${FLAGS[@]:-}"
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --provider) provider="${2:-}"; shift 2 ;;
      --op)       op_id="${2:-}"; shift 2 ;;
      --lane)     lane="${2:-}"; shift 2 ;;
      --model)    model="${2:-}"; shift 2 ;;
      --effort)   effort="${2:-}"; shift 2 ;;
      --cwd)      cwd="${2:-}"; shift 2 ;;
      --isolate|--worktree) isolate=1; shift ;;
      --report)   report="${2:-}"; shift 2 ;;     # opt-in deliverable contract
      --no-recovery) no_recovery=1; shift ;;
      --verify) verify_command="${2:-}"; shift 2 ;;
      --verify-name) verify_name="${2:-}"; shift 2 ;;
      --verify-timeout) verify_timeout="${2:-}"; shift 2 ;;
      --prepare) prepare_command="${2:-}"; shift 2 ;;
      --arg)      extra+=("${2:-}"); shift 2 ;;   # repeatable pass-through to the agent CLI
      "")         shift ;;
      *) die "spawn: unknown option '$1'" ;;
    esac
  done
  local prompt="${REST[*]:-}"

  # Expand --op first (explicit --provider/--model/--effort win over expansion).
  if [[ -n "$op_id" ]]; then
    ops_apply_to_spawn "$op_id"
  fi

  [[ -n "$provider" ]] || die "spawn: --provider or --op is required (claude|codex|grok)"
  is_known_provider "$provider" || die "spawn: unknown provider '$provider'"
  [[ -n "$lane" ]] || die "spawn: --lane is required"
  validate_lane_name "$lane"
  [[ -n "$prompt" ]] || die "spawn: a task prompt is required after '--'"
  cwd="$(cd "$cwd" && pwd)" || die "spawn: --cwd does not exist"
  guard_cwd "$cwd"   # never hand a worker '/' silently (known grok --cwd / crash)
  if [[ -n "$effort" && ! "$effort" =~ ^(none|minimal|low|medium|high|xhigh|max)$ ]]; then
    die "spawn: --effort must be one of none|minimal|low|medium|high|xhigh|max (got: $effort)"
  fi

  # If capabilities-derived whitelist is loaded, enforce per provider (after op expansion).
  if [[ -n "$effort" && -n "${provider:-}" ]]; then
    local _wl_var="WASPFLOW_EFFORTS_${provider^^}"
    local _wl="${!_wl_var:-}"
    if [[ -n "$_wl" && ! "$effort" =~ ^($_wl)$ ]]; then
      die "spawn: effort '$effort' not in capabilities whitelist for $provider (valid: ${_wl//|/, })"
    fi
  fi
  if [[ -n "$verify_command" ]]; then
    [[ -n "$verify_name" ]] || die "spawn: --verify-name cannot be empty"
    [[ "$verify_timeout" =~ ^[0-9]+$ && "$verify_timeout" -gt 0 ]] \
      || die "spawn: --verify-timeout must be a positive integer (got: $verify_timeout)"
  elif [[ -n "$prepare_command" ]]; then
    die "spawn: --prepare requires --verify"
  fi

  if lane_exists "$lane" && [[ "$(lane_get "$lane" status)" == "live" ]]; then
    die "lane '$lane' is already live (reap it first or pick another name)"
  fi

  require_cmd tmux jq
  load_provider "$provider"
  "${provider}_preflight" || die "spawn aborted: $provider preflight failed"

  # Worktree isolation (opt-in, only inside a git repo).
  local work_cwd="$cwd" wt_path="" repo_root=""
  if [[ "$isolate" -eq 1 ]]; then
    repo_root="$(worktree_repo_root "$cwd")"
    wt_path="$(worktree_create "$lane" "$cwd")" || die "spawn: worktree isolation failed"
    work_cwd="$wt_path"
    log "isolated worktree: $wt_path"
  fi

  local session_id transcript
  session_id="$(new_uuid)"           # claude/grok use this; codex mints its own
  mkdir -p "$(lane_dir "$lane")"
  transcript="$(lane_transcript "$lane")"
  : >"$transcript"

  # Resolve a --report path to absolute against the worker's working dir so the
  # agent writes it where we'll look for it.
  local report_abs=""
  if [[ -n "$report" ]]; then
    case "$report" in
      /*) report_abs="$report" ;;
      *)  report_abs="$work_cwd/$report" ;;
    esac
  fi

  # Record state BEFORE spawn so a crash mid-spawn is still recoverable.
  # Claude and Grok accept a client-minted --session-id; Codex discovers its own.
  local recorded_sid=""
  case "$provider" in claude|grok) recorded_sid="$session_id" ;; esac
  # When --op was used, record policy/catalog pins for lane→evidence traceability.
  local policy_version="" catalog_ref="" policy_file=""
  if [[ -n "${OP_ID:-}" ]]; then
    ops_load 2>/dev/null || true
    if [[ -n "${OPS_POLICY_JSON:-}" ]]; then
      policy_version="$(jq -r '.policy_version // empty' <<<"$OPS_POLICY_JSON")"
      catalog_ref="$(jq -r '.catalog_ref // empty' <<<"$OPS_POLICY_JSON")"
    fi
    policy_file="${OPS_POLICY_FILE:-}"
  fi

  lane_set "$lane" \
    provider "$provider" \
    status "live" \
    result "" \
    cwd "$work_cwd" \
    origin_cwd "$cwd" \
    model "$model" \
    effort "$effort" \
    effort_requested "$effort" \
    op "${OP_ID:-}" \
    op_mode "${OP_MODE:-}" \
    policy_version "$policy_version" \
    catalog_ref "$catalog_ref" \
    policy_file "$policy_file" \
    op_expands_to "${OP_EXPANDS_TO:-}" \
    explicit_overrides "${EXPLICIT_OVERRIDES:-[]}" \
    session_id "$recorded_sid" \
    rollout "" \
    worktree "$wt_path" \
    repo_root "$repo_root" \
    transcript "$transcript" \
    report "$report_abs" \
    no_recovery "$([[ "$no_recovery" -eq 1 ]] && echo true || echo false)" \
    verify_command "$verify_command" \
    verify_name "$verify_name" \
    verify_timeout "$verify_timeout" \
    prepare_command "$prepare_command" \
    spawn_epoch "$(date +%s)" \
    prompt "$prompt"

  # Durable artifacts: prompt + git-status-before, automatically (no flag).
  artifacts_capture_before "$lane" "$work_cwd" "$prompt"

  # Spawn + confirm the task actually submitted. A provider adapter returns nonzero
  # when it could not confirm submission (dead-on-arrival: window up, task never
  # injected — e.g. a modal stole focus). Record the lane either way so it stays
  # inspectable, but tell the caller LOUDLY and exit nonzero: a silent "spawned"
  # on a lane that never ran is the failure that makes an orchestrator report
  # phantom work in flight.
  local spawn_rc=0
  "${provider}_spawn" "$lane" "$work_cwd" "$model" "$session_id" "$transcript" "$prompt" "${extra[@]}" || spawn_rc=$?

  if [[ "$spawn_rc" -ne 0 ]]; then
    lane_set "$lane" spawn_submitted "false"
    err "spawn: lane '$lane' launched but the task was NOT confirmed submitted"
    err "  the worker may be stuck at a startup prompt (trust gate / MCP auth / other modal)."
    err "  inspect:  waspflow peek $lane        (see what is blocking)"
    err "  recover:  waspflow revise $lane -- \"<the task>\"   (re-inject once unblocked)"
    err "  the lane is recorded, so nothing is lost — but do NOT assume it is working."
    return 3
  fi
  lane_set "$lane" spawn_submitted "true"

  log "spawned $provider lane '$lane' (tmux: $WASPFLOW_TMUX_SESSION:$lane) — next: wait/peek/revise/reap $lane"
  [[ -n "$report_abs" ]] && log "  deliverable contract: $report_abs (verified on idle; one recovery pass if missing)"
  [[ -n "$verify_command" ]] && log "  verify contract: $verify_name -> $verify_command"
  return 0
}

cmd_exec() {
  exec_run "$@"
}

cmd_demo() {
  local provider="" lane="" run=0 cwd="$PWD"
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --provider) provider="${2:-}"; shift 2 ;;
      --lane) lane="${2:-}"; shift 2 ;;
      --cwd) cwd="${2:-}"; shift 2 ;;
      --run) run=1; shift ;;
      -h|--help)
        cat <<'EOF'
waspflow demo --provider <claude|codex|grok> [--run] [--lane NAME] [--cwd DIR]

Without --run, prints a safe first-run walkthrough.
With --run, performs spawn -> wait -> peek -> reap using a tiny no-edit task.
EOF
        return 0
        ;;
      *) die "demo: unknown option '$1'" ;;
    esac
  done

  if [[ -z "$provider" ]]; then
    if command -v codex >/dev/null 2>&1; then provider="codex"
    elif command -v claude >/dev/null 2>&1; then provider="claude"
    elif command -v grok >/dev/null 2>&1; then provider="grok"
    else die "demo: no provider found on PATH (install codex, claude, or grok, or pass --provider)"
    fi
  fi
  is_known_provider "$provider" || die "demo: unknown provider '$provider'"
  cwd="$(cd "$cwd" && pwd)" || die "demo: --cwd does not exist"
  lane="${lane:-demo-$(date +%s)}"
  validate_lane_name "$lane"

  local prompt="This is a waspflow first-run demo. Do not edit files. Reply with exactly one sentence that starts with 'waspflow demo ready'."
  if [[ "$run" -ne 1 ]]; then
    cat <<EOF
waspflow demo

This will prove the core loop with a no-edit task:

  waspflow spawn --provider $provider --lane $lane --cwd "$cwd" -- "$prompt"
  waspflow wait $lane --timeout 300
  waspflow peek $lane --lines 8
  waspflow reap $lane

Run it now:

  waspflow demo --provider $provider --lane $lane --cwd "$cwd" --run
EOF
    return 0
  fi

  cmd_spawn --provider "$provider" --lane "$lane" --cwd "$cwd" -- "$prompt"
  cmd_wait "$lane" --timeout 300
  cmd_peek "$lane" --lines 8
  cmd_reap "$lane"
}

cmd_list() {
  local status_filter=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --status) status_filter="${2:-}"; shift 2 ;;
      *) shift ;;
    esac
  done
  local lanes; lanes="$(list_lanes)"
  if [[ -z "$lanes" ]]; then echo "(no lanes)"; return 0; fi
  printf '%-20s %-8s %-8s %-11s %s\n' LANE PROVIDER STATE OUTCOME CWD
  local lane matched=0
  while IFS= read -r lane; do
    [[ -n "$lane" ]] || continue
    local provider status cwd live outcome
    provider="$(lane_get "$lane" provider)"
    status="$(lane_get "$lane" status)"
    cwd="$(lane_get "$lane" cwd)"
    outcome="$(lane_outcome "$lane")"
    # --status filters on the fan-in OUTCOME (the reap-safe question).
    if [[ -n "$status_filter" ]]; then
      fanin_outcome_matches "$lane" "$status_filter" || continue
    fi
    matched=1
    if tmux_window_exists "$lane"; then live="live"; else live="exited"; fi
    [[ "$status" == "reaped" ]] && live="reaped"
    printf '%-20s %-8s %-8s %-11s %s\n' "$lane" "$provider" "$live" "$outcome" "$cwd"
  done <<<"$lanes"
  [[ -n "$status_filter" && "$matched" -eq 0 ]] && echo "(no lanes with outcome in: $status_filter)"
  return 0
}

cmd_close() {
  local lane="" outcome="" pkey="" pval=""
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --status)  outcome="${2:-}"; shift 2 ;;
      --into)    pkey="into";   pval="${2:-}"; shift 2 ;;
      --by)      pkey="by";     pval="${2:-}"; shift 2 ;;
      --reason)  pkey="reason"; pval="${2:-}"; shift 2 ;;
      "")        shift ;;
      -*)        die "close: unknown option '$1'" ;;
      *)         [[ -z "$lane" ]] && { lane="$1"; shift; } || die "close: unexpected arg '$1'" ;;
    esac
  done
  [[ -n "$lane" ]]    || die "close: <lane> required"
  [[ -n "$outcome" ]] || die "close: --status <harvested|superseded|abandoned|open> required"
  fanin_close "$lane" "$outcome" "$pkey" "$pval"
}

cmd_captured() {
  local lane="" ref=""
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --in) ref="${2:-}"; shift 2 ;;
      "")   shift ;;
      -*)   die "captured: unknown option '$1'" ;;
      *)    [[ -z "$lane" ]] && { lane="$1"; shift; } || die "captured: unexpected arg '$1'" ;;
    esac
  done
  [[ -n "$lane" ]] || die "captured: <lane> required"
  [[ -n "$ref" ]]  || die "captured: --in <ref> required"
  fanin_captured "$lane" "$ref"   # prints verdict to stdout, summary to stderr
}

cmd_status() {
  local lane="${1:-}"; [[ -n "$lane" ]] || die "status: <lane> required"
  lane_exists "$lane" || die "no such lane '$lane'"
  # Pretty-print the state, but on malformed JSON emit a clear waspflow error
  # instead of leaking a raw `jq: parse error` to the operator (red-team finding).
  local sf; sf="$(lane_state_file "$lane")"
  jq . "$sf" 2>/dev/null || die "lane '$lane' has corrupted state.json ($sf) — cannot parse"
}

cmd_peek() {
  local lane="${1:-}" lines=40; shift || true
  while [[ $# -gt 0 ]]; do case "$1" in --lines) lines="${2:-40}"; shift 2 ;; *) shift ;; esac; done
  [[ -n "$lane" ]] || die "peek: <lane> required"
  if tmux_window_exists "$lane"; then
    tmux capture-pane -p -t "$(tmux_window_target "$lane")" -S -"$lines" 2>/dev/null \
      | strip_ansi | grep -v '^$' | tail -"$lines"
  else
    local t; t="$(lane_get "$lane" transcript)"
    [[ -f "$t" ]] || die "peek: lane '$lane' has no live window and no transcript"
    strip_ansi <"$t" | grep -v '^$' | tail -"$lines"
  fi
}

cmd_wait() {
  local lane="${1:-}" timeout=600 interval=2; shift || true
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --timeout) timeout="${2:-600}"; shift 2 ;;
      --interval) interval="${2:-2}"; shift 2 ;;
      *) shift ;;
    esac
  done
  [[ -n "$lane" ]] || die "wait: <lane> required"
  lane_exists "$lane" || die "no such lane '$lane'"
  local provider; provider="$(lane_get "$lane" provider)"
  load_provider "$provider"
  require_cmd jq

  # Stale-idle barrier. A live `revise` starts a new turn asynchronously; the
  # provider's idle predicate reads the LAST terminal event, which — in the window
  # right after revise — is still the PRIOR turn's end_turn/task_complete. So a
  # bare `revise x; wait` would return instantly on the previous turn's idle and
  # silently drop the steering instruction.
  #
  # Barrier signal: revise records revise_barrier_mark = the provider's turn_mark
  # (session-log line count) at revise time. wait honors an idle reading only once
  # turn_mark has ADVANCED past that value — i.e. the new turn actually appended a
  # session event (the pasted user message alone advances it). This keys on the
  # PROVIDER SESSION LOG, not the pane transcript, so it is immune to the paste
  # echo growing the transcript. Self-clearing and order-independent: if the
  # revised turn completes before wait is ever called, turn_mark is already past
  # the mark, so the barrier clears on the first poll — no stale flag, no false
  # timeout. A one-time barrier: once satisfied it never re-arms within this call.
  local barrier_mark
  barrier_mark="$(lane_get "$lane" revise_barrier_mark)"
  local barrier_cleared=0
  [[ -n "$barrier_mark" ]] || barrier_cleared=1

  # Mid-run interactive-prompt (stall) detection. A worker can BLOCK mid-turn on a
  # prompt that expects a human keystroke (quota/model-downgrade offer, security
  # wait, y/n). It never reaches idle, so plain `wait` would stall blind until
  # timeout. We watch the lane transcript for activity: if it stops growing for
  # WASPFLOW_STALL_SECONDS *and* the pane looks blocked, return a distinct
  # 'blocked' state (rc 4) with the pane text — so the orchestrator answers via
  # `revise` in seconds instead of losing the whole timeout. We never auto-answer.
  local stall_secs="${WASPFLOW_STALL_SECONDS:-45}"
  local transcript; transcript="$(lane_transcript "$lane")"
  local last_size; last_size="$(wc -c <"$transcript" 2>/dev/null || echo 0)"
  local last_change; last_change="$(date +%s)"

  local deadline=$(( $(date +%s) + timeout ))
  while :; do
    if [[ "$barrier_cleared" -eq 0 ]]; then
      local cur_mark; cur_mark="$("${provider}_turn_mark" "$lane" 2>/dev/null || echo 0)"
      if [[ "${cur_mark:-0}" -gt "$barrier_mark" ]]; then
        # New turn appended a session event past the revise mark — barrier satisfied.
        barrier_cleared=1
        lane_set "$lane" revise_barrier_mark ""
      fi
    fi
    if [[ "$barrier_cleared" -eq 1 ]] && "${provider}_is_idle" "$lane"; then
      # Capture the change so far (cheap, idempotent). Deliverable enforcement +
      # the honest result happen at reap (the explicit end-of-run), so an
      # intermediate idle between revise turns doesn't trigger premature recovery.
      artifacts_capture_after "$lane"
      log "wait: lane '$lane' is IDLE"
      return 0
    fi
    # --- stall check ---
    # The ROBUST signal is STALL itself, not prompt wording: the worker produced no
    # output for stall_secs while its turn hasn't ended. Whatever the cause — an
    # interactive prompt awaiting input, a hung backend, a network wait — the right
    # action is the SAME: stop waiting blind, surface it, let the orchestrator peek
    # and decide. We do NOT gate on matching the prompt text (that's brittle: it
    # breaks the moment a provider rephrases or a new prompt type appears). Prompt
    # matching is only an optional HINT in the message, never the trigger.
    local now cur_size; now="$(date +%s)"
    cur_size="$(wc -c <"$transcript" 2>/dev/null || echo 0)"
    if [[ "$cur_size" != "$last_size" ]]; then
      last_size="$cur_size"; last_change="$now"      # activity → reset the stall clock
    elif [[ $(( now - last_change )) -ge "$stall_secs" ]]; then
      local pane hint=""
      pane="$(tmux capture-pane -p -t "$(tmux_window_target "$lane")" -S -40 2>/dev/null | strip_ansi)"
      hint="$(wf_pane_looks_blocked "$pane" || true)"   # optional: names a likely prompt shape
      lane_set "$lane" wait_state "stalled" stalled_after "$stall_secs" \
        blocked_hint "${hint:-unknown (no output; could be a prompt, a hang, or a slow tool)}"
      warn "wait: lane '$lane' STALLED — no output for ${stall_secs}s and turn not ended${hint:+ (looks like: $hint)}"
      warn "  the worker may be waiting on an interactive prompt (e.g. a quota/model-downgrade"
      warn "  offer or a security check) or genuinely hung. waspflow never auto-answers. Inspect:"
      warn "    waspflow peek $lane            # see exactly what it's waiting on"
      warn "    waspflow revise $lane -- \"<answer>\"   # answer a prompt (e.g. 1 / yes / no) — YOUR call"
      warn "  or raise --interval/WASPFLOW_STALL_SECONDS if this turn is just slow."
      return 4
    fi
    if [[ "$now" -ge "$deadline" ]]; then
      warn "wait: TIMEOUT after ${timeout}s (lane '$lane' never went idle)"
      return 1
    fi
    sleep "$interval"
  done
}

cmd_revise() {
  split_after_ddash "$@"
  local lane="" out=""
  set -- "${FLAGS[@]:-}"
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --out) out="${2:-}"; shift 2 ;;
      "") shift ;;
      *) [[ -z "$lane" ]] && { lane="$1"; shift; } || die "revise: unexpected arg '$1'" ;;
    esac
  done
  local message="${REST[*]:-}"
  [[ -n "$lane" ]] || die "revise: <lane> required"
  [[ -n "$message" ]] || die "revise: a message is required after '--'"
  lane_exists "$lane" || die "no such lane '$lane'"
  local provider; provider="$(lane_get "$lane" provider)"
  load_provider "$provider"
  if tmux_window_exists "$lane"; then
    log "revise: steering live pane for lane '$lane'"
    # Live steer starts a NEW turn asynchronously; record the provider turn_mark
    # (session-log line count) now so a following `wait` won't honor the PRIOR
    # turn's stale idle until turn_mark advances past this (see cmd_wait barrier).
    # Headless resume (else branch) blocks until the reply, so it needs no barrier.
    local mark
    mark="$("${provider}_turn_mark" "$lane" 2>/dev/null || echo 0)"
    lane_set "$lane" revise_barrier_mark "$mark"
  else
    log "revise: lane '$lane' window exited; resuming session headlessly"
  fi
  "${provider}_revise" "$lane" "$message" "$out"
}

cmd_attach() {
  local lane="${1:-}"; [[ -n "$lane" ]] || die "attach: <lane> required"
  tmux_window_exists "$lane" || die "attach: lane '$lane' has no live window"
  log "attaching to $WASPFLOW_TMUX_SESSION:$lane (detach with Ctrl-b d)"
  tmux select-window -t "$(tmux_window_target "$lane")"
  tmux attach-session -t "$WASPFLOW_TMUX_SESSION"
}

cmd_reap() {
  local lane="" force=0 keep_wt=0 no_archive=0 status_filter=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force=1; shift ;;
      --keep-worktree) keep_wt=1; shift ;;
      --no-archive) no_archive=1; shift ;;
      --status) status_filter="${2:-}"; shift 2 ;;   # batch: reap the reap-safe set
      -*) die "reap: unknown option '$1'" ;;
      "") shift ;;
      *) [[ -z "$lane" ]] && { lane="$1"; shift; } || die "reap: unexpected arg '$1'" ;;
    esac
  done

  # Batch mode: reap every lane whose fan-in outcome matches the filter. This is
  # the one-command fan-in cleanup — `reap --status harvested,superseded,abandoned`.
  if [[ -n "$status_filter" ]]; then
    [[ -z "$lane" ]] || die "reap: give a <lane> OR --status, not both"
    local rc=0 any=0 l
    while IFS= read -r l; do
      [[ -n "$l" ]] || continue
      [[ "$(lane_get "$l" status)" == "reaped" ]] && continue   # already reaped
      fanin_outcome_matches "$l" "$status_filter" || continue
      any=1
      _reap_one "$l" "$force" "$keep_wt" "$no_archive" || rc=$?
    done < <(list_lanes)
    [[ "$any" -eq 1 ]] || log "reap: no lanes with outcome in: $status_filter"
    return "$rc"
  fi

  [[ -n "$lane" ]] || die "reap: <lane> required (or --status S,... for batch)"
  lane_exists "$lane" || die "no such lane '$lane'"
  _reap_one "$lane" "$force" "$keep_wt" "$no_archive"
}

# Reap a single lane. Args: lane force keep_wt no_archive. Returns 2 on an unmet
# deliverable/verification contract so callers/CI can key on it.
_reap_one() {
  local lane="$1" force="$2" keep_wt="$3" no_archive="$4"
  local provider; provider="$(lane_get "$lane" provider)"
  load_provider "$provider"

  # Finalize FIRST (before killing the window or removing the worktree): capture
  # the diff, enforce any --report contract, and — if the report is missing —
  # run one recovery pass. Recovery may resume the live pane OR the exited
  # session, and needs the worktree intact to read the diff + write the report.
  local result; result="$(artifacts_finalize "$lane" "$provider")"
  result="$(artifacts_verify "$lane" "$result")"

  if tmux_window_exists "$lane"; then
    tmux kill-window -t "$(tmux_window_target "$lane")" 2>/dev/null || true
  fi

  # Bundle-before-reap: archive the branch tip to a verified git bundle BEFORE
  # removing the worktree/branch, so "reaping is cleanup, not data loss" holds
  # even for unpushed branches. --no-archive opts out for the truly disposable.
  [[ "$no_archive" -eq 1 ]] || fanin_bundle_lane "$lane" || true

  local wt; wt="$(lane_get "$lane" worktree)"
  if [[ -n "$wt" && "$keep_wt" -ne 1 ]]; then
    local repo_root; repo_root="$(lane_get "$lane" repo_root)"
    if worktree_remove "$lane" "$wt" "$repo_root" "$force"; then
      log "reap: removed worktree $wt"
    fi
  fi

  lane_set "$lane" status "reaped"
  case "$result" in
    succeeded)       log "reap: lane '$lane' reaped — result=succeeded" ;;
    verified)        log "reap: lane '$lane' reaped — result=verified" ;;
    recovered)       warn "reap: lane '$lane' reaped — result=recovered (report rebuilt by recovery pass)" ;;
    verify_failed)   err  "reap: lane '$lane' reaped — result=verify_failed" ;;
    report_missing)  err  "reap: lane '$lane' reaped — result=report_missing (recovery disabled)" ;;
    failed)          err  "reap: lane '$lane' reaped — result=failed (required report never produced)" ;;
    *)               log "reap: lane '$lane' reaped" ;;
  esac
  case "$result" in failed|report_missing|verify_failed) return 2 ;; esac
  return 0
}

cmd_doctor() {
  echo "waspflow doctor"
  echo "  WASPFLOW_HOME = $WASPFLOW_HOME"
  echo "  tmux session  = $WASPFLOW_TMUX_SESSION"
  local ok=1
  local agent_ok=0
  for c in tmux jq git; do
    if command -v "$c" >/dev/null 2>&1; then echo "  [ok]   $c"; else echo "  [MISS] $c (required)"; ok=0; fi
  done
  command -v curl >/dev/null 2>&1 || ok=0
  command -v uuidgen >/dev/null 2>&1 || [[ -r /proc/sys/kernel/random/uuid ]] || ok=0
  for c in claude codex grok curl uuidgen; do
    if command -v "$c" >/dev/null 2>&1; then
      echo "  [ok]   $c"
      [[ "$c" == "claude" || "$c" == "codex" || "$c" == "grok" ]] && agent_ok=1
    elif [[ "$c" == "curl" || "$c" == "uuidgen" ]]; then
      echo "  [MISS] $c (required on systems without an equivalent)"
    else
      echo "  [warn] $c (install at least one agent CLI)"
    fi
  done
  if ! command -v uuidgen >/dev/null 2>&1 && [[ -r /proc/sys/kernel/random/uuid ]]; then
    echo "  [ok]   /proc/sys/kernel/random/uuid"
  fi
  # Codex backend
  local url="$WASPFLOW_CODEX_BACKEND_HEALTH_URL"
  if [[ -n "$url" ]] && command -v curl >/dev/null 2>&1; then
    local code; code="$(curl -s -o /dev/null -w '%{http_code}' --max-time 4 "$url" 2>/dev/null || echo 000)"
    if [[ "$code" == "200" ]]; then echo "  [ok]   codex model proxy $url"; else
      echo "  [warn] codex model proxy $url -> $code (start your Codex proxy, or unset WASPFLOW_CODEX_BACKEND_HEALTH_URL)"; fi
  fi
  billing_report_auth
  [[ "$agent_ok" -eq 1 ]] || ok=0
  [[ "$ok" -eq 1 ]] || {
    echo "  -> missing prerequisites"
    echo "     see: $WASPFLOW_ROOT/docs/prerequisites.md"
    return 1
  }
  echo "  -> ready"
}

# ============================================================================
main() {
  local verb="${1:-}"; shift || true
  case "$verb" in
    spawn)  cmd_spawn "$@" ;;
    exec)   cmd_exec "$@" ;;
    ops)    cmd_ops "$@" ;;
    init)   cmd_init "$@" ;;
    demo)   cmd_demo "$@" ;;
    list|ls) cmd_list "$@" ;;
    status) cmd_status "$@" ;;
    peek)   cmd_peek "$@" ;;
    wait)   cmd_wait "$@" ;;
    revise) cmd_revise "$@" ;;
    attach) cmd_attach "$@" ;;
    close)  cmd_close "$@" ;;
    captured) cmd_captured "$@" ;;
    reap)   cmd_reap "$@" ;;
    check)  cmd_check "$@" ;;
    doctor) cmd_doctor "$@" ;;
    -h|--help|help|"") usage ;;
    *) die "unknown command '$verb' (try: waspflow help)" ;;
  esac
}
main "$@"
